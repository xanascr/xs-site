<div id="searchOverlay" class="fixed inset-0 z-[100] hidden bg-black/40 backdrop-blur-sm">
  <div class="flex items-start justify-center pt-[15vh] px-4">
    <div class="w-full max-w-xl bg-white rounded-2xl shadow-2xl border border-gray-200 overflow-hidden animate-up">
      <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100">
        <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="searchInput" type="text" placeholder="Search courses, docs, packages..." class="flex-1 border-0 outline-none text-sm bg-transparent text-gray-800 placeholder-gray-400" autocomplete="off" autocorrect="off" autofocus>
        <kbd class="text-xs text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded font-mono">ESC</kbd>
      </div>
      <div id="searchResults" class="max-h-[50vh] overflow-y-auto">
        <div class="text-center py-8 text-sm text-gray-400">Type to search...</div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var overlay = document.getElementById('searchOverlay');
  var input = document.getElementById('searchInput');
  var results = document.getElementById('searchResults');
  var activeIndex = -1;
  var debounceTimer = null;

  function openSearch() {
    overlay.classList.remove('hidden');
    input.value = '';
    results.innerHTML = '<div class="text-center py-8 text-sm text-gray-400">Type to search...</div>';
    activeIndex = -1;
    setTimeout(function() { input.focus(); }, 50);
  }

  function closeSearch() {
    overlay.classList.add('hidden');
    input.blur();
  }

  // CmdK / CtrlK / slash
  document.addEventListener('keydown', function(e) {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (overlay.classList.contains('hidden')) openSearch();
      else closeSearch();
    }
    if (e.key === '/' && !['INPUT', 'TEXTAREA', 'SELECT'].includes(e.target.tagName) && e.target.getAttribute('contenteditable') !== 'true') {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape') closeSearch();
  });

  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) closeSearch();
  });

  input.addEventListener('keydown', function(e) {
    var items = results.querySelectorAll('[data-url]');
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIndex = Math.min(activeIndex + 1, items.length - 1);
      highlight(items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIndex = Math.max(activeIndex - 1, 0);
      highlight(items);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (items[activeIndex]) {
        closeSearch();
        window.location.href = items[activeIndex].getAttribute('data-url');
      }
    }
  });

  function highlight(items) {
    items.forEach(function(el, i) {
      if (i === activeIndex) el.classList.add('bg-pinky-50', 'border-pinky-200');
      else el.classList.remove('bg-pinky-50', 'border-pinky-200');
    });
    if (items[activeIndex]) items[activeIndex].scrollIntoView({ block: 'nearest' });
  }

  input.addEventListener('input', function() {
    clearTimeout(debounceTimer);
    var q = input.value.trim();
    if (!q) {
      results.innerHTML = '<div class="text-center py-8 text-sm text-gray-400">Type to search...</div>';
      return;
    }
    debounceTimer = setTimeout(function() {
      activeIndex = -1;
      fetch('/api/search?q=' + encodeURIComponent(q))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data.ok || !data.results || data.results.length === 0) {
            results.innerHTML = '<div class="text-center py-8 text-sm text-gray-400">No results for "' + escapeHtml(q) + '"</div>';
            return;
          }
          var html = '<div class="py-1">';
          data.results.forEach(function(r) {
            html += '<a href="' + r.url + '" data-url="' + r.url + '" class="flex items-center gap-3 px-4 py-2.5 border-l-2 border-transparent hover:bg-pinky-50 hover:border-pinky-200 no-underline transition-all cursor-pointer">'
              + '<span class="text-sm">' + (r.label || '') + '</span>'
              + '<span class="text-xs text-gray-400 ml-auto">' + r.type + '</span>'
              + '</a>';
          });
          html += '</div>';
          results.innerHTML = html;
        })
        .catch(function() {
          results.innerHTML = '<div class="text-center py-8 text-sm text-red-400">Search failed.</div>';
        });
    }, 200);
  });

  function escapeHtml(str) {
    var d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }
})();
</script>