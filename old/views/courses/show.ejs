<%- include('../partials/head', {}) %>
<%- include('../partials/navbar', {}) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-4xl mx-auto">
    <a href="/courses" class="text-sm text-gray-400 hover:text-pinky-400 no-underline mb-4 inline-block">&larr; Voltar para cursos</a>

    <div class="xs-card xs-card-glass animate-fade-in">
      <div class="p-6 sm:p-8">
        <div class="flex flex-wrap items-center gap-2 mb-4">
          <span class="xs-tag xs-tag-primary"><%= course.category || 'Geral' %></span>
          <span class="xs-tag xs-tag-ghost"><%= course.level || 'Iniciante' %></span>
          <span class="xs-tag xs-tag-ghost"><%= course.lessons ? course.lessons.length : 0 %> lições</span>
          <span class="xs-tag xs-tag-ghost"><%= course.totalPoints || 0 %> pts</span>
          <% if (course.duration) { %><span class="xs-tag xs-tag-ghost"><%= course.duration %></span><% } %>
        </div>

        <h1 class="text-2xl sm:text-3xl font-black mb-3"><%= course.title %></h1>
        <p class="text-gray-500 text-sm sm:text-base mb-6"><%= course.description || '' %></p>

        <div class="flex items-stretch gap-3 mb-6" id="enrollSection">
          <% if (!enrollment) { %>
            <button id="enrollBtn" class="xs-btn xs-btn-primary text-base px-8 py-3">Iniciar Curso</button>
          <% } else { %>
            <% var pct = course.totalPoints > 0 ? Math.round((enrollment.points || 0) / course.totalPoints * 100) : 0 %>
            <% var doneCount = (enrollment.progress || []).filter(function(p) { return p.completed; }).length %>
            <% var totalCount = (course.lessons || []).length %>
            <% var nextLesson = (course.lessons || []).find(function(l) { var p = (enrollment.progress || []).find(function(x) { return x.lessonSlug === l.slug }); return !p || !p.completed; }) || course.lessons[0] %>
            <a href="/courses/<%= course.slug %>/lessons/<%= nextLesson.slug %>" class="xs-btn xs-btn-primary text-base px-8 py-3 no-underline"><%= (doneCount === 0) ? 'Iniciar Primeira Lição' : (doneCount < totalCount ? 'Continuar Aprendendo' : 'Revisar Curso') %></a>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between text-xs text-gray-500 mb-1">
                <span><%= doneCount %>/<%= totalCount %> lições concluídas</span>
                <span><%= enrollment.points || 0 %>/<%= course.totalPoints || 0 %> pts</span>
              </div>
              <div class="w-full h-2.5 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full bg-green-500 rounded-full transition-all duration-500" style="width:<%= pct %>%"></div>
              </div>
            </div>
          <% } %>
        </div>

        <% if (enrollment && enrollment.certificateEligible) { %>
          <div class="mb-6 bg-amber-50 border border-amber-200 rounded-xl p-5">
            <div class="flex items-center gap-3">
              <svg class="w-8 h-8 text-amber-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <div>
                <h3 class="font-bold text-amber-800">Parabéns!</h3>
                <p class="text-sm text-amber-700">Você completou todas as lições. <a href="/courses/<%= course.slug %>/certificate" class="font-semibold underline">Solicitar certificado</a>.</p>
              </div>
            </div>
          </div>
        <% } %>

        <% var moduleSize = 7; var lessonCount = (course.lessons || []).length; var moduleCount = Math.ceil(lessonCount / moduleSize); %>
        <h2 class="text-xl font-bold mb-4">Conteúdo do Curso (<%= lessonCount %> lições)</h2>
        <% for (var modIdx = 0; modIdx < moduleCount; modIdx++) { %>
          <div class="mb-6">
            <div class="flex items-center gap-2 mb-2">
              <h3 class="text-base font-bold text-gray-700">Módulo <%= modIdx + 1 %></h3>
              <a href="/courses/<%= course.slug %>/quiz/<%= modIdx %>" class="ml-auto text-xs font-semibold text-pinky-500 hover:text-pinky-600 no-underline">Fazer Quiz &rarr;</a>
            </div>
            <div class="space-y-1.5">
              <% for (var li = modIdx * moduleSize; li < Math.min((modIdx + 1) * moduleSize, lessonCount); li++) { %>
                <%
                var lesson = course.lessons[li];
                var prog = enrollment ? (enrollment.progress || []).find(function(p) { return p.lessonSlug === lesson.slug }) : null;
                var done = prog && prog.completed;
                %>
                <a href="/courses/<%= course.slug %>/lessons/<%= lesson.slug %>" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl px-4 py-2.5 no-underline transition-all hover:border-pinky-400 hover:shadow-sm <%= done ? 'border-green-200 bg-green-50/40' : '' %>">
                  <div class="w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-bold shrink-0 <%= done ? 'bg-green-500 text-white' : 'bg-gray-100 text-gray-400' %>"><%= done ? 'OK' : (li + 1) %></div>
                  <div class="flex-1 min-w-0">
                    <div class="font-semibold text-sm text-gray-800 truncate"><%= lesson.title %></div>
                    <div class="text-xs text-gray-400"><%= lesson.points || 0 %> pts<% if (lesson.challenges && lesson.challenges.length > 0) { %> - <%= lesson.challenges.length %> desafio(s)<% } %></div>
                  </div>
                  <% if (!done) { %><span class="text-xs font-semibold text-pinky-400 shrink-0"><%= (!prog || !prog.completed) && enrollment ? 'Iniciar' : '' %></span><% } %>
                  <svg class="w-4 h-4 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </a>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  var enrollBtn = document.getElementById('enrollBtn');
  if (!enrollBtn) return;

  enrollBtn.addEventListener('click', function() {
    var token = localStorage.getItem('xs_token') || document.cookie.match(/xs_token=([^;]+)/)?.[1];
    if (!token) {
      window.location.href = '/login?redirect=/courses/<%= course.slug %>';
      return;
    }

    enrollBtn.disabled = true;
    enrollBtn.textContent = 'Inscrevendo...';

    fetch('/api/courses/<%= course.slug %>/enroll', {
      method: 'POST',
      headers: { 'Authorization': 'Bearer ' + token }
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.ok) { window.location.reload(); }
      else {
        alert(d.error || 'Inscrição falhou. Tente novamente.');
        enrollBtn.disabled = false;
        enrollBtn.textContent = 'Iniciar Curso';
      }
    })
    .catch(function() {
      alert('Erro de rede.');
      enrollBtn.disabled = false;
      enrollBtn.textContent = 'Iniciar Curso';
    });
  });
})();
</script>

<%- include('../partials/footer', {}) %>