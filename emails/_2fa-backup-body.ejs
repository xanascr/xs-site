<p>Hi <strong><%= username %></strong>,</p>
<p>You requested new backup codes for your account. Each code can be used <strong>only once</strong>.</p>
<p style="font-size:13px;color:#6b7280">Store these in a safe place — they will not be shown again.</p>
<div class="code-block" style="font-size:14px;letter-spacing:1px;line-height:1.8">
  <% codes.forEach(function(c) { %><%= c %>
<% }) %>
</div>
<hr class="hr">
<p style="font-size:13px;color:#6b7280">If you did not request new codes, <a href="<%= resetLink %>" style="color:#f58b8e">secure your account immediately</a>.</p>
