<%- include('layout', {
  body: `
    <p>Hi <strong><%= username %></strong>,</p>
    <p>Your package <strong><%= packageName %>@<%= packageVersion %></strong> has been <span style="color:#059669;font-weight:700">approved</span> and published!</p>
    <p style="text-align:center">
      <a class="btn" href="<%= link %>">View Package</a>
    </p>
    <p>Install it with:</p>
    <div class="code-block">xs install <%= packageName %></div>
    <hr class="hr">
    <p style="font-size:13px;color:#6b7280">Thank you for contributing to the XanaScript ecosystem!</p>
  `
}) %>
