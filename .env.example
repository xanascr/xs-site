PORT=3010
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://user:password@host:27017/xanascript

# Redis (optional — cache will be disabled if unavailable)
REDIS_URL=redis://:password@host:5432/0

# SeaweedFS (optional — uploads disabled if unavailable)
SEAWEEDFS_MASTER=http://localhost:9333
SEAWEEDFS_VOLUME=http://localhost:8080
SEAWEEDFS_USERNAME=your_username
SEAWEEDFS_PASSWORD=your_password

# JWT / session
SESSION_SECRET=your-session-secret-change-this
JWT_SECRET=your-jwt-secret-change-this

# SMTP
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USER=admin@example.com
EMAIL_PASS=your-smtp-password

# Personal access tokens — generate via Admin Panel > API Keys

# Seed admin (run: node scripts/seed-admin.mjs)
SEED_EMAIL=admin@example.com
SEED_PASSWORD=jOtC-y9q6ce0GSaS8siH
SEED_ROLE=admin
