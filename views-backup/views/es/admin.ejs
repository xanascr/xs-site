<%- include('../partials/head', { lang, t, alternates }) %>
<%- include('../partials/navbar', { lang, t }) %>

<div id="adminRoot" class="hidden">
<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-5xl mx-auto">
    <div id="adminHeader">
      <h1 class="text-3xl font-black mb-2">Panel de Administracion</h1>
      <p class="text-gray-500 text-sm mb-8">Revisa y aprueba paquetes enviados al registro.</p>
    </div>

    <div id="adminContent">
      <div class="flex gap-2 mb-6">
        <button class="tab-btn text-sm px-4 py-2 rounded-lg font-semibold bg-pinky-400 text-white" data-status="pending">Pendientes</button>
        <button class="tab-btn text-sm px-4 py-2 rounded-lg font-semibold bg-gray-100 text-gray-500 hover:bg-gray-200" data-status="approved">Aprobados</button>
        <button class="tab-btn text-sm px-4 py-2 rounded-lg font-semibold bg-gray-100 text-gray-500 hover:bg-gray-200" data-status="rejected">Rechazados</button>
      </div>
      <div id="adminList" class="space-y-4 mb-12"></div>
    </div>

    <div id="apiKeysSection" class="hidden">
      <h2 class="text-xl font-black mb-4">Llaves de API</h2>
      <p class="text-sm text-gray-500 mb-4">Tokens de acceso personal para operaciones automatizadas (CLI publish, CI/CD).</p>

      <div class="flex gap-2 mb-4">
        <input id="newKeyName" type="text" placeholder="ej: mi-ci-cd" maxlength="64" class="flex-1 px-4 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-pinky-400">
        <button id="createKeyBtn" class="bg-pinky-400 hover:bg-pinky-500 text-white font-semibold px-4 py-2 rounded-xl text-sm transition-all">Generar</button>
      </div>

      <div id="newKeyResult" class="hidden bg-amber-50 border border-amber-200 rounded-xl p-4 mb-4">
        <p class="text-sm font-semibold text-amber-800 mb-1">Guarda este token — no se mostrara de nuevo!</p>
        <code id="newKeyValue" class="block bg-white border border-amber-200 rounded-lg px-3 py-2 text-sm font-mono select-all"></code>
      </div>

      <div id="keysList" class="space-y-3"></div>
    </div>
  </div>
</section>
</div>

<script>
(function() {
  var token = localStorage.getItem('xs_token');

  if (!token) {
    window.location.href = '/<%= lang %>/login';
    return;
  }

  fetch('/api/auth/me', { headers: { 'Authorization': 'Bearer ' + token } })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.ok || data.user.role !== 'admin') {
        window.location.href = '/<%= lang %>/packages/dashboard';
        return;
      }
      document.getElementById('adminRoot').classList.remove('hidden');
      initAdmin(token);
    })
    .catch(function() {
      window.location.href = '/<%= lang %>/login';
    });

  function initAdmin(tkn) {
    var currentStatus = 'pending';

    function loadPackages(status) {
      fetch('/api/admin/packages?status=' + status, { headers: { 'Authorization': 'Bearer ' + tkn } })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var list = document.getElementById('adminList');
          list.innerHTML = '';
          if (!data.ok || !data.packages || data.packages.length === 0) {
            list.innerHTML = '<p class="text-center text-gray-400 text-sm py-8">No hay paquetes ' + status + '.</p>';
            return;
          }
          data.packages.forEach(function(pkg) {
            var div = document.createElement('div');
            div.className = 'bg-white rounded-2xl border border-gray-200 p-5';
            var actions = status === 'pending'
              ? '<div class="flex gap-2 mt-3"><button class="approve-btn text-xs bg-green-100 text-green-700 px-3 py-1.5 rounded-lg font-semibold hover:bg-green-200 transition-colors" data-name="' + pkg.name + '">Aprobar</button><button class="reject-btn text-xs bg-red-100 text-red-600 px-3 py-1.5 rounded-lg font-semibold hover:bg-red-200 transition-colors" data-name="' + pkg.name + '">Rechazar</button></div>'
              : '';
            var notes = pkg.reviewNotes ? '<div class="mt-2 text-sm text-gray-500 bg-gray-50 rounded-lg px-3 py-2">Notas: ' + pkg.reviewNotes + '</div>' : '';
            div.innerHTML = '<div class="flex items-start justify-between"><div><h3 class="font-bold text-gray-800">' + pkg.name + '</h3><p class="text-sm text-gray-500 mt-1">' + (pkg.description || '') + '</p><p class="text-xs text-gray-400 mt-1">por ' + (pkg.authorId?.username || pkg.author || 'desconocido') + ' | v' + pkg.version + ' | ' + (pkg.license || 'N/A') + '</p></div></div>' + actions + notes + '<div class="mt-2 text-xs text-gray-400">Enviado ' + new Date(pkg.createdAt).toLocaleDateString() + ' | ' + (pkg.downloads || 0) + ' dl</div></div>';
            list.appendChild(div);
          });
          document.querySelectorAll('.approve-btn').forEach(function(btn) {
            btn.onclick = function() {
              fetch('/api/admin/packages/' + this.dataset.name + '/approve', { method: 'POST', headers: { 'Authorization': 'Bearer ' + tkn } })
                .then(function(r) { return r.json(); })
                .then(function(d) { if (d.ok) loadPackages(currentStatus); });
            };
          });
          document.querySelectorAll('.reject-btn').forEach(function(btn) {
            btn.onclick = function() {
              var reason = prompt('Razon del rechazo:');
              if (reason === null) return;
              fetch('/api/admin/packages/' + this.dataset.name + '/reject', { method: 'POST', headers: { 'Authorization': 'Bearer ' + tkn, 'Content-Type': 'application/json' }, body: JSON.stringify({ reason: reason || 'Sin motivo' }) })
                .then(function(r) { return r.json(); })
                .then(function(d) { if (d.ok) loadPackages(currentStatus); });
            };
          });
        });
    }

    document.querySelectorAll('.tab-btn').forEach(function(btn) {
      btn.onclick = function() {
        document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('bg-pinky-400', 'text-white'); b.classList.add('bg-gray-100', 'text-gray-500'); });
        this.classList.add('bg-pinky-400', 'text-white'); this.classList.remove('bg-gray-100', 'text-gray-500');
        currentStatus = this.dataset.status;
        loadPackages(currentStatus);
      };
    });

    loadPackages('pending');
    loadKeys();

    function loadKeys() {
      fetch('/api/auth/api-keys', { headers: { 'Authorization': 'Bearer ' + tkn } })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var list = document.getElementById('keysList');
          list.innerHTML = '';
          if (!data.ok || !data.keys || data.keys.length === 0) {
            list.innerHTML = '<p class="text-center text-gray-400 text-sm py-6">No hay llaves de API. Genera una arriba.</p>';
            return;
          }
          data.keys.forEach(function(k) {
            var div = document.createElement('div');
            div.className = 'bg-white rounded-xl border border-gray-200 p-4 flex items-center justify-between';
            div.innerHTML = '<div><div class="font-semibold text-sm text-gray-800">' + escapeHtml(k.name) + '</div><div class="text-xs text-gray-400 mt-0.5"><code>' + escapeHtml(k.prefix) + '...</code> &middot; Creada ' + new Date(k.createdAt).toLocaleDateString() + (k.lastUsedAt ? ' &middot; Usada ' + new Date(k.lastUsedAt).toLocaleDateString() : ' &middot; Nunca usada') + '</div></div><button class="revoke-key text-xs text-red-500 hover:text-red-700 hover:bg-red-50 px-3 py-1 rounded-lg transition-colors" data-id="' + k.id + '">Revocar</button></div>';
            list.appendChild(div);
          });
          document.querySelectorAll('.revoke-key').forEach(function(btn) {
            btn.onclick = function() {
              if (!confirm('Revocar esta llave de API? Cualquier servicio que la use perdera acceso.')) return;
              fetch('/api/auth/api-keys/' + this.dataset.id, { method: 'DELETE', headers: { 'Authorization': 'Bearer ' + tkn } })
                .then(function(r) { return r.json(); })
                .then(function(d) { if (d.ok) loadKeys(); });
            };
          });
        });
    }

    document.getElementById('createKeyBtn').onclick = function() {
      var name = document.getElementById('newKeyName').value.trim();
      if (!name) { alert('Ingresa un nombre para esta llave.'); return; }
      fetch('/api/auth/api-keys', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + tkn, 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name }),
      })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data.ok) { alert(data.error); return; }
          document.getElementById('newKeyName').value = '';
          document.getElementById('newKeyValue').textContent = data.key.token;
          document.getElementById('newKeyResult').classList.remove('hidden');
          loadKeys();
        });
    };
  }

  function escapeHtml(str) {
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
})();
</script>

<%- include('../partials/footer', { lang, t }) %>