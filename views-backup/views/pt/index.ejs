<%- include('../partials/head', { lang, t, alternates }) %>

<%- include('../partials/navbar', { lang, t }) %>

<!-- Hero + Playground -->
<section class="min-h-[100dvh] pt-20 sm:pt-24 pb-10 sm:pb-16 px-4 sm:px-6 bg-gradient-to-b from-pinky-50 to-white relative overflow-hidden">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-6 sm:mb-8 animate-fade-in">
      <h1 class="text-3xl sm:text-5xl md:text-7xl font-black leading-tight mb-3 sm:mb-4">
        XanaScript <span class="text-pinky-400">Playground</span>
      </h1>
      <p class="text-base sm:text-lg md:text-xl text-gray-500 max-w-2xl mx-auto px-2 font-light"><%= t('hero.subtitle') %></p>
    </div>

    <div class="flex flex-col lg:flex-row gap-4 sm:gap-6 animate-slide-up" style="height: min(calc(100dvh - 18rem), 640px); min-height: 300px;">
      <div class="flex-1 min-h-[200px] lg:min-h-0 rounded-2xl overflow-hidden shadow-2xl border border-gray-200 bg-white flex flex-col">
        <div class="flex items-center gap-1.5 px-3 sm:px-4 py-2.5 sm:py-3 bg-gray-100 border-b border-gray-200">
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-red-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-yellow-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-green-400"></div>
          <span class="text-gray-500 text-xs sm:text-sm ml-2 sm:ml-3 font-medium">app.xs</span>
          <div class="ml-auto flex gap-1 sm:gap-2">
            <button id="runBtn" class="bg-pinky-400 hover:bg-pinky-500 text-white px-4 sm:px-5 py-1.5 rounded-lg text-xs sm:text-sm font-semibold transition-all shadow-md shadow-pinky-200 active:scale-95"><%= t('playground.run') %></button>
          </div>
        </div>
        <div id="examplesBar" class="flex items-center gap-1.5 px-3 sm:px-4 py-1.5 bg-gray-50 border-b border-gray-200 overflow-x-auto"></div>
        <textarea id="codeEditor" name="codeEditor" spellcheck="false">CRIA nome = "XanaScript"
CRIA idade = 25

CHAMA ESSE CARA saudacao(nome, idade) {
  VOLTA "Ola, " + nome + "! Tenho " + idade + " anos."
}

SOLTA O GRITO(saudacao(nome, idade))

CRIA soma = 0
REPETE NA MORAL (CRIA i = 1; i <= 10; i += 1) {
  soma = soma + i
}

SOLTA O GRITO("Soma de 1 a 10: " + soma)</textarea>
        <div id="editorContainer"></div>
      </div>

      <div class="flex-1 min-h-[200px] lg:min-h-0 rounded-2xl overflow-hidden shadow-2xl border border-gray-200 bg-white flex flex-col">
        <div class="flex items-center gap-1.5 px-3 sm:px-4 py-2.5 sm:py-3 bg-gray-100 border-b border-gray-200">
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-red-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-yellow-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-green-400"></div>
          <span class="text-gray-500 text-xs sm:text-sm ml-2 sm:ml-3 font-medium">Output</span>
          <button id="clearBtn" class="ml-auto text-xs text-gray-400 hover:text-gray-600 transition-colors"><%= t('playground.clear') %></button>
        </div>
        <pre id="output" class="flex-1 min-h-[160px] m-0 bg-white text-gray-700 p-4 sm:p-5 font-mono text-xs sm:text-sm overflow-auto leading-relaxed whitespace-pre-wrap border-t border-gray-100"><%= t('playground.ready') %></pre>
      </div>
    </div>

    <div class="text-center mt-4 sm:mt-6 text-xs sm:text-sm text-gray-400">
      <span><%= t('playground.cli') %> </span><a href="#install" class="text-pinky-400 hover:underline font-medium"><%= t('playground.cliLink') %></a>
    </div>
  </div>
</section>

<!-- Installation -->
<section id="install" class="py-14 sm:py-20 px-4 sm:px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-center mb-3 sm:mb-4"><%= t('install.title') %></h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-8 sm:mb-12 text-base sm:text-lg font-light"><%= t('install.subtitle') %></p>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-pinky-50 rounded-2xl p-8 border border-pinky-100">
        <h3 class="text-xl font-bold mb-3"><%= t('install.npm.title') %></h3>
        <p class="text-gray-500 text-sm mb-4"><%= t('install.npm.desc') %></p>
        <div class="code-block bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">Bash</div>
          <pre class="p-4">npm install -g xanascript</pre>
        </div>
      </div>
      <div class="bg-pinky-50 rounded-2xl p-8 border border-pinky-100">
        <h3 class="text-xl font-bold mb-3"><%= t('install.binary.title') %></h3>
        <p class="text-gray-500 text-sm mb-4"><%= t('install.binary.desc') %></p>
        <div data-cmd="curl -fsSL https://xanascript.xyz/install.sh | bash" class="inline-flex items-center gap-2 bg-white border border-gray-200 rounded-xl px-4 py-2.5 font-mono text-sm text-gray-500 cursor-pointer transition-all hover:border-pinky-400 select-none">
          <span class="text-pinky-400">$</span>
          <span class="text-gray-800">curl -fsSL https://xanascript.xyz/install.sh | bash</span>
        </div>
        <div data-cmd="xs --version" class="mt-2 inline-flex items-center gap-2 bg-white border border-gray-200 rounded-xl px-4 py-2.5 font-mono text-sm text-gray-500 cursor-pointer transition-all hover:border-pinky-400 select-none">
          <span class="text-pinky-400">$</span>
          <span class="text-gray-800">xs --version</span>
        </div>
        <% if (typeof npmDownloads !== 'undefined' && npmDownloads !== null) { %>
        <div class="mt-3 text-xs text-gray-400">
          <span class="inline-flex items-center gap-1"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a.5.5 0 0 1 .5.5v11.793l3.146-3.147a.5.5 0 0 1 .708.708l-4 4a.5.5 0 0 1-.708 0l-4-4a.5.5 0 0 1 .708-.708L7.5 13.293V1.5A.5.5 0 0 1 8 1z"/></svg> <%= npmDownloads.toLocaleString() %> downloads este mês</span>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<!-- Syntax -->
<section id="syntax" class="py-20 px-6 bg-pinky-50/50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-4">Sintaxe Completa</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light">Cada palavra-chave é em português claro. O código se explica por si só.</p>
    <div class="grid md:grid-cols-2 gap-6">
      <div>
        <h4 class="font-semibold mb-3 text-gray-700">Variáveis e Funções</h4>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4"><span class="kw">CRIA</span> nome = <span class="str">"XanaScript"</span>
<span class="kw">CRIA</span> idade = <span class="num">5</span>

<span class="kw">CHAMA ESSE CARA</span> <span class="fn">saudacao</span>(nome, idade) {
  <span class="kw">VOLTA</span> <span class="str">"Ola, "</span> + nome + <span class="str">"! Tenho "</span> + idade + <span class="str">" anos."</span>
}</pre>
        </div>

        <h4 class="font-semibold mb-3 mt-6 text-gray-700">Condicionais e Laços</h4>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4"><span class="kw">SE LIGA SO</span> (idade >= <span class="num">18</span>) {
  <span class="kw">SOLTA O GRITO</span>(<span class="str">"Maior de idade"</span>)
} <span class="kw">SENAO</span> {
  <span class="kw">SOLTA O GRITO</span>(<span class="str">"Menor de idade"</span>)
}

<span class="kw">REPETE NA MORAL</span> (<span class="kw">CRIA</span> i = <span class="num">0</span>; i < <span class="num">5</span>; i++) {
  <span class="kw">SOLTA O GRITO</span>(i)
}

<span class="kw">REPETE AI</span> (condicao) {
  <span class="cm">// while loop</span>
}</pre>
        </div>
      </div>
      <div>
        <h4 class="font-semibold mb-3 text-gray-700">Classes e POO</h4>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4"><span class="kw">CLASSE</span> <span class="fn">Animal</span> {
  <span class="kw">CONSTRUTOR</span>(nome) {
    <span class="kw">CRIA ISTO</span>.nome = nome
  }
  <span class="kw">METODO</span> falar() {
    <span class="kw">SOLTA O GRITO</span>(<span class="kw">ISTO</span>.nome + <span class="str">" faz barulho"</span>)
  }
}

<span class="kw">CLASSE</span> <span class="fn">Cachorro</span> <span class="kw">HERDA</span> Animal {
  <span class="kw">METODO</span> falar() {
    <span class="kw">SOLTA O GRITO</span>(<span class="kw">ISTO</span>.nome + <span class="str">" diz: Au Au!"</span>)
  }
}

<span class="kw">CRIA</span> rex = <span class="kw">NOVA</span> Cachorro(<span class="str">"Rex"</span>)
rex.falar()</pre>
        </div>

        <h4 class="font-semibold mb-3 mt-6 text-gray-700">Pattern Matching e Mais</h4>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4"><span class="kw">CRIA</span> resultado = <span class="kw">COMBINA</span> (valor) {
  <span class="kw">CASO</span> <span class="num">0</span> =&gt; <span class="str">"zero"</span>
  <span class="kw">CASO</span> <span class="num">1</span> =&gt; <span class="str">"um"</span>
  <span class="kw">CASO</span> _ =&gt; <span class="str">"outro"</span>
}

<span class="cm">// Template strings</span>
<span class="kw">SOLTA O GRITO</span>(`Ola, <span class="str">${nome}</span>!`)

<span class="cm">// Arrow functions</span>
<span class="kw">CRIA</span> quadrado = (x) =&gt; x * x

<span class="cm">// Async/Await</span>
<span class="kw">CRIA</span> data = <span class="kw">ESPERA AI</span> <span class="kw">AGORA VAI</span>(url)

<span class="cm">// Regex</span>
<span class="str">"hello"</span> ~= <span class="str">"^h.*o$"</span></pre>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Features -->
<section id="features" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-4">Por que XanaScript?</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light">Uma linguagem projetada do zero com um conjunto completo de ferramentas de compilação, não um transpilador ou wrapper.</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Sintaxe em Português</h3>
        <p class="text-gray-500 text-sm">Palavras-chave multipalavra (<code>SE LIGA SO</code>, <code>CHAMA ESSE CARA</code>, <code>REPETE NA MORAL</code>) são interpretadas como tokens atômicos via lookahead DFA. Sem camada de tradução — a própria gramática é em português.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Geração de Código JS Otimizada</h3>
        <p class="text-gray-500 text-sm">Otimizador multi-passagem: constant folding, desenrolamento de laços (até 8 iterações), inferência de tipo inteiro para uso automático de <code>Int32Array</code>/<code>Float64Array</code> e inlining de funções.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">WebAssembly Nativo</h3>
        <p class="text-gray-500 text-sm">Emissão direta de binário <code>.wasm</code> — sem Emscripten, sem wabt.js, sem LLVM. Implementa as seções Type/Function/Code/Export/Data manualmente com um linker embutido que resolve índices de função e offsets de label.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">ORM Embutido</h3>
        <p class="text-gray-500 text-sm"><code>TABELA</code> é um construto sintático de primeira classe analisado em nós AST. O codegen emite funções CRUD completas (<code>inserir</code>, <code>buscar</code>, <code>atualizar</code>, <code>remover</code>) com suporte a filtros (<code>$gt</code>, <code>$lt</code>, <code>$eq</code>) e persistência JSON.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Macros em Tempo de Compilação</h3>
        <p class="text-gray-500 text-sm">Definições <code>MACRO</code> são armazenadas na tabela de símbolos e expandidas durante a travessia da AST antes da geração de código. Suporta expansão recursiva com limites de profundidade configuráveis. Impacto zero em tempo de execução.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Executor de Testes Nativo</h3>
        <p class="text-gray-500 text-sm"><code>TESTE</code> e <code>AFIRMA</code> são analisados como instruções AST e executados pelo interpretador. Descobre automaticamente arquivos de teste, exibe resultados no formato TAP e finaliza com códigos prontos para CI.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Servidor LSP</h3>
        <p class="text-gray-500 text-sm">Protocolo de Servidor de Linguagem via stdio. Arquitetura sem estado: cada requisição reinterpreta o documento do zero. Suporta completações, documentação hover, ir para definição, diagnósticos em tempo real e formatação.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Gerenciador de Pacotes</h3>
        <p class="text-gray-500 text-sm"><code>xs install</code> resolve pacotes de repositórios GitHub com compatibilidade semver. <code>xs publish</code> cria uma entrada no registro. Suporte a npm fallback para interoperabilidade JS.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Erros Estilo Rust</h3>
        <p class="text-gray-500 text-sm">Cada erro inclui um código único, localização exata no código-fonte com anotação de seta e mensagens estruturadas de dica/ajuda. O parser implementa recuperação de erros em modo pânico para reportar múltiplos erros por execução.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Extensão VS Code</h3>
        <p class="text-gray-500 text-sm">Usa <code>vscode-xs</code> com gramáticas TextMate para realce de sintaxe, 18 snippets de código e integração com cliente LSP. Comandos para executar, compilar, testar e formatar.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">CLI Completa</h3>
        <p class="text-gray-500 text-sm">20+ subcomandos: <code>run</code>, <code>build</code> (JS/Wasm), <code>test</code>, <code>repl</code>, <code>format</code>, <code>docs</code>, <code>lsp</code>, <code>init</code>, <code>install</code>, <code>publish</code>, <code>watch</code>, <code>benchmark</code>. Binário único via <code>bun --compile</code>, zero dependências em tempo de execução.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Executor de Tarefas</h3>
        <p class="text-gray-500 text-sm">Declarações <code>TAREFA</code> em <code>tarefas.xs</code> definem tarefas nomeadas analisadas em AST. Executadas via <code>xs &lt;taskname&gt;</code> com resolução de dependências.</p>
      </div>
    </div>
  </div>
</section>

<!-- Wasm -->
<section id="wasm" class="py-20 px-6 bg-pinky-50/50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-4">WebAssembly Nativo</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light">Emissão direta de <code>.wasm</code> — sem Emscripten, sem wabt.js, sem LLVM.</p>
    <div class="grid md:grid-cols-2 gap-8">
      <div>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4"><span class="kw">CHAMA ESSE CARA</span> <span class="fn">sum</span>(a, b) {
  <span class="kw">VOLTA</span> a + b
}
<span class="kw">CHAMA ESSE CARA</span> <span class="fn">main</span>() {
  <span class="kw">VOLTA</span> sum(<span class="num">10</span>, <span class="num">20</span>)
}</pre>
        </div>
        <div data-cmd="xs build --wasm math.xs" class="mt-3 inline-flex items-center gap-2 bg-gray-50 border border-gray-200 rounded-xl px-4 py-2.5 font-mono text-sm text-gray-500 cursor-pointer transition-all hover:border-pinky-400 select-none">
          <span class="text-pinky-400">$</span>
          <span class="text-gray-800">xs build --wasm math.xs</span>
        </div>
      </div>
      <div>
        <p class="text-gray-600 mb-4"><strong class="text-gray-800">wasm_binary.js</strong> implementa a especificação do formato binário Wasm do zero:</p>
        <ul class="list-disc list-inside text-gray-600 space-y-1.5 mb-4">
          <li>Magic number (<code>00 61 73 6d</code>) + versão (<code>01 00 00 00</code>)</li>
          <li>Codificação de seções: Type Section (assinaturas de função), Function Section (mapeamento de índice de tipo), Code Section (corpos de função com declarações de locais), Export Section (exportações nomeadas), Data Section (conteúdo inicial da memória)</li>
          <li>Todos os inteiros codificados via LEB128 (variantes sem sinal e com sinal)</li>
          <li>Sistema de tipos de dois valores: <code>i32</code> e <code>f64</code> — todas as operações aritméticas XS mapeiam para o opcode apropriado</li>
        </ul>
        <p class="text-gray-600 mb-4">O <strong class="text-gray-800">linker</strong> interno resolve índices de função entre seções durante uma segunda passagem. Após a geração de código, ele corrige offsets de label para instruções de desvio (<code>br</code>, <code>br_if</code>, <code>block</code>, <code>loop</code>). O linker também gerencia a codificação da tabela de strings de nomes de exportação.</p>
        <p class="text-gray-600 mb-4">A alocação de memória usa um bump allocator embutido — <code>CRIA VETOR</code> com tamanhos conhecidos em tempo de compilação emite <code>memory.grow</code> + aritmética de ponteiros. Strings são armazenadas como pares (tamanho, dados) no offset alocado.</p>
        <div class="grid grid-cols-2 gap-2">
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">i32 / f64</code><span class="text-gray-400 text-xs">Tipos de valor</span></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">block / loop</code><span class="text-gray-400 text-xs">Fluxo de controle</span></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">call / return</code><span class="text-gray-400 text-xs">Funções</span></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">memory.grow</code><span class="text-gray-400 text-xs">Alocação dinâmica</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ORM -->
<section id="orm" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-4">ORM Embutido</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light">Tabelas como um nó AST de primeira classe — analisadas, verificadas por tipo e geradas no pipeline do compilador.</p>
    <div class="grid md:grid-cols-2 gap-8">
      <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
        <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
        <pre class="p-4"><span class="kw">TABELA</span> <span class="fn">Product</span> {
  name: <span class="typ">TEXTO</span>,
  price: <span class="typ">NUMERO</span>,
  stock: <span class="typ">NUMERO</span>
}

<span class="kw">CRIA</span> repo = Product
repo.create({ name: <span class="str">"Keyboard"</span>, price: <span class="num">250</span>, stock: <span class="num">10</span> })
repo.create({ name: <span class="str">"Mouse"</span>, price: <span class="num">120</span>, stock: <span class="num">25</span> })

<span class="kw">SOLTA O GRITO</span>(repo.list())
<span class="kw">CRIA</span> expensive = repo.findWhere({ price: <span class="num">250</span> })
repo.update(<span class="num">1</span>, { name: <span class="str">"RGB Keyboard"</span> })
repo.delete(<span class="num">2</span>)</pre>
      </div>
      <div>
        <p class="text-gray-600 mb-4"><code>TABELA</code> é analisado como um nó AST <code>TableDef</code> contendo um nome e uma lista de campos tipados. O parser valida que os tipos de campo são um dos cinco suportados: <code>TEXTO</code>, <code>NUMERO</code>, <code>BOOLEANO</code>, <code>DATA</code>, <code>QUALQUER</code>. Tipos inválidos produzem um erro em tempo de compilação com anotação de origem.</p>
        <p class="text-gray-600 mb-4">No lado do codegen, <code>TableDef</code> emite uma função construtora que retorna um objeto com os métodos CRUD. O runtime armazena dados como arquivos JSON em disco (Node/Bun) ou em memória (navegador). Cada registro recebe um campo <code>_id</code> auto-incrementado além dos timestamps <code>_criado</code> e <code>_atualizado</code>.</p>
        <p class="text-gray-600 mb-4">O método <code>findWhere</code> suporta operadores de filtro passados como chaves prefixadas com <code>$</code>: <code>$eq</code>, <code>$gt</code>, <code>$lt</code>, <code>$gte</code>, <code>$lte</code>, <code>$ne</code> e <code>$in</code> (correspondência de array). Filtros compostos usam semântica AND implícita.</p>
        <div class="grid grid-cols-2 gap-2">
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">TEXTO</code><span class="text-gray-400 text-xs">string</span></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">NUMERO</code><span class="text-gray-400 text-xs">number</span></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">BOOLEANO</code><span class="text-gray-400 text-xs">boolean</span></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">DATA</code><span class="text-gray-400 text-xs">string ISO</span></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">QUALQUER</code><span class="text-gray-400 text-xs">qualquer</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Macros -->
<section id="macros" class="py-20 px-6 bg-pinky-50/50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-4">Macros em Tempo de Compilação</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light">Substituição em nível de AST — expandidas durante a fase de otimização, removidas antes da geração de código.</p>
    <div class="grid md:grid-cols-2 gap-8">
      <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
        <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
        <pre class="p-4"><span class="kw">MACRO</span> <span class="fn">square</span>(x) { x * x }
<span class="kw">MACRO</span> <span class="fn">cube</span>(x) { x * square(x) }
<span class="kw">MACRO</span> <span class="fn">max</span>(a, b) {
  <span class="kw">SE LIGA SO</span> (a > b) { a } <span class="kw">SENAO</span> { b }
}
<span class="kw">CRIA</span> r1 = square(<span class="num">5</span>)
<span class="kw">CRIA</span> r2 = cube(<span class="num">3</span>)
<span class="kw">CRIA</span> r3 = max(<span class="num">10</span>, <span class="num">20</span>)
<span class="kw">CRIA</span> r4 = max(square(<span class="num">4</span>), cube(<span class="num">2</span>))</pre>
      </div>
      <div>
        <p class="text-gray-600 mb-4">Macros são analisadas em nós AST <code>MacroDef</code> com uma lista de parâmetros e corpo. Durante a fase de otimização, o expansor de macros percorre a AST e substitui cada <code>CallExpr</code> que corresponde a um nome de macro pelo corpo da macro, substituindo identificadores de parâmetros pelas expressões de argumento via cópia rasa.</p>
        <p class="text-gray-600 mb-4">A expansão é <strong>recursiva</strong>: se um corpo de macro contém chamadas a outras macros, elas são expandidas em uma passagem pós-substituição. O expansor rastreia um contador de profundidade (limite padrão: 64) para evitar recursão infinita de referências circulares de macro. Após a expansão completa, todos os nós <code>MacroDef</code> são removidos da AST.</p>
        <p class="text-gray-600 mb-4">Como a expansão opera na AST em vez de texto (diferente do pré-processador C <code>#define</code>), não há risco de bugs de precedência de operadores ou colagem acidental de tokens. A AST resultante é então alimentada pelo otimizador e codegen como se os corpos das macros tivessem sido escritos inline.</p>
      </div>
    </div>
  </div>
</section>

<!-- Tests -->
<section id="tests" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-4">Executor de Testes</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light">Nós AST <code>TESTE</code> e <code>AFIRMA</code> de primeira classe — analisados, interpretados e reportados pelo próprio compilador.</p>
    <div class="grid md:grid-cols-2 gap-8">
      <div>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4"><span class="kw">TESTE</span> <span class="str">"sum of two numbers"</span> {
  <span class="kw">CRIA</span> r = <span class="num">2</span> + <span class="num">3</span>
  <span class="kw">AFIRMA</span>(r == <span class="num">5</span>)
  <span class="kw">ASSUNTO</span>(r, <span class="num">5</span>)
}
<span class="kw">TESTE</span> <span class="str">"multiplication"</span> {
  <span class="kw">CRIA</span> r = <span class="num">3</span> * <span class="num">4</span>
  <span class="kw">ASSUNTO</span>(r, <span class="num">12</span>)
}</pre>
        </div>
        <div data-cmd="xs test ." class="mt-3 inline-flex items-center gap-2 bg-gray-50 border border-gray-200 rounded-xl px-4 py-2.5 font-mono text-sm text-gray-500 cursor-pointer transition-all hover:border-pinky-400 select-none">
          <span class="text-pinky-400">$</span>
          <span class="text-gray-800">xs test .</span>
        </div>
      </div>
      <div>
        <p class="text-gray-600 mb-4">Blocos <code>TESTE</code> são analisados em nós AST <code>TestStmt</code> contendo uma expressão (a descrição) e um bloco de instruções. <code>AFIRMA</code> e <code>ASSUNTO</code> são analisados como nós <code>AssertStmt</code> — o primeiro recebe uma única expressão booleana, o segundo recebe um par real/esperado com comparação estrutural.</p>
        <p class="text-gray-600 mb-4">O executor de testes descobre arquivos por padrão glob (<code>**/*.test.xs</code>) e os executa através do interpretador AST. Cada <code>TestStmt</code> é envolvido em um try-catch: falhas de asserção lançam objetos <code>AssertionError</code> estruturados com informações de arquivo/linha/diff. O executor agrega resultados e exibe no formato TAP com indicadores coloridos de pass/fail, tempo de execução por teste e uma linha de resumo.</p>
        <p class="text-gray-600 mb-4">Código de saída 1 em caso de falha — pronto para CI/CD. A flag <code>xs test --watch</code> reexecuta ao alterar arquivos usando o observador de arquivos embutido.</p>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">Saída</div>
          <pre class="p-4 text-green-600">  PASS  sum of two numbers (2ms)
  PASS  multiplication (1ms)

  Tests: 2 passed, 2 total</pre>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- LSP -->
<section id="lsp" class="py-20 px-6 bg-pinky-50/50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-4">LSP — Protocolo de Servidor de Linguagem</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light">Servidor LSP sem estado via stdin/stdout JSON-RPC — uma interpretação por requisição, sem estado persistente.</p>
    <div class="grid md:grid-cols-2 gap-8">
      <div>
        <p class="text-gray-600 mb-3">Inicie o servidor com <code class="bg-pinky-50">xs lsp</code>. Implementa <code>textDocument/completion</code> (itens de completação para palavras-chave/builtins/identificadores com tipo e detalhe), <code>textDocument/hover</code> (documentação Markdown para funções embutidas com assinatura), <code>textDocument/definition</code> (resolve declarações de variáveis/funções para sua localização de origem) e <code>textDocument/diagnostic</code> (saída completa de erro do compilador mapeada para Range, incluindo código de erro e gravidade).</p>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden mb-6">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">Bash</div>
          <pre class="p-4">xs lsp</pre>
        </div>
        <h4 class="font-semibold mb-3 text-gray-700">Neovim</h4>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <pre class="p-4">vim.api.nvim_create_autocmd(<span class="str">"FileType"</span>, {
  pattern = <span class="str">"xs"</span>,
  callback = <span class="kw">function</span>()
    vim.lsp.start({
      name = <span class="str">"xanascript"</span>,
      cmd = { <span class="str">"xs"</span>, <span class="str">"lsp"</span> },
    })
  <span class="kw">end</span>,
})</pre>
        </div>
      </div>
      <div>
        <div class="space-y-2 mb-6">
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm">Diagnósticos pull-based via <code>textDocument/diagnostic</code></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm">Itens de completação com <code>kind</code> (Keyword, Function, Variable)</div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm">Hover com documentação Markdown do registro de builtins</div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm">Ir para definição resolve localizações de nós AST</div>
        </div>
        <h4 class="font-semibold mb-3 text-gray-700">VS Code</h4>
        <p class="text-gray-600 mb-4">A extensão <code class="bg-pinky-50">vscode-xs/</code> integra o LSP automaticamente em arquivos <code class="bg-pinky-50">.xs</code>. Registra <code>documentFormattingProvider</code> usando o formatador embutido e <code>CodeActionProvider</code> com sugestões de correção rápida.</p>
      </div>
    </div>
  </div>
</section>

