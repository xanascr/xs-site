<%- include('../../partials/head', { lang, t, alternates }) %>
<%- include('../../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-4xl mx-auto">
    <a href="/<%= lang %>/courses/<%= course.slug %>" class="text-sm text-gray-400 hover:text-pinky-400 no-underline mb-4 inline-block">&larr; Voltar ao curso</a>

    <div class="xs-card xs-card-glass animate-fade-in">
      <div class="p-6 sm:p-8">
        <div class="flex items-center justify-between mb-6">
          <div>
            <span class="text-xs text-gray-400 uppercase tracking-wider font-semibold">Aula <%= (course.lessons || []).findIndex(function(l) { return l.slug === lesson.slug }) + 1 %> de <%= (course.lessons || []).length %></span>
            <h1 class="text-2xl sm:text-3xl font-black mt-1"><%= lesson.title %></h1>
          </div>
          <span class="xs-tag xs-tag-primary"><%= lesson.points || 0 %> pts</span>
        </div>

        <div class="lesson-prose mb-8">
          <%- lessonHtml %>
        </div>

        <div id="challengesArea">
          <% if (lesson.challenges && lesson.challenges.length > 0) { %>
            <div class="border-t border-gray-200 pt-6 mt-8">
              <h2 class="text-xl font-bold mb-4">Desafios</h2>
              <div id="challenges" class="space-y-4">
                <% lesson.challenges.forEach(function(ch, i) { %>
                  <% var isDisabled = enrollment && enrollment.progress && enrollment.progress.find(function(p) { return p.lessonSlug === lesson.slug && p.completed }) %>
                  <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 challenge-card" data-idx="<%= i %>">
                    <p class="font-semibold text-sm text-gray-800 mb-2">Desafio <%= i + 1 %>: <%= ch.question %></p>
                    <div class="flex items-center gap-2">
                      <input type="text" class="challenge-input xs-input w-full" data-idx="<%= i %>" data-answer="<%= ch.answer.replace(/"/g, '&quot;') %>" placeholder="Digite sua resposta..." <%= isDisabled ? 'disabled' : '' %>>
                      <span class="challenge-result text-sm font-semibold w-20 text-center"></span>
                    </div>
                    <div class="challenge-feedback text-xs mt-1 hidden"></div>
                  </div>
                <% }) %>
              </div>
              <button id="checkAnswersBtn" class="xs-btn xs-btn-ghost mt-4">Verificar Respostas</button>
            </div>
          <% } %>
        </div>

        <div class="flex items-center justify-between mt-8 pt-6 border-t border-gray-200">
          <div id="lessonStatus">
            <% if (enrollment && enrollment.progress && enrollment.progress.find(function(p) { return p.lessonSlug === lesson.slug && p.completed })) { %>
              <span class="inline-flex items-center gap-1.5 text-sm text-green-600 font-semibold"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Concluido</span>
            <% } else if (enrollment) { %>
              <button id="completeBtn" class="xs-btn xs-btn-primary">Marcar como Concluido</button>
            <% } else { %>
              <a href="/<%= lang %>/login?redirect=/<%= lang %>/courses/<%= course.slug %>/lessons/<%= lesson.slug %>" class="xs-btn xs-btn-primary">Faca login para acompanhar</a>
            <% } %>
          </div>
          <span id="earnedPoints" class="text-sm text-gray-400"></span>
        </div>

        <div class="flex items-center justify-between mt-6 pt-4 border-t border-gray-100">
          <div>
            <% var prevIdx = (course.lessons || []).findIndex(function(l) { return l.slug === lesson.slug }) - 1 %>
            <% if (prevIdx >= 0) { %>
              <a href="/<%= lang %>/courses/<%= course.slug %>/lessons/<%= course.lessons[prevIdx].slug %>" class="text-sm text-gray-400 hover:text-pinky-500 no-underline inline-flex items-center gap-1">&larr; Anterior</a>
            <% } %>
          </div>
          <div>
            <% var nextIdx = (course.lessons || []).findIndex(function(l) { return l.slug === lesson.slug }) + 1 %>
            <% if (nextIdx < (course.lessons || []).length) { %>
              <a href="/<%= lang %>/courses/<%= course.slug %>/lessons/<%= course.lessons[nextIdx].slug %>" id="nextLessonBtn" class="text-sm font-semibold text-pinky-500 hover:text-pinky-600 no-underline inline-flex items-center gap-1">Proximo &rarr;</a>
            <% } else { %>
              <a href="/<%= lang %>/courses/<%= course.slug %>/certificate" class="text-sm font-semibold text-pinky-500 hover:text-pinky-600 no-underline inline-flex items-center gap-1">Certificado &rarr;</a>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="xs-card xs-card-glass mt-8 p-6 sm:p-8" id="commentsSection">
      <h2 class="text-xl font-bold mb-4">Comentarios</h2>
      <div id="commentsList" class="space-y-3">
        <div class="text-center py-6 text-gray-400 text-sm">Carregando comentarios...</div>
      </div>
      <div id="commentForm" class="mt-4 hidden">
        <textarea id="commentBody" class="xs-input w-full" rows="3" placeholder="Compartilhe seus pensamentos..." maxlength="2000"></textarea>
        <button id="submitCommentBtn" class="xs-btn xs-btn-primary text-sm mt-2">Comentar</button>
        <span id="commentError" class="text-xs text-red-500 ml-2 hidden"></span>
      </div>
      <div id="loginToComment" class="mt-4 hidden">
        <a href="/<%= lang %>/login?redirect=/<%= lang %>/courses/<%= course.slug %>/lessons/<%= lesson.slug %>" class="text-sm text-pinky-500 underline">Faca login para comentar</a>
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  var token = localStorage.getItem('xs_token');
  var courseSlug = '<%= course.slug %>';
  var lessonSlug = '<%= lesson.slug %>';

  var completeBtn = document.getElementById('completeBtn');
  if (completeBtn) {
    completeBtn.addEventListener('click', function() {
      var answers = [];
      document.querySelectorAll('.challenge-input').forEach(function(inp) { answers.push(inp.value); });
      completeBtn.disabled = true;
      completeBtn.textContent = 'Salvando...';
      fetch('/api/courses/' + courseSlug + '/lessons/' + lessonSlug + '/complete', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
        body: JSON.stringify({ answers: answers })
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.ok) {
          var pts = document.getElementById('earnedPoints');
          if (d.earned) pts.textContent = '+' + d.earned + ' XP ganhos!';
          pts.className = 'text-sm text-green-600 font-semibold';
          setTimeout(function() { window.location.reload(); }, 1200);
        } else { alert(d.error || 'Falhou'); completeBtn.disabled = false; completeBtn.textContent = 'Marcar como Concluido'; }
      })
      .catch(function() { alert('Erro de rede.'); completeBtn.disabled = false; completeBtn.textContent = 'Marcar como Concluido'; });
    });
  }

  var checkBtn = document.getElementById('checkAnswersBtn');
  if (checkBtn) {
    checkBtn.addEventListener('click', function() {
      document.querySelectorAll('.challenge-card').forEach(function(card) {
        var inp = card.querySelector('.challenge-input');
        var correctAnswer = inp.getAttribute('data-answer');
        var userAnswer = inp.value.trim().toLowerCase();
        var correctLow = (correctAnswer || '').trim().toLowerCase();
        var isCorrect = correctAnswer && userAnswer === correctLow;
        var resultSpan = card.querySelector('.challenge-result');
        var fb = card.querySelector('.challenge-feedback');

        inp.className = inp.className.replace(/border-(red|green)-\d+/g, '').trim();
        inp.className += ' xs-input w-full';
        inp.classList.remove('border-gray-200');

        if (!userAnswer) {
          if (resultSpan) resultSpan.textContent = '';
          if (fb) fb.classList.add('hidden');
          return;
        }

        if (isCorrect) {
          inp.classList.add('border-green-300', 'bg-green-50');
          if (resultSpan) { resultSpan.textContent = 'Correto'; resultSpan.className = 'challenge-result text-sm font-semibold w-20 text-center text-green-600'; }
          if (fb) { fb.textContent = ''; fb.classList.add('hidden'); }
        } else {
          inp.classList.add('border-red-300');
          if (resultSpan) { resultSpan.textContent = 'Errado'; resultSpan.className = 'challenge-result text-sm font-semibold w-20 text-center text-red-500'; }
          if (fb) {
            fb.textContent = 'Resposta comeca com: ' + (correctAnswer ? correctAnswer.substring(0, 3) + '...' : '');
            fb.classList.remove('hidden');
            fb.className = 'challenge-feedback text-xs mt-1 text-red-500';
          }
        }
      });
    });
  }

  // Comments
  function loadComments() {
    fetch('/api/courses/' + courseSlug + '/lessons/' + lessonSlug + '/comments')
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var list = document.getElementById('commentsList');
        if (!d.ok || !d.comments || d.comments.length === 0) {
          list.innerHTML = '<div class="text-center py-6 text-gray-400 text-sm">Nenhum comentario ainda. Seja o primeiro!</div>';
          return;
        }
        list.innerHTML = '';
        d.comments.forEach(function(c) {
          var date = new Date(c.createdAt).toLocaleDateString();
          list.innerHTML += '<div class="bg-gray-50 border border-gray-200 rounded-xl p-4">'
            + '<div class="flex items-center gap-2 mb-1">'
            + '<span class="font-semibold text-xs text-gray-700">' + escapeHtml(c.username) + '</span>'
            + '<span class="text-xs text-gray-400">' + date + '</span>'
            + '</div>'
            + '<p class="text-sm text-gray-700">' + escapeHtml(c.body) + '</p>'
            + '</div>';
        });
      });
  }

  function escapeHtml(str) { var d = document.createElement('div'); d.textContent = str; return d.innerHTML; }

  if (token) {
    document.getElementById('commentForm').classList.remove('hidden');
  } else {
    document.getElementById('loginToComment').classList.remove('hidden');
  }

  var submitBtn = document.getElementById('submitCommentBtn');
  if (submitBtn) {
    submitBtn.addEventListener('click', function() {
      var body = document.getElementById('commentBody');
      if (!body.value.trim()) return;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';
      fetch('/api/courses/' + courseSlug + '/lessons/' + lessonSlug + '/comments', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
        body: JSON.stringify({ body: body.value.trim() })
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.ok) { body.value = ''; loadComments(); }
        submitBtn.disabled = false;
        submitBtn.textContent = 'Comentar';
      })
      .catch(function() { submitBtn.disabled = false; submitBtn.textContent = 'Comentar'; });
    });
  }

  loadComments();
})();
</script>

<%- include('../../partials/footer', { lang, t }) %>