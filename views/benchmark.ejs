<%- include('partials/head', { lang, t, alternates }) %>
<%- include('partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-5xl mx-auto">
    <h1 class="text-3xl md:text-5xl font-black text-center mb-4"><%= t('benchmark.title') %></h1>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light"><%= t('benchmark.subtitle') %></p>

    <div class="overflow-x-auto border border-gray-200 rounded-2xl shadow-sm">
      <table class="w-full text-sm whitespace-nowrap">
        <thead>
          <tr>
            <th class="text-left font-semibold text-gray-500 p-3 sm:p-4 bg-gray-50 sticky left-0 bg-gray-50">Benchmark</th>
            <th class="text-right font-semibold text-pinky-500 p-3 sm:p-4 bg-gray-50">XanaScript</th>
            <th class="text-right font-semibold text-gray-500 p-3 sm:p-4 bg-gray-50">JavaScript (Node)</th>
            <th class="text-right font-semibold text-gray-500 p-3 sm:p-4 bg-gray-50">Python 3</th>
            <th class="text-right font-semibold text-gray-500 p-3 sm:p-4 bg-gray-50">Lua</th>
          </tr>
        </thead>
        <tbody class="text-gray-600">
          <% benchmarks.forEach(function(b) { %>
          <% var xsWins = b.higherBetter ? (b.xs >= b.js && b.xs >= b.python && b.xs >= b.lua) : (b.xs <= b.js && b.xs <= b.python && b.xs <= b.lua) %>
          <% var values = [b.xs, b.js, b.python, b.lua] %>
          <% var maxVal = Math.max.apply(null, values) %>
          <% var minVal = Math.min.apply(null, values) %>
          <tr class="border-t border-gray-100 hover:bg-gray-50 transition-colors">
            <td class="p-3 sm:p-4 font-medium text-gray-800 sticky left-0 bg-white border-r border-gray-100"><%= b.name %></td>
            <td class="p-3 sm:p-4 text-right font-mono <%= xsWins ? 'text-green-600 font-bold' : '' %>">
              <div class="flex items-center justify-end gap-2">
                <span><%= b.xs.toLocaleString() %> <%= b.unit %></span>
                <% if (b.higherBetter && maxVal > 0) { %>
                <div class="hidden sm:block w-12 h-1.5 bg-gray-100 rounded-full overflow-hidden">
                  <div class="h-full rounded-full <%= xsWins ? 'bg-green-400' : 'bg-pinky-400' %>" style="width: <%= (b.xs / maxVal * 100).toFixed(0) %>%"></div>
                </div>
                <% } else if (!b.higherBetter && maxVal > 0) { %>
                <div class="hidden sm:block w-12 h-1.5 bg-gray-100 rounded-full overflow-hidden">
                  <div class="h-full rounded-full <%= xsWins ? 'bg-green-400' : 'bg-pinky-400' %>" style="width: <%= ((maxVal - b.xs) / maxVal * 100).toFixed(0) %>%"></div>
                </div>
                <% } %>
              </div>
            </td>
            <td class="p-3 sm:p-4 text-right font-mono text-gray-500"><%= b.js.toLocaleString() %> <%= b.unit %></td>
            <td class="p-3 sm:p-4 text-right font-mono text-gray-500"><%= b.python.toLocaleString() %> <%= b.unit %></td>
            <td class="p-3 sm:p-4 text-right font-mono text-gray-500"><%= b.lua.toLocaleString() %> <%= b.unit %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <p class="text-center text-gray-400 text-xs mt-4">Menor é melhor, exceto req/s (maior é melhor). Testes executados em AMD Ryzen 7, Node 22, Python 3.12, Lua 5.4.</p>
  </div>
</section>

<%- include('partials/footer', { lang, t }) %>
