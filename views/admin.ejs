<%- include('partials/head', { lang, alternates }) %>
<%- include('partials/navbar', { lang }) %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/javascript.min.js"></script>

<div id="adminRoot" class="hidden">
<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-5xl mx-auto">
    <div id="adminHeader">
      <h1 class="text-3xl font-black mb-2">Painel de Administração</h1>
      <p class="text-gray-500 text-sm mb-2">Revise pacotes, gerencie cursos e certificados.</p>
      <p class="text-xs text-gray-400 mb-8">Atualizando automaticamente a cada 10s <span id="refreshIndicator" class="inline-block w-2 h-2 rounded-full bg-gray-300 ml-1"></span></p>
    </div>

    <div class="flex gap-2 mb-6 flex-wrap">
      <button id="navPackages" class="text-sm px-4 py-2 rounded-lg font-semibold bg-pinky-400 text-white">Pacotes</button>
      <a href="//admin/certificates" class="text-sm px-4 py-2 rounded-lg font-semibold bg-gray-100 text-gray-500 hover:bg-gray-200 no-underline">Certificados</a>
    </div>

    <div id="adminContent">
      <div class="flex gap-2 mb-6">
        <button class="tab-btn text-sm px-4 py-2 rounded-lg font-semibold bg-pinky-400 text-white" data-status="pending">Pendentes</button>
        <button class="tab-btn text-sm px-4 py-2 rounded-lg font-semibold bg-gray-100 text-gray-500 hover:bg-gray-200" data-status="approved">Aprovados</button>
        <button class="tab-btn text-sm px-4 py-2 rounded-lg font-semibold bg-gray-100 text-gray-500 hover:bg-gray-200" data-status="rejected">Rejeitados</button>
      </div>
      <div id="adminList" class="space-y-4 mb-12"></div>
    </div>

    <div id="packageReview" class="hidden">
      <button id="backToList" class="text-sm text-gray-400 hover:text-pinky-400 no-underline mb-4">&larr; Voltar à lista</button>
      <div id="reviewContent"></div>
    </div>

    <div id="apiKeysSection" class="mt-8">
      <h2 class="text-xl font-black mb-4">Chaves de API</h2>
      <p class="text-sm text-gray-500 mb-4">Tokens de acesso pessoal para operações automatizadas (publicação CLI, CI/CD).</p>

      <div class="flex gap-2 mb-4">
        <input id="newKeyName" type="text" placeholder="ex.: meu-ci-cd" maxlength="64" class="flex-1 px-4 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-pinky-400">
        <button id="createKeyBtn" class="bg-pinky-400 hover:bg-pinky-500 text-white font-semibold px-4 py-2 rounded-xl text-sm transition-all">Gerar</button>
      </div>

      <div id="newKeyResult" class="hidden bg-amber-50 border border-amber-200 rounded-xl p-4 mb-4">
        <p class="text-sm font-semibold text-amber-800 mb-1">Salve este token — ele não será mostrado novamente!</p>
        <code id="newKeyValue" class="block bg-white border border-amber-200 rounded-lg px-3 py-2 text-sm font-mono select-all"></code>
      </div>

      <div id="keysList" class="space-y-3"></div>
    </div>
  </div>
</section>
</div>

<script>
(function() {
  var token = localStorage.getItem('xs_token');

  if (!token) {
    window.location.href = '/login';
    return;
  }

  fetch('/api/auth/me', { headers: { 'Authorization': 'Bearer ' + token } })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.ok || data.user.role !== 'admin') {
        window.location.href = '//packages/dashboard';
        return;
      }
      document.getElementById('adminRoot').classList.remove('hidden');
      initAdmin(token);
    })
    .catch(function() {
      window.location.href = '/login';
    });

  function initAdmin(tkn) {
    var currentStatus = 'pending';
    var refreshTimer = null;

    function loadPackages(status) {
      fetch('/api/admin/packages?status=' + status, { headers: { 'Authorization': 'Bearer ' + tkn } })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var indicator = document.getElementById('refreshIndicator');
          indicator.classList.remove('bg-green-400', 'bg-red-400');
          indicator.classList.add('bg-green-400');

          var list = document.getElementById('adminList');
          list.innerHTML = '';
          if (!data.ok || !data.packages || data.packages.length === 0) {
            list.innerHTML = '<p class="text-center text-gray-400 text-sm py-8">Nenhum pacote ' + status + '.</p>';
            return;
          }
          data.packages.forEach(function(pkg) {
            var div = document.createElement('div');
            div.className = 'bg-white rounded-2xl border border-gray-200 p-5 cursor-pointer hover:border-pinky-200 hover:shadow-sm transition-all';
            var versionCount = pkg.versions ? pkg.versions.length : 1;
            var versionList = (pkg.versions || []).map(function(v) { return v.version; }).join(', ');

            var actions = status === 'pending'
              ? '<div class="flex gap-2 mt-3"><button class="approve-btn text-xs bg-green-100 text-green-700 px-3 py-1.5 rounded-lg font-semibold hover:bg-green-200 transition-colors" data-name="' + pkg.name + '">Aprovar</button><button class="reject-btn text-xs bg-red-100 text-red-600 px-3 py-1.5 rounded-lg font-semibold hover:bg-red-200 transition-colors" data-name="' + pkg.name + '">Rejeitar</button></div>'
              : '';

            var notes = pkg.reviewNotes ? '<div class="mt-2 text-sm text-gray-500 bg-gray-50 rounded-lg px-3 py-2">Notas: ' + escapeHtml(pkg.reviewNotes) + '</div>' : '';

            div.innerHTML = '<div class="flex items-start justify-between">'
              + '<div class="min-w-0">'
              + '<h3 class="font-bold text-gray-800">' + escapeHtml(pkg.name) + '</h3>'
              + '<p class="text-sm text-gray-500 mt-1 truncate">' + escapeHtml(pkg.description || '') + '</p>'
              + '<p class="text-xs text-gray-400 mt-1">por ' + escapeHtml(pkg.authorId?.username || pkg.author || 'desconhecido') + ' | v' + pkg.version + ' | ' + (pkg.license || 'N/D') + ' | <span class="font-medium text-gray-500">' + versionCount + ' versão(ões)</span></p>'
              + '<p class="text-xs text-gray-400">Versões: ' + escapeHtml(versionList) + '</p>'
              + '</div>'
              + '</div>'
              + actions
              + notes
              + '<div class="mt-2 text-xs text-gray-400">Enviado em ' + new Date(pkg.createdAt).toLocaleDateString() + ' | ' + (pkg.downloads || 0) + ' dl</div></div>';

            div.onclick = function(e) {
              if (e.target.closest('button')) return;
              showReview(tkn, pkg.name);
            };
            list.appendChild(div);
          });

          document.querySelectorAll('.approve-btn').forEach(function(btn) {
            btn.onclick = function(e) {
              e.stopPropagation();
              fetch('/api/admin/packages/' + this.dataset.name + '/approve', { method: 'POST', headers: { 'Authorization': 'Bearer ' + tkn } })
                .then(function(r) { return r.json(); })
                .then(function(d) { if (d.ok) loadPackages(currentStatus); });
            };
          });
          document.querySelectorAll('.reject-btn').forEach(function(btn) {
            btn.onclick = function(e) {
              e.stopPropagation();
              var reason = prompt('Motivo da rejeição:');
              if (reason === null) return;
              fetch('/api/admin/packages/' + this.dataset.name + '/reject', { method: 'POST', headers: { 'Authorization': 'Bearer ' + tkn, 'Content-Type': 'application/json' }, body: JSON.stringify({ reason: reason || 'Nenhum motivo informado' }) })
                .then(function(r) { return r.json(); })
                .then(function(d) { if (d.ok) loadPackages(currentStatus); });
            };
          });
        })
        .catch(function() {
          document.getElementById('refreshIndicator').classList.remove('bg-green-400');
          document.getElementById('refreshIndicator').classList.add('bg-red-400');
        });
    }

    document.querySelectorAll('.tab-btn').forEach(function(btn) {
      btn.onclick = function() {
        document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('bg-pinky-400', 'text-white'); b.classList.add('bg-gray-100', 'text-gray-500'); });
        this.classList.add('bg-pinky-400', 'text-white'); this.classList.remove('bg-gray-100', 'text-gray-500');
        currentStatus = this.dataset.status;
        loadPackages(currentStatus);
      };
    });

    function showReview(tkn, name) {
      if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }
      document.getElementById('adminContent').classList.add('hidden');
      document.getElementById('packageReview').classList.remove('hidden');
      var container = document.getElementById('reviewContent');
      container.innerHTML = '<p class="text-gray-400 text-sm">Carregando...</p>';

      fetch('/api/admin/packages/' + name, { headers: { 'Authorization': 'Bearer ' + tkn } })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data.ok || !data.package) {
            container.innerHTML = '<p class="text-gray-500">Pacote não encontrado.</p>';
            return;
          }
          var pkg = data.package;
          var versionCount = pkg.versions ? pkg.versions.length : 1;
          var versionList = (pkg.versions || []).map(function(v) {
            return '<span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded font-mono">' + escapeHtml(v.version) + '</span>';
          }).join(' ');

          var html = '<div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">';
          html += '<div class="p-6">';
          html += '<div class="flex items-start justify-between gap-4 flex-wrap">';
          html += '<div class="min-w-0"><h2 class="text-2xl font-black text-gray-800 break-all">' + escapeHtml(pkg.name) + '</h2>';
          html += '<p class="text-gray-500 mt-1">' + escapeHtml(pkg.description || '') + '</p></div>';
          html += '<div class="text-right shrink-0"><div class="text-xl font-black text-gray-800">v' + pkg.version + '</div>';
          html += '<div class="text-sm text-gray-400 mt-1">Status: <span class="font-semibold ' + (pkg.status === 'approved' ? 'text-green-600' : pkg.status === 'rejected' ? 'text-red-500' : 'text-amber-500') + '">' + pkg.status + '</span></div></div></div>';

          html += '<div class="flex flex-wrap items-center gap-2 mt-4 text-sm">';
          if (pkg.license) html += '<span class="text-xs bg-gray-100 text-gray-500 px-2.5 py-1 rounded font-medium">Licença: ' + escapeHtml(pkg.license) + '</span>';
          if (pkg.author) html += '<span class="text-xs text-gray-400">por <span class="font-medium text-gray-600">' + escapeHtml(pkg.author) + '</span></span>';
          html += '<span class="text-xs text-gray-400">' + (pkg.downloads || 0) + ' downloads</span>';
          html += '<span class="text-xs text-gray-400">Enviado em ' + new Date(pkg.createdAt).toLocaleDateString() + '</span>';
          html += '<span class="text-xs text-gray-400">' + versionCount + ' versão(ões)</span>';
          if (pkg.authorId) html += '<span class="text-xs text-gray-400">Autor: ' + escapeHtml(pkg.authorId.username) + ' (' + pkg.authorId.email + ')</span>';
          html += '</div>';

          if (versionList) {
            html += '<div class="mt-3"><span class="text-xs font-semibold text-gray-500 uppercase tracking-wide mr-2">Versões:</span> ' + versionList + '</div>';
          }

          if (pkg.dependencies && pkg.dependencies.length > 0) {
            html += '<div class="mt-2"><span class="text-xs font-semibold text-gray-500 uppercase tracking-wide mr-2">Dependências:</span>';
            pkg.dependencies.forEach(function(dep) {
              html += '<span class="text-xs bg-gray-50 text-gray-600 px-2 py-0.5 rounded border border-gray-200 font-mono mr-1">' + escapeHtml(dep) + '</span>';
            });
            html += '</div>';
          }

          if (pkg.keywords && pkg.keywords.length > 0) {
            html += '<div class="flex flex-wrap gap-1.5 mt-3">';
            pkg.keywords.forEach(function(kw) {
              html += '<span class="text-xs bg-pinky-50 text-pinky-500 px-2 py-0.5 rounded">' + escapeHtml(kw) + '</span>';
            });
            html += '</div>';
          }

          if (pkg.repository) {
            html += '<div class="mt-3"><a href="' + escapeHtml(pkg.repository) + '" target="_blank" class="text-sm text-pinky-400 hover:underline">' + escapeHtml(pkg.repository) + '</a></div>';
          }

          if (pkg.status === 'pending') {
            html += '<div class="mt-4 flex gap-2">';
            html += '<button class="review-approve bg-green-100 text-green-700 px-4 py-2 rounded-lg font-semibold text-sm hover:bg-green-200 transition-colors" data-name="' + pkg.name + '">Aprovar</button>';
            html += '<button class="review-reject bg-red-100 text-red-600 px-4 py-2 rounded-lg font-semibold text-sm hover:bg-red-200 transition-colors" data-name="' + pkg.name + '">Rejeitar</button>';
            html += '</div>';
          }
          html += '</div>';

          if (pkg.readme) {
            html += '<div class="border-t border-gray-100 px-6 py-4"><h3 class="font-bold text-gray-800 mb-3">Visualização do README</h3><div class="markdown-body" style="font-size:14px">' + pkg.readmeSanitized + '</div></div>';
          }

          html += '<div class="border-t border-gray-100 px-6 py-4"><h3 class="font-bold text-gray-800 mb-3">Arquivos Fonte</h3><div id="reviewSourceFiles"><p class="text-gray-400 text-sm">Carregando arquivos fonte...</p></div></div>';
          html += '</div>';

          container.innerHTML = html;

          document.querySelector('.review-approve')?.addEventListener('click', function() {
            fetch('/api/admin/packages/' + this.dataset.name + '/approve', { method: 'POST', headers: { 'Authorization': 'Bearer ' + tkn } })
              .then(function(r) { return r.json(); })
              .then(function(d) { if (d.ok) { backToDashboard(); } });
          });
          document.querySelector('.review-reject')?.addEventListener('click', function() {
            var reason = prompt('Motivo da rejeição:');
            if (reason === null) return;
            fetch('/api/admin/packages/' + this.dataset.name + '/reject', { method: 'POST', headers: { 'Authorization': 'Bearer ' + tkn, 'Content-Type': 'application/json' }, body: JSON.stringify({ reason: reason || 'Nenhum motivo informado' }) })
              .then(function(r) { return r.json(); })
              .then(function(d) { if (d.ok) { backToDashboard(); } });
          });

          loadSourceFiles(name);

          // Highlight README code blocks
          if (typeof hljs !== 'undefined') {
            document.querySelectorAll('#reviewContent .markdown-body pre code').forEach(function(b) { hljs.highlightElement(b); });
          }
        });
    }

    function loadSourceFiles(name) {
      fetch('/api/packages/' + name + '/source', { headers: { 'Authorization': 'Bearer ' + tkn } })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var container = document.getElementById('reviewSourceFiles');
          if (!data.ok || !data.files || data.files.length === 0) {
            container.innerHTML = '<p class="text-gray-400 text-sm">Nenhum arquivo fonte disponível.</p>';
            return;
          }
          container.innerHTML = '';
          data.files.forEach(function(file) {
            var ext = file.path.split('.').pop();
            var langClass = (ext === 'xs' || ext === 'js' || ext === 'json' || ext === 'md') ? 'language-' + ext : '';
            var div = document.createElement('div');
            div.className = 'mb-3 border border-gray-200 rounded-xl overflow-hidden';
            div.innerHTML = '<div class="flex items-center justify-between px-4 py-2 bg-gray-50 border-b border-gray-200">'
              + '<span class="text-xs font-mono text-gray-500 truncate">' + escapeHtml(file.path) + '</span>'
              + '<span class="text-xs text-gray-400">' + formatSize(file.content.length) + '</span>'
              + '</div>'
              + '<pre class="p-4 text-xs leading-relaxed font-mono text-gray-700 bg-white overflow-x-auto max-h-80 scrollbar-thin"><code class="' + langClass + '">' + escapeHtml(file.content) + '</code></pre>';
            container.appendChild(div);
          });
          if (typeof hljs !== 'undefined') {
            document.querySelectorAll('#reviewSourceFiles pre code').forEach(function(b) { hljs.highlightElement(b); });
          }
        })
        .catch(function() {
          document.getElementById('reviewSourceFiles').innerHTML = '<p class="text-gray-400 text-sm">Falha ao carregar arquivos fonte.</p>';
        });
    }

    function backToDashboard() {
      document.getElementById('packageReview').classList.add('hidden');
      document.getElementById('adminContent').classList.remove('hidden');
      loadPackages(currentStatus);
      startAutoRefresh();
    }
    document.getElementById('backToList').onclick = backToDashboard;

    function startAutoRefresh() {
      if (refreshTimer) clearInterval(refreshTimer);
      refreshTimer = setInterval(function() {
        loadPackages(currentStatus);
      }, 10000);
    }

    loadPackages('pending');
    startAutoRefresh();
    loadKeys();

    function loadKeys() {
      fetch('/api/auth/api-keys', { headers: { 'Authorization': 'Bearer ' + tkn } })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var list = document.getElementById('keysList');
          list.innerHTML = '';
          if (!data.ok || !data.keys || data.keys.length === 0) {
            list.innerHTML = '<p class="text-center text-gray-400 text-sm py-6">Nenhuma chave de API. Gere uma acima.</p>';
            return;
          }
          data.keys.forEach(function(k) {
            var div = document.createElement('div');
            div.className = 'bg-white rounded-xl border border-gray-200 p-4 flex items-center justify-between';
            div.innerHTML = '<div><div class="font-semibold text-sm text-gray-800">' + escapeHtml(k.name) + '</div><div class="text-xs text-gray-400 mt-0.5"><code>' + escapeHtml(k.prefix) + '...</code> &middot; Criada em ' + new Date(k.createdAt).toLocaleDateString() + (k.lastUsedAt ? ' &middot; Último uso em ' + new Date(k.lastUsedAt).toLocaleDateString() : ' &middot; Nunca usada') + '</div></div><button class="revoke-key text-xs text-red-500 hover:text-red-700 hover:bg-red-50 px-3 py-1 rounded-lg transition-colors" data-id="' + k.id + '">Revogar</button></div>';
            list.appendChild(div);
          });
          document.querySelectorAll('.revoke-key').forEach(function(btn) {
            btn.onclick = function() {
              if (!confirm('Revogar esta chave de API? Qualquer serviço usando-a perderá o acesso.')) return;
              fetch('/api/auth/api-keys/' + this.dataset.id, { method: 'DELETE', headers: { 'Authorization': 'Bearer ' + tkn } })
                .then(function(r) { return r.json(); })
                .then(function(d) { if (d.ok) loadKeys(); });
            };
          });
        });
    }

    document.getElementById('createKeyBtn').onclick = function() {
      var name = document.getElementById('newKeyName').value.trim();
      if (!name) { alert('Insira um nome para esta chave.'); return; }
      fetch('/api/auth/api-keys', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + tkn, 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name }),
      })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data.ok) { alert(data.error); return; }
          document.getElementById('newKeyName').value = '';
          document.getElementById('newKeyValue').textContent = data.key.token;
          document.getElementById('newKeyResult').classList.remove('hidden');
          loadKeys();
        });
    };
  }

  function escapeHtml(str) {
    if (!str) return '';
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function formatSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / 1048576).toFixed(1) + ' MB';
  }
})();
</script>

<%- include('partials/footer', { lang }) %>
