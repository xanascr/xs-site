<%- include('../layouts/main', { body: `
<div class="max-w-md mx-auto px-4 py-12">
  <h1 class="font-heading font-800 text-3xl text-center mb-8">Nova senha</h1>
  <form id="reset-form" class="space-y-4">
    <input type="hidden" name="token" value="<%= token %>">
    <div>
      <label class="block text-sm text-text-2 mb-1">Nova senha</label>
      <input type="password" name="password" required minlength="6" class="w-full bg-bg-2 border border-border rounded px-4 py-2.5 text-text focus:outline-none focus:border-primary">
    </div>
    <button type="submit" class="w-full py-3 bg-primary text-white rounded font-heading font-600 text-sm hover:bg-primary-hover transition-colors">Redefinir</button>
    <p id="reset-msg" class="text-center text-sm hidden"></p>
  </form>
</div>
<script>
document.getElementById('reset-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const data = Object.fromEntries(new FormData(e.target));
  const res = await fetch('/api/auth/reset-password/' + data.token, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
  const json = await res.json();
  const el = document.getElementById('reset-msg');
  if (json.ok) { el.textContent = 'Senha redefinida! Redirecionando...'; el.className = 'text-center text-sm text-success'; el.classList.remove('hidden'); setTimeout(() => window.location.href = '/login', 2000); }
  else { el.textContent = json.error; el.className = 'text-center text-sm text-error'; el.classList.remove('hidden'); }
});
</script>
`}) %>
