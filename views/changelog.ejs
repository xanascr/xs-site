<%- include('partials/head', { lang, t, alternates }) %>
<%- include('partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl md:text-5xl font-black text-center mb-4"><%= t('changelog.title') %></h1>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light"><%= t('changelog.subtitle') %></p>

    <div class="relative space-y-0">
      <% changelog.forEach(function(r, i) { %>
      <div class="relative pl-8 sm:pl-10 pb-8">
        <% if (i < changelog.length - 1) { %>
        <div class="absolute left-[13px] sm:left-[17px] top-8 bottom-0 w-0.5 bg-gray-200"></div>
        <% } %>
        <div class="absolute left-0 top-1.5 w-[26px] h-[26px] sm:w-[34px] sm:h-[34px] rounded-full border-2 flex items-center justify-center bg-white <%= r.type === 'major' ? 'border-red-400' : 'border-blue-400' %>">
          <div class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full <%= r.type === 'major' ? 'bg-red-400' : 'bg-blue-400' %>"></div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 p-4 sm:p-6 shadow-sm hover:shadow-md transition-shadow">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2 sm:gap-3 flex-wrap">
              <span class="<%= r.type === 'major' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-600' %> text-xs font-bold px-2.5 py-1 rounded-full"><%= r.version %></span>
              <span class="text-xs text-gray-400"><%= r.date %></span>
            </div>
            <% if (r.type === 'major') { %>
            <span class="text-xs font-semibold text-red-600 bg-red-50 px-2 py-0.5 rounded">Major</span>
            <% } %>
          </div>
          <ul class="space-y-1.5">
            <% r.changes.forEach(function(c) { %>
            <li class="text-sm text-gray-600 flex items-start gap-2">
              <span class="text-gray-300 mt-0.5">-</span>
              <span><%= c %></span>
            </li>
            <% }) %>
          </ul>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('partials/footer', { lang, t }) %>
