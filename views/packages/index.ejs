<%- include('../partials/head', {}) %>
<%- include('../partials/navbar', {}) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-5xl mx-auto animate-fade-in">
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-pinky-50 border border-pinky-100 text-pinky-500 text-xs font-semibold mb-4">Registry</div>
      <h1 class="text-4xl md:text-5xl font-black mb-2">Registro de Pacotes</h1>
      <p class="text-gray-500 max-w-xl mx-auto">Descubra e compartilhe pacotes XanaScript.</p>
    </div>

    <form method="GET" class="max-w-2xl mx-auto mb-10">
      <div class="relative">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input type="text" name="q" value="<%= query %>" placeholder="Pesquisar pacotes..." class="xs-input pl-12 py-3.5 text-sm shadow-sm">
      </div>
    </form>

    <% if (query) { %>
    <p class="text-sm text-gray-500 mb-6"><%= packages.length %> <%= packages.length === 1 ? 'pacote' : 'pacotes' %> encontrados para "<strong><%= query %></strong>"</p>
    <% } %>

    <% if (packages.length === 0) { %>
    <div class="text-center py-16">
      <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
      <p class="text-gray-400">Nenhum pacote encontrado.</p>
    </div>
    <% } else { %>
    <div class="space-y-3">
      <% packages.forEach(function(pkg) { %>
      <a href="/packages/<%= pkg.name %>" class="xs-card block p-5 no-underline group">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2">
              <h3 class="font-bold text-gray-800 group-hover:text-pinky-500 transition-colors"><%= pkg.name %></h3>
              <span class="text-xs font-mono text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded shrink-0">v<%= pkg.version %></span>
            </div>
            <p class="text-sm text-gray-500 mt-1 line-clamp-2"><%= pkg.description %></p>
            <div class="flex flex-wrap items-center gap-2 mt-2.5">
              <% if (pkg.license) { %><span class="text-xs bg-gray-50 text-gray-500 border border-gray-100 px-2 py-0.5 rounded"><%= pkg.license %></span><% } %>
              <% if (pkg.author) { %><span class="text-xs text-gray-400">by <span class="text-gray-500"><%= pkg.author %></span></span><% } %>
              <span class="text-xs text-gray-400"><%= new Date(pkg.updatedAt).toLocaleDateString() %></span>
              <% if (pkg.keywords && pkg.keywords.length > 0) { %>
                <% pkg.keywords.slice(0, 3).forEach(function(kw) { %>
                <span class="text-xs text-pinky-400 bg-pinky-50 px-1.5 py-0.5 rounded"><%= kw %></span>
                <% }) %>
              <% } %>
            </div>
          </div>
          <div class="text-right shrink-0 flex flex-col items-end gap-1.5">
            <div class="flex items-center gap-1 text-sm text-gray-400">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              <span><%= pkg.downloads?.toLocaleString() || 0 %></span>
            </div>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer', {}) %>
