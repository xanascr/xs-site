<%- include('../layouts/main', { body: `
<div class="max-w-5xl mx-auto px-4 py-12">
  <a href="/packages" class="text-sm text-primary hover:underline mb-6 inline-block">&larr; Todos os pacotes</a>

  <div class="bg-bg-2 border border-border rounded p-6 sm:p-8 mb-6">
    <div class="flex flex-col sm:flex-row justify-between items-start gap-4 mb-4">
      <div>
        <h1 class="font-heading font-800 text-3xl mb-1"><%= pkg.name %></h1>
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-text-2">
          <span>v<%= pkg.version %></span>
          <span>por <%= pkg.author?.username || '?' %></span>
          <span><%= pkg.downloads %> downloads</span>
          <% if (pkg.license && pkg.license !== 'MIT') { %><span><%= pkg.license %></span><% } %>
        </div>
      </div>
      <div class="flex gap-2 shrink-0">
        <select id="version-select" class="bg-bg-3 border border-border rounded px-3 py-2 text-sm text-text">
          <% (pkg.versions || []).forEach(v => { %>
            <option value="<%= v.version %>" <%= v.version === pkg.version ? 'selected' : '' %>><%= v.version %></option>
          <% }) %>
        </select>
        <button onclick="downloadPkg()" class="px-4 py-2 bg-primary text-white rounded text-sm font-600 hover:bg-primary-hover transition-colors flex items-center gap-1">
          <span class="material-symbols-outlined text-base">download</span> Download
        </button>
      </div>
    </div>

    <p class="text-text-2 mb-6"><%= pkg.description || 'Sem descrição.' %></p>

    <div class="bg-bg-3 border border-border rounded p-4 font-mono text-sm text-text-2 mb-6 flex items-center justify-between">
      <span>xs install <%= pkg.name %></span>
      <button onclick="copyCmd()" class="text-primary hover:underline text-xs shrink-0 ml-2">Copiar</button>
    </div>

    <% if (pkg.repository) { %>
      <a href="<%= pkg.repository %>" target="_blank" rel="noopener noreferrer" class="text-sm text-primary hover:underline inline-flex items-center gap-1 mb-4">
        <span class="material-symbols-outlined text-base">link</span> Repositório
      </a>
    <% } %>

    <% if (pkg.keywords && pkg.keywords.length > 0) { %>
      <div class="flex flex-wrap gap-2 mb-4">
        <% pkg.keywords.forEach(k => { %>
          <span class="px-2.5 py-1 bg-bg-3 text-text-2 rounded text-xs"><%= k %></span>
        <% }) %>
      </div>
    <% } %>

    <% if (pkg.readme) { %>
      <div class="border-t border-border pt-6 mt-6">
        <h2 class="font-heading font-700 text-lg mb-4">README</h2>
        <div class="text-text-2 leading-relaxed whitespace-pre-wrap font-mono text-sm"><%= pkg.readme %></div>
      </div>
    <% } %>
  </div>

  <div class="bg-bg-2 border border-border rounded p-6 sm:p-8 mb-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="font-heading font-700 text-lg">Source</h2>
      <button id="source-btn" onclick="toggleSource()" class="px-4 py-2 bg-bg-3 text-text rounded text-sm hover:bg-bg-3/80 transition-colors">Ver arquivos</button>
    </div>
    <div id="source-container" class="hidden">
      <div id="source-loading" class="text-text-2 text-sm py-4">Carregando...</div>
      <div id="source-files"></div>
    </div>
  </div>

  <div class="bg-bg-2 border border-border rounded p-6 sm:p-8">
    <h2 class="font-heading font-700 text-lg mb-4">Avaliações</h2>
    <% if (reviews && reviews.length > 0) { %>
      <% reviews.forEach(r => { %>
        <div class="border-b border-border last:border-0 py-4">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-sm font-600"><%= r.user?.username || '?' %></span>
            <span class="text-yellow-400 text-sm"><%= '★'.repeat(r.rating) + '☆'.repeat(5 - r.rating) %></span>
          </div>
          <% if (r.title) { %><p class="font-600 text-sm"><%= r.title %></p><% } %>
          <% if (r.body) { %><p class="text-text-2 text-sm mt-1"><%= r.body %></p><% } %>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-text-2 text-sm">Nenhuma avaliação ainda.</p>
    <% } %>
  </div>
</div>

<script>
const pkgName = '<%= pkg.name %>';
const versions = <%- JSON.stringify((pkg.versions || []).map(v => v.version)) %>;
const sel = document.getElementById('version-select');

sel.addEventListener('change', () => {
  window.location.href = '/packages/' + pkgName + '/' + sel.value;
});

async function downloadPkg() {
  const ver = sel ? sel.value : '<%= pkg.version %>';
  const res = await fetch('/api/packages/' + pkgName + '/download?version=' + ver, { method: 'POST' });
  if (!res.ok) return alert('Erro ao baixar');
  const blob = await res.blob();
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = pkgName + '-' + ver + '.tar.gz';
  a.click();
  URL.revokeObjectURL(url);
}

function copyCmd() {
  navigator.clipboard.writeText('xs install ' + pkgName);
}

let sourceLoaded = false;
async function toggleSource() {
  const container = document.getElementById('source-container');
  const btn = document.getElementById('source-btn');
  if (container.classList.contains('hidden')) {
    container.classList.remove('hidden');
    btn.textContent = 'Ocultar arquivos';
    if (!sourceLoaded) {
      sourceLoaded = true;
      const ver = sel ? sel.value : '<%= pkg.version %>';
      try {
        const res = await fetch('/api/packages/' + pkgName + '/source?version=' + ver);
        const data = await res.json();
        document.getElementById('source-loading').classList.add('hidden');
        if (data.ok && data.files) {
          const html = '<div class="space-y-2 max-h-96 overflow-y-auto">' +
            data.files.map(f =>
              '<div class="bg-bg-3 border border-border rounded p-3">' +
                '<div class="text-xs text-text-2 mb-1 font-mono">' + escapeHtml(f.path) + '</div>' +
                '<pre class="text-xs text-text leading-relaxed overflow-x-auto max-h-48 overflow-y-auto"><code>' + escapeHtml(f.content) + '</code></pre>' +
              '</div>'
            ).join('') +
            '</div>';
          document.getElementById('source-files').innerHTML = html;
        } else {
          document.getElementById('source-files').innerHTML = '<p class="text-text-2 text-sm">' + (data.error || 'Erro ao carregar fonte') + '</p>';
        }
      } catch (e) {
        document.getElementById('source-loading').classList.add('hidden');
        document.getElementById('source-files').innerHTML = '<p class="text-error text-sm">Erro: ' + e.message + '</p>';
      }
    }
  } else {
    container.classList.add('hidden');
    btn.textContent = 'Ver arquivos';
  }
}

function escapeHtml(str) {
  if (!str) return '';
  var d = document.createElement('div');
  d.textContent = str;
  return d.innerHTML;
}
</script>
`}) %>