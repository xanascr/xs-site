<%- include('../partials/head', { lang, alternates }) %>
<%- include('../partials/navbar', { lang }) %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/javascript.min.js"></script>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-4xl mx-auto animate-fade-in">
    <a href="//packages" class="text-sm text-gray-400 hover:text-pinky-400 no-underline inline-flex items-center gap-1">&larr; Voltar</a>

    <div class="xs-card mt-6 overflow-hidden">
      <div class="p-8 pb-6">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="min-w-0">
            <h1 class="text-3xl font-black text-gray-800 break-all"><%= pkg.name %></h1>
            <p class="text-gray-500 mt-2"><%= pkg.description %></p>
          </div>
          <div class="text-right text-sm text-gray-400 shrink-0">
            <div class="text-2xl font-black text-gray-800" id="pkgVersion">v<%= pkg.version %></div>
            <div class="mt-1"><%= pkg.downloads?.toLocaleString() || 0 %> Downloads</div>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-2 mt-4">
          <% if (pkg.license) { %><span class="text-xs bg-gray-100 text-gray-500 px-2.5 py-1 rounded font-medium">Licença: <%= pkg.license %></span><% } %>
          <% if (pkg.author) { %><span class="text-xs text-gray-400">por <span class="font-medium text-gray-600"><%= pkg.author %></span></span><% } %>
          <span class="text-xs text-gray-400">Atualizado: <%= new Date(pkg.updatedAt).toLocaleDateString() %></span>
        </div>

        <% if (pkg.keywords && pkg.keywords.length > 0) { %>
        <div class="flex flex-wrap gap-1.5 mt-3">
          <% pkg.keywords.forEach(function(kw) { %>
          <span class="text-xs bg-pinky-50 text-pinky-500 px-2 py-0.5 rounded"><%= kw %></span>
          <% }) %>
        </div>
        <% } %>

        <% if (pkg.repository) { %>
        <div class="mt-3">
          <a href="<%= pkg.repository %>" target="_blank" class="text-sm text-pinky-400 hover:underline inline-flex items-center gap-1">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            <%= pkg.repository %>
          </a>
        </div>
        <% } %>

        <% if (pkg.dependencies && pkg.dependencies.length > 0) { %>
        <div class="mt-4">
          <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Dependências</span>
          <div class="flex flex-wrap gap-1.5 mt-1">
            <% pkg.dependencies.forEach(function(dep) { %>
            <a href="//packages/<%= dep %>" class="text-xs bg-gray-50 text-gray-600 px-2.5 py-1 rounded border border-gray-200 hover:border-pinky-300 hover:text-pinky-500 transition-colors no-underline font-mono"><%= dep %></a>
            <% }) %>
          </div>
        </div>
        <% } %>

        <div class="mt-6 flex gap-3 flex-wrap">
          <button id="installCopyBtn" class="xs-btn xs-btn-primary text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            xs install <%= pkg.name %>
          </button>
          <button id="downloadBtn" class="xs-btn xs-btn-ghost text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Baixar .tar.gz
          </button>
        </div>

        <% if (versions && versions.length > 1) { %>
        <div class="mt-4 flex items-center gap-2">
          <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Versão:</span>
          <select id="versionSelect" class="xs-input w-auto text-sm">
            <% versions.forEach(function(v) { %>
            <option value="<%= v %>" <%= v === pkg.version ? 'selected' : '' %>><%= v %></option>
            <% }) %>
          </select>
        </div>
        <% } %>
      </div>

      <div class="border-t border-gray-100" id="readmeSection">
        <% if (pkg.readmeSanitized) { %>
        <div class="px-8 py-6">
          <h2 class="text-lg font-bold text-gray-800 mb-4">README</h2>
          <div class="markdown-body">
            <%- pkg.readmeSanitized %>
          </div>
        </div>
        <% } %>
      </div>

      <div class="border-t border-gray-100 px-8 py-6">
        <h2 class="text-lg font-bold text-gray-800 mb-4">Notificações por E-mail</h2>
        <p class="text-sm text-gray-500 mb-3">Receba notificações quando uma nova versão do <%= pkg.name %> for lançada.</p>
        <div class="flex items-center gap-2">
          <input type="email" id="webhookEmail" placeholder="your@email.com" class="xs-input text-sm max-w-xs">
          <button id="webhookSubscribeBtn" class="xs-btn xs-btn-primary text-sm">Inscrever</button>
          <button id="webhookUnsubscribeBtn" class="xs-btn xs-btn-ghost text-sm">Cancelar</button>
        </div>
        <span id="webhookMsg" class="text-xs mt-1 block"></span>
      </div>

      <div class="border-t border-gray-100 px-8 py-6">
        <h2 class="text-lg font-bold text-gray-800 mb-4">Avaliações</h2>
        <div id="reviewsList" class="space-y-3">
          <div class="text-center py-6 text-gray-400 text-sm">Carregando avaliações...</div>
        </div>
        <div id="reviewForm" class="mt-4 p-4 bg-gray-50 border border-gray-200 rounded-xl hidden">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-sm font-semibold text-gray-700">Sua Avaliação:</span>
            <div id="starRating" class="flex gap-1">
              <% for (var s = 1; s <= 5; s++) { %><span class="star text-2xl cursor-pointer text-gray-300 hover:text-amber-400 transition-colors" data-val="<%= s %>">&#9733;</span><% } %>
            </div>
            <span id="ratingLabel" class="text-xs text-gray-400">Selecionar</span>
          </div>
          <input type="text" id="reviewTitle" class="xs-input w-full mb-2" placeholder="Resumo curto (opcional)" maxlength="120">
          <textarea id="reviewBody" class="xs-input w-full" rows="3" placeholder="Escreva sua avaliação..." maxlength="2000"></textarea>
          <button id="submitReviewBtn" class="xs-btn xs-btn-primary text-sm mt-2">Enviar Avaliação</button>
          <span id="reviewError" class="text-xs text-red-500 ml-2 hidden"></span>
        </div>
        <div id="loginToReview" class="mt-4 hidden">
          <a href="/login?redirect=/packages/<%= pkg.name %>" class="text-sm text-pinky-500 underline">Faça login para avaliar</a>
        </div>
      </div>

      <div class="border-t border-gray-100 px-8 py-6">
        <h2 class="text-lg font-bold text-gray-800 mb-4">Arquivos Fonte</h2>
        <div id="sourceFiles">
          <p class="text-gray-400 text-sm">Carregando arquivos fonte...</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
var pkgName = '<%= pkg.name %>';
var currentVersion = '<%= pkg.version %>';

var installBtn = document.getElementById('installCopyBtn');
if (installBtn) {
  installBtn.addEventListener('click', function() {
    navigator.clipboard.writeText('xs install ' + pkgName).then(function() {
      var btn = document.getElementById('installCopyBtn');
      btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Copiado!';
      setTimeout(function() {
        btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg> xs install ' + pkgName;
      }, 2000);
    });
  });
}

var dlBtn = document.getElementById('downloadBtn');
if (dlBtn) dlBtn.addEventListener('click', downloadTar);
var verSelect = document.getElementById('versionSelect');
if (verSelect) verSelect.addEventListener('change', function() {
  switchVersion(this.value);
});

async function downloadTar() {
  try {
    const res = await fetch('/api/packages/' + pkgName + '/download', { method: 'POST' });
    if (!res.ok) { alert('Falha no download'); return; }
    const blob = await res.blob();
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = pkgName + '-' + currentVersion + '.tar.gz';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  } catch (e) {
    alert('Erro no download: ' + e.message);
  }
}

function switchVersion(version) {
  window.location.href = window.location.pathname.replace(/\/[^/]*$/, '') + '/' + version;
}

// ── Reviews ─────────────────────────────────────────────────────────────
var selectedRating = 0;
var token = localStorage.getItem('xs_token');

function loadReviews() {
  fetch('/api/packages/' + pkgName + '/reviews')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      var section = document.getElementById('reviewsList');
      if (!d.ok || !d.reviews || d.reviews.length === 0) {
        section.innerHTML = '<div class="text-center py-6 text-gray-400 text-sm">Nenhuma avaliação ainda. Seja o primeiro!</div>';
        return;
      }
      var avg = d.reviews.reduce(function(s, r) { return s + r.rating; }, 0) / d.reviews.length;
      section.innerHTML = '<div class="flex items-center gap-2 mb-4"><span class="text-lg font-bold text-gray-800">' + avg.toFixed(1) + '</span><span class="flex gap-0.5">' + starsHtml(Math.round(avg)) + '</span><span class="text-xs text-gray-400">(' + d.reviews.length + ' avaliações)</span></div>';
      d.reviews.forEach(function(r) {
        var date = new Date(r.createdAt).toLocaleDateString();
        section.innerHTML += '<div class="bg-gray-50 border border-gray-200 rounded-xl p-4">'
          + '<div class="flex items-center gap-2 mb-1">'
          + '<span class="flex gap-0.5">' + starsHtml(r.rating) + '</span>'
          + '<span class="font-semibold text-xs text-gray-700">' + escapeHtml(r.title || '') + '</span>'
          + '<span class="text-xs text-gray-400 ml-auto">' + date + '</span>'
          + '</div>'
          + (r.body ? '<p class="text-sm text-gray-600 mt-1">' + escapeHtml(r.body) + '</p>' : '')
          + '</div>';
      });
    });
}

function starsHtml(n) {
  var s = '';
  for (var i = 1; i <= 5; i++) s += '<span class="text-amber-400 text-sm">' + (i <= n ? '\u2605' : '\u2606') + '</span>';
  return s;
}

if (token) {
  document.getElementById('reviewForm').classList.remove('hidden');
} else {
  document.getElementById('loginToReview').classList.remove('hidden');
}

// Star rating
document.querySelectorAll('.star').forEach(function(el) {
  el.addEventListener('click', function() {
    selectedRating = parseInt(this.getAttribute('data-val'));
    document.querySelectorAll('.star').forEach(function(s) {
      s.classList.remove('text-amber-400');
      s.classList.add('text-gray-400');
    });
    document.querySelectorAll('.star').forEach(function(s) {
      var val = parseInt(s.getAttribute('data-val'));
      if (val <= selectedRating) { s.classList.remove('text-gray-400'); s.classList.add('text-amber-400'); }
    });
    document.getElementById('ratingLabel').textContent = selectedRating + '/5';
  });
  el.addEventListener('mouseenter', function() {
    var val = parseInt(this.getAttribute('data-val'));
    document.querySelectorAll('.star').forEach(function(s) {
      var sv = parseInt(s.getAttribute('data-val'));
      if (sv <= val) { s.classList.remove('text-gray-400'); s.classList.add('text-amber-300'); }
      else { s.classList.remove('text-amber-300', 'text-amber-400'); s.classList.add('text-gray-400'); }
    });
  });
  el.addEventListener('mouseleave', function() {
    document.querySelectorAll('.star').forEach(function(s) {
      var val = parseInt(s.getAttribute('data-val'));
      if (val <= selectedRating) { s.classList.remove('text-gray-400', 'text-amber-300'); s.classList.add('text-amber-400'); }
      else { s.classList.remove('text-amber-300', 'text-amber-400'); s.classList.add('text-gray-400'); }
    });
  });
});

document.getElementById('submitReviewBtn').addEventListener('click', function() {
  var btn = this;
  if (!selectedRating) { showReviewError('Selecione uma avaliação'); return; }
  btn.disabled = true;
  btn.textContent = 'Enviando...';
  fetch('/api/packages/' + pkgName + '/reviews', {
    method: 'POST',
    headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
    body: JSON.stringify({ rating: selectedRating, title: document.getElementById('reviewTitle').value.trim(), body: document.getElementById('reviewBody').value.trim() })
  })
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.ok) { document.getElementById('reviewTitle').value = ''; document.getElementById('reviewBody').value = ''; loadReviews(); hideReviewError(); }
    else { showReviewError(d.error || 'Falhou'); }
    btn.disabled = false;
    btn.textContent = 'Enviar Avaliação';
  })
  .catch(function() { showReviewError('Erro de rede.'); btn.disabled = false; btn.textContent = 'Enviar Avaliação'; });
});

function showReviewError(msg) { var el = document.getElementById('reviewError'); el.textContent = msg; el.classList.remove('hidden'); }
function hideReviewError() { document.getElementById('reviewError').classList.add('hidden'); }
loadReviews();

(async function() {
  try {
    const res = await fetch('/api/packages/<%= pkg.name %>/source');
    const data = await res.json();
    if (data.ok && data.files && data.files.length > 0) {
      const container = document.getElementById('sourceFiles');
      container.innerHTML = '';
      data.files.forEach(function(file, i) {
        const ext = file.path.split('.').pop();
        const langClass = (ext === 'xs' || ext === 'js' || ext === 'json' || ext === 'md') ? 'language-' + ext : '';
        const div = document.createElement('div');
        div.className = 'mb-4 border border-gray-200 rounded-xl overflow-hidden';
        div.innerHTML = '<div class="flex items-center justify-between px-4 py-2 bg-gray-50 border-b border-gray-200">'
          + '<span class="text-xs font-mono text-gray-500 truncate">' + escapeHtml(file.path) + '</span>'
          + '<span class="text-xs text-gray-400">' + formatSize(file.content.length) + '</span>'
          + '</div>'
          + '<pre class="p-4 text-xs leading-relaxed font-mono text-gray-700 bg-white overflow-x-auto max-h-96 scrollbar-thin"><code class="' + langClass + '">' + escapeHtml(file.content) + '</code></pre>';
        container.appendChild(div);
      });
      if (typeof hljs !== 'undefined') {
        document.querySelectorAll('#sourceFiles pre code').forEach(function(block) {
          hljs.highlightElement(block);
        });
      }
    }
  } catch (e) {
    document.getElementById('sourceFiles').innerHTML = '<p class="text-gray-400 text-sm">Arquivos fonte indisponíveis.</p>';
  }
  if (typeof hljs !== 'undefined') {
    document.querySelectorAll('.markdown-body pre code').forEach(function(block) {
      hljs.highlightElement(block);
    });
  }
  // Webhook subscribe / unsubscribe
  var webhookEmail = document.getElementById('webhookEmail');
  document.getElementById('webhookSubscribeBtn').addEventListener('click', function() {
    var email = webhookEmail.value.trim();
    if (!email) return showWebhookMsg('Insira um e-mail', 'text-red-500');
    fetch('/api/webhooks/packages/' + pkgName + '/subscribe', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: email })
    }).then(function(r){return r.json()}).then(function(d){
      showWebhookMsg(d.message, d.ok ? 'text-green-500' : 'text-red-500');
    });
  });
  document.getElementById('webhookUnsubscribeBtn').addEventListener('click', function() {
    var email = webhookEmail.value.trim();
    if (!email) return showWebhookMsg('Insira seu e-mail', 'text-red-500');
    fetch('/api/webhooks/packages/' + pkgName + '/unsubscribe', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: email })
    }).then(function(r){return r.json()}).then(function(d){
      showWebhookMsg(d.message, d.ok ? 'text-green-500' : 'text-red-500');
    });
  });
  function showWebhookMsg(msg, cls) {
    var el = document.getElementById('webhookMsg');
    el.textContent = msg; el.className = 'text-xs mt-1 block ' + cls;
  }

  function escapeHtml(str) {
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
  function formatSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / 1048576).toFixed(1) + ' MB';
  }
})();
</script>

<%- include('../partials/footer', { lang }) %>
