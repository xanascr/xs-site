<div id="readLaterToast" class="fixed bottom-6 right-6 z-50 bg-gray-900 text-white px-4 py-2.5 rounded-xl shadow-2xl text-sm hidden animate-up flex items-center gap-2">
  <span id="readLaterToastText">Salvo!</span>
</div>

<script>
(function() {
  var DB_NAME = 'xs-offline';
  var DB_VERSION = 1;

  function openDB() {
    return new Promise(function(resolve, reject) {
      var req = indexedDB.open(DB_NAME, DB_VERSION);
      req.onupgradeneeded = function(e) {
        var db = e.target.result;
        if (!db.objectStoreNames.contains('lessons')) {
          db.createObjectStore('lessons', { keyPath: 'id' });
        }
      };
      req.onsuccess = function() { resolve(req.result); };
      req.onerror = function() { reject(req.error); };
    });
  }

  window.saveLessonOffline = async function(courseSlug, lessonSlug, title, html) {
    try {
      var db = await openDB();
      var tx = db.transaction('lessons', 'readwrite');
      var store = tx.objectStore('lessons');
      store.put({ id: courseSlug + '/' + lessonSlug, courseSlug: courseSlug, lessonSlug: lessonSlug, title: title, html: html, savedAt: new Date().toISOString() });
      return new Promise(function(resolve, reject) {
        tx.oncomplete = function() { resolve(); };
        tx.onerror = function() { reject(tx.error); };
      });
    } catch(e) { console.error('Read later save failed:', e); }
  };

  window.removeLessonOffline = async function(courseSlug, lessonSlug) {
    try {
      var db = await openDB();
      var tx = db.transaction('lessons', 'readwrite');
      var store = tx.objectStore('lessons');
      store.delete(courseSlug + '/' + lessonSlug);
      return new Promise(function(resolve, reject) {
        tx.oncomplete = function() { resolve(); };
        tx.onerror = function() { reject(tx.error); };
      });
    } catch(e) { console.error('Read later remove failed:', e); }
  };

  window.getSavedLessons = async function() {
    try {
      var db = await openDB();
      var tx = db.transaction('lessons', 'readonly');
      var store = tx.objectStore('lessons');
      var req = store.getAll();
      return new Promise(function(resolve, reject) {
        req.onsuccess = function() { resolve(req.result || []); };
        req.onerror = function() { reject(req.error); };
      });
    } catch(e) { return []; }
  };

  window.isLessonSaved = async function(courseSlug, lessonSlug) {
    var lessons = await window.getSavedLessons();
    return lessons.some(function(l) { return l.courseSlug === courseSlug && l.lessonSlug === lessonSlug; });
  };

  function showToast(msg) {
    var toast = document.getElementById('readLaterToast');
    var text = document.getElementById('readLaterToastText');
    if (!toast) return;
    text.textContent = msg;
    toast.classList.remove('hidden');
    setTimeout(function() { toast.classList.add('hidden'); }, 2500);
  }

  // Listen for save requests from lesson page
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-save-offline]');
    if (!btn) return;
    var course = btn.getAttribute('data-course');
    var slug = btn.getAttribute('data-slug');
    var title = btn.getAttribute('data-title');
    if (!course || !slug) return;
    var htmlEl = document.querySelector('.lesson-prose');
    if (!htmlEl) return;

    (async function() {
      var saved = await window.isLessonSaved(course, slug);
      if (saved) {
        await window.removeLessonOffline(course, slug);
        btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg> Ler Depois';
        showToast('Removido do modo offline');
      } else {
        await window.saveLessonOffline(course, slug, title || slug, html.outerHTML);
        btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="currentColor" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg> Salvo';
        showToast('Lição salva para ler offline!');
      }
    })();
  });
})();
</script>