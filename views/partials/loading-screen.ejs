<div id="loadingScreen" class="fixed inset-0 z-[200] bg-white flex flex-col items-center justify-center transition-opacity duration-500">
  <div class="text-center animate-fade-in">
    <div class="text-5xl mb-4 font-black tracking-tight text-gray-900">Xana<span class="text-pinky-400">Script</span></div>
    <div class="flex items-center justify-center gap-1 mb-6">
      <div class="w-2 h-2 bg-pinky-400 rounded-full animate-bounce" style="animation-delay:0s"></div>
      <div class="w-2 h-2 bg-pinky-400 rounded-full animate-bounce" style="animation-delay:0.1s"></div>
      <div class="w-2 h-2 bg-pinky-400 rounded-full animate-bounce" style="animation-delay:0.2s"></div>
    </div>
    <p id="loadingFact" class="text-sm text-gray-400 max-w-xs mx-auto leading-relaxed"></p>
  </div>
</div>

<script>
(function() {
  var facts = [
    "XanaScript usa palavras-chave multipalavra como SE LIGA SO e REPETE NA MORAL.",
    "XanaScript tem um ORM embutido chamado TABELA com suporte a SQL.",
    "O compilador do XanaScript faz loop unrolling e constant folding.",
    "XanaScript suporta WebAssembly nativo sem Emscripten.",
    "Macros em XanaScript são expandidas em tempo de compilação, custo zero em runtime.",
    "XanaScript tem pattern matching com COMBINA que suporta ranges e wildcards.",
    "O LSP do XanaScript oferece completions, hover, diagnósticos e go-to-definition.",
    "XanaScript tem um test runner nativo com TESTE e AFIRMA.",
    "A licença do XanaScript é Apache 2.0 — 100% open source.",
    "XanaScript foi criado por flazo0 com sintaxe em Português brasileiro.",
    "Com XanaScript voce pode criar servidores HTTP nativos com CRIA SERVIDOR.",
    "XanaScript suporta classes com heranca usando CLASSE e HERDA.",
    "Tratamento de erros em XanaScript usa TENTA/PEGA — igual try/catch.",
    "XanaScript compila para WebAssembly, JavaScript, e binario nativo.",
    "O parser do XanaScript e recursive descent com 40+ tipos de AST.",
  ];

  var el = document.getElementById('loadingFact');
  if (el) el.textContent = facts[Math.floor(Math.random() * facts.length)];

  window.showLoading = function() {
    document.getElementById('loadingScreen').classList.remove('hidden');
  };
  window.hideLoading = function() {
    var screen = document.getElementById('loadingScreen');
    if (screen) { screen.classList.add('opacity-0'); setTimeout(function() { screen.classList.add('hidden'); screen.classList.remove('opacity-0'); }, 500); }
  };
})();
</script>