        <a href="/pt/" class="text-xs font-semibold px-1.5 py-1 rounded-md no-underline transition-all <%= lang === 'pt' ? 'text-white bg-pinky-400 shadow-sm shadow-pinky-200/40' : 'text-gray-400 hover:text-gray-700 hover:bg-gray-100/60' %>">PT</a>
        <a href="/es/" class="text-xs font-semibold px-1.5 py-1 rounded-md no-underline transition-all <%= lang === 'es' ? 'text-white bg-pinky-400 shadow-sm shadow-pinky-200/40' : 'text-gray-400 hover:text-gray-700 hover:bg-gray-100/60' %>">ES</a>
      </div>
