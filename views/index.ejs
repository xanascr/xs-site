<%- include('partials/head', {}) %>

<%- include('partials/navbar', {}) %>

<!-- Hero + Playground -->
<section class="pt-16 sm:pt-24 pb-8 sm:pb-16 px-3 sm:px-6 bg-gradient-to-b from-pinky-50 to-white relative overflow-hidden">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-4 sm:mb-8 animate-fade-in px-0 sm:px-4">
      <h1 class="text-3xl sm:text-5xl md:text-7xl font-black leading-tight mb-2 sm:mb-4">
        XanaScript <span class="text-pinky-400">Playground</span>
      </h1>
      <p class="text-sm sm:text-lg md:text-xl text-gray-500 max-w-2xl mx-auto font-light">Uma linguagem de programação completa com compilador otimizador, ORM nativo, macros em tempo de compilação e WebAssembly nativo.</p>
    </div>

    <div class="flex flex-col lg:flex-row gap-2 sm:gap-6 animate-slide-up">
      <div class="flex-1 min-h-[40vh] sm:min-h-[45vh] lg:min-h-[50vh] rounded-xl sm:rounded-2xl overflow-hidden shadow-lg sm:shadow-2xl border border-gray-200 bg-white flex flex-col">
        <div class="flex items-center gap-1.5 px-3 sm:px-4 py-2.5 sm:py-3 bg-gray-100 border-b border-gray-200">
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-red-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-yellow-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-green-400"></div>
          <span class="text-gray-500 text-xs sm:text-sm ml-2 sm:ml-3 font-medium">app.xs</span>
          <div class="ml-auto flex gap-1 sm:gap-2">
            <button id="runBtn" class="bg-pinky-400 hover:bg-pinky-500 text-white px-4 sm:px-5 py-1.5 rounded-lg text-xs sm:text-sm font-semibold transition-all shadow-md shadow-pinky-200 active:scale-95 w-full sm:w-auto">Executar</button>
          </div>
        </div>
        <div id="examplesBar" class="flex items-center gap-1.5 px-3 sm:px-4 py-1.5 bg-gray-50 border-b border-gray-200 overflow-x-auto touch-pan-x snap-x snap-mandatory scrollbar-thin">
          <div class="snap-start shrink-0"></div>
        </div>
        <textarea id="codeEditor" spellcheck="false">CRIA nome = "XanaScript"
CRIA idade = 25

CHAMA ESSE CARA saudacao(nome, idade) {
  VOLTA "Ola, " + nome + "! Tenho " + idade + " anos."
}

SOLTA O GRITO(saudacao(nome, idade))

CRIA soma = 0
REPETE NA MORAL (CRIA i = 1; i <= 10; i += 1) {
  soma = soma + i
}

SOLTA O GRITO("Soma de 1 a 10: " + soma)</textarea>
        <div id="editorContainer"></div>
      </div>

      <div class="flex-1 min-h-[20vh] sm:min-h-[40vh] lg:min-h-[50vh] rounded-xl sm:rounded-2xl overflow-hidden shadow-lg sm:shadow-2xl border border-gray-200 bg-white flex flex-col">
        <div class="flex items-center gap-1.5 px-3 sm:px-4 py-2.5 sm:py-3 bg-gray-100 border-b border-gray-200">
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-red-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-yellow-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-green-400"></div>
          <span class="text-gray-500 text-xs sm:text-sm ml-2 sm:ml-3 font-medium">Saída</span>
          <button id="clearBtn" class="ml-auto text-xs text-gray-400 hover:text-gray-600 transition-colors">Limpar</button>
        </div>
        <pre id="output" class="flex-1 min-h-[160px] m-0 bg-white text-gray-700 p-4 sm:p-5 font-mono text-xs sm:text-sm overflow-auto leading-relaxed whitespace-pre-wrap border-t border-gray-100">Pronto para executar código XanaScript...</pre>
      </div>
    </div>

    <div class="text-center mt-4 sm:mt-6 text-xs sm:text-sm text-gray-400">
      <span>Prefere o terminal? </span><a href="#install" class="text-pinky-400 hover:underline font-medium">npm install -g xanascript</a>
    </div>
  </div>
</section>

<!-- Installation -->
<section id="install" class="py-16 sm:py-20 px-4 sm:px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-center mb-3 sm:mb-4">Instalação</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-8 sm:mb-12 text-sm sm:text-lg font-light">Instale via npm — a maneira mais fácil de começar.</p>
<div class="grid sm:grid-cols-2 gap-4 sm:gap-6">
        <div class="bg-pinky-50 rounded-xl sm:rounded-2xl p-5 sm:p-8 border border-pinky-100">
          <h3 class="text-base sm:text-xl font-bold mb-2 sm:mb-3">npm (Multiplataforma)</h3>
          <p class="text-gray-500 text-xs sm:text-sm mb-3 sm:mb-4">Requer Node.js. Funciona no Windows, Linux e macOS.</p>
        <div class="code-block bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">Bash</div>
          <pre class="p-4 text-sm">npm install -g xanascript</pre>
        </div>
      </div>
      <div class="bg-pinky-50 rounded-xl sm:rounded-2xl p-5 sm:p-8 border border-pinky-100">
        <h3 class="text-lg sm:text-xl font-bold mb-3">Binário Nativo</h3>
        <p class="text-gray-500 text-sm mb-4">Executável independente, sem necessidade de Node.js.</p>
        <div data-cmd="curl -fsSL https://xanascript.xyz/install.sh | bash" class="xs-cmd inline-flex items-center gap-2 bg-white border border-gray-200 rounded-xl px-4 py-2.5 font-mono text-sm text-gray-500 cursor-pointer transition-all hover:border-pinky-400 hover:shadow-sm select-none">
          <span class="text-pinky-400">$</span>
          <span class="text-gray-800">curl -fsSL https://xanascript.xyz/install.sh | bash</span>
        </div>
        <div data-cmd="xs --version" class="xs-cmd mt-2 inline-flex items-center gap-2 bg-white border border-gray-200 rounded-xl px-4 py-2.5 font-mono text-sm text-gray-500 cursor-pointer transition-all hover:border-pinky-400 hover:shadow-sm select-none">
          <span class="text-pinky-400">$</span>
          <span class="text-gray-800">xs --version</span>
        </div>
        <% if (typeof npmDownloads !== 'undefined' && npmDownloads !== null) { %>
        <div class="mt-3 text-xs text-gray-400">
          <span class="inline-flex items-center gap-1"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a.5.5 0 0 1 .5.5v11.793l3.146-3.147a.5.5 0 0 1 .708.708l-4 4a.5.5 0 0 1-.708 0l-4-4a.5.5 0 0 1 .708-.708L7.5 13.293V1.5A.5.5 0 0 1 8 1z"/></svg> <%= npmDownloads.toLocaleString() %> downloads este mês</span>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<!-- Syntax -->
<section id="syntax" class="py-16 sm:py-20 px-4 sm:px-6 bg-pinky-50/50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-center mb-3 sm:mb-4">Sintaxe Completa</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-8 sm:mb-12 text-sm sm:text-lg font-light">Cada palavra-chave &eacute; portugu&ecirc;s claro. O c&oacute;digo se explica sozinho.</p>
    <div class="grid sm:grid-cols-2 gap-6">
      <div>
        <h4 class="font-semibold mb-3 text-gray-700 text-sm sm:text-base">Vari&aacute;veis &amp; Fun&ccedil;&otilde;es</h4>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4 text-xs sm:text-sm overflow-x-auto"><span class="kw">CRIA</span> nome = <span class="str">&quot;XanaScript&quot;</span>
<span class="kw">CRIA</span> idade = <span class="num">5</span>

<span class="kw">CHAMA ESSE CARA</span> <span class="fn">saudacao</span>(nome, idade) {
  <span class="kw">VOLTA</span> <span class="str">&quot;Ola, &quot;</span> + nome + <span class="str">&quot;! Tenho &quot;</span> + idade + <span class="str">&quot; anos.&quot;</span>
}</pre>
        </div>

        <h4 class="font-semibold mb-3 mt-6 text-gray-700 text-sm sm:text-base">Condicionais &amp; La&ccedil;os</h4>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4 text-xs sm:text-sm overflow-x-auto"><span class="kw">SE LIGA SO</span> (idade >= <span class="num">18</span>) {
  <span class="kw">SOLTA O GRITO</span>(<span class="str">&quot;Maior de idade&quot;</span>)
} <span class="kw">SENAO</span> {
  <span class="kw">SOLTA O GRITO</span>(<span class="str">&quot;Menor de idade&quot;</span>)
}

<span class="kw">REPETE NA MORAL</span> (<span class="kw">CRIA</span> i = <span class="num">0</span>; i < <span class="num">5</span>; i++) {
  <span class="kw">SOLTA O GRITO</span>(i)
}

<span class="kw">REPETE AI</span> (condicao) {
  <span class="cm">// while loop</span>
}</pre>
        </div>
      </div>
      <div>
        <h4 class="font-semibold mb-3 text-gray-700 text-sm sm:text-base">Classes &amp; POO</h4>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4 text-xs sm:text-sm overflow-x-auto"><span class="kw">CLASSE</span> <span class="fn">Animal</span> {
  <span class="kw">CONSTRUTOR</span>(nome) {
    <span class="kw">CRIA ISTO</span>.nome = nome
  }
  <span class="kw">METODO</span> falar() {
    <span class="kw">SOLTA O GRITO</span>(<span class="kw">ISTO</span>.nome + <span class="str">&quot; faz barulho&quot;</span>)
  }
}

<span class="kw">CLASSE</span> <span class="fn">Cachorro</span> <span class="kw">HERDA</span> Animal {
  <span class="kw">METODO</span> falar() {
    <span class="kw">SOLTA O GRITO</span>(<span class="kw">ISTO</span>.nome + <span class="str">&quot; diz: Au Au!&quot;</span>)
  }
}

<span class="kw">CRIA</span> rex = <span class="kw">NOVA</span> Cachorro(<span class="str">&quot;Rex&quot;</span>)
rex.falar()</pre>
        </div>

        <h4 class="font-semibold mb-3 mt-6 text-gray-700 text-sm sm:text-base">Pattern Matching &amp; Mais</h4>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4 text-xs sm:text-sm overflow-x-auto"><span class="kw">CRIA</span> resultado = <span class="kw">COMBINA</span> (valor) {
  <span class="kw">CASO</span> <span class="num">0</span> =&gt; <span class="str">&quot;zero&quot;</span>
  <span class="kw">CASO</span> <span class="num">1</span> =&gt; <span class="str">&quot;um&quot;</span>
  <span class="kw">CASO</span> _ =&gt; <span class="str">&quot;outro&quot;</span>
}

<span class="cm">// Template strings</span>
<span class="kw">SOLTA O GRITO</span>(`Ola, <span class="str">${nome}</span>!`)

<span class="cm">// Arrow functions</span>
<span class="kw">CRIA</span> quadrado = (x) =&gt; x * x

<span class="cm">// Async/Await</span>
<span class="kw">CRIA</span> data = <span class="kw">ESPERA AI</span> <span class="kw">AGORA VAI</span>(url)

<span class="cm">// Regex</span>
<span class="str">&quot;hello&quot;</span> ~= <span class="str">&quot;^h.*o$&quot;</span></pre>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Features -->
<section id="features" class="py-16 sm:py-20 px-4 sm:px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-center mb-3 sm:mb-4">Por que XanaScript?</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-8 sm:mb-12 text-sm sm:text-lg font-light">Uma linguagem projetada do zero com um pipeline de compilador completo, n&atilde;o um transpilador ou wrapper.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <div class="group bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-6 sm:p-7 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-pinky-400 hover:-translate-y-1 flex flex-col">
        <div class="mb-3"><svg class="w-8 h-8 text-pinky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg></div>
        <h3 class="font-bold text-base sm:text-lg mb-2">Sintaxe Portuguesa</h3>
        <p class="text-gray-500 text-xs sm:text-sm leading-relaxed flex-1">Palavras-chave multi-palavras (<code>SE LIGA SO</code>, <code>CHAMA ESSE CARA</code>, <code>REPETE NA MORAL</code>) s&atilde;o analisadas como tokens at&ocirc;micos via DFA com lookahead. Sem camada de tradu&ccedil;&atilde;o - a pr&oacute;pria gram&aacute;tica &eacute; portugu&ecirc;s.</p>
      </div>
      <div class="group bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-6 sm:p-7 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-pinky-400 hover:-translate-y-1 flex flex-col">
        <div class="mb-3"><svg class="w-8 h-8 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div>
        <h3 class="font-bold text-base sm:text-lg mb-2">Gera&ccedil;&atilde;o de C&oacute;digo JS Otimizada</h3>
        <p class="text-gray-500 text-xs sm:text-sm leading-relaxed flex-1">Otimizador multi-passo: dobra de constantes, desenrolamento de la&ccedil;os (at&eacute; 8 itera&ccedil;&otilde;es), infer&ecirc;ncia de tipo inteiro para uso autom&aacute;tico de <code>Int32Array</code>/<code>Float64Array</code> e inlining de fun&ccedil;&otilde;es.</p>
      </div>
      <div class="group bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-6 sm:p-7 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-pinky-400 hover:-translate-y-1 flex flex-col">
        <div class="mb-3"><svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.144-2.056-.382-3.016z"/></svg></div>
        <h3 class="font-bold text-base sm:text-lg mb-2">WebAssembly Nativo</h3>
        <p class="text-gray-500 text-xs sm:text-sm leading-relaxed flex-1">Emiss&atilde;o bin&aacute;ria direta <code>.wasm</code> - sem Emscripten, sem wabt.js, sem LLVM. Tempo de compila&ccedil;&atilde;o compar&aacute;vel ao dos interpretadores tradicionais.</p>
      </div>
      <div class="group bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-6 sm:p-7 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-pinky-400 hover:-translate-y-1 flex flex-col">
        <div class="mb-3"><svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg></div>
        <h3 class="font-bold text-base sm:text-lg mb-2">ORM Integrado</h3>
        <p class="text-gray-500 text-xs sm:text-sm leading-relaxed flex-1"><code>TABELA</code> &eacute; um construto de sintaxe de primeira classe analisado em n&oacute;s AST. A gera&ccedil;&atilde;o de c&oacute;digo emite fun&ccedil;&otilde;es CRUD completas (<code>inserir</code>, <code>buscar</code>, <code>atualizar</code>, <code>remover</code>) com suporte a filtros (<code>$gt</code>, <code>$lt</code>, <code>$eq</code>) e persist&ecirc;ncia JSON.</p>
      </div>
      <div class="group bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-6 sm:p-7 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-pinky-400 hover:-translate-y-1 flex flex-col">
        <div class="mb-3"><svg class="w-8 h-8 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg></div>
        <h3 class="font-bold text-base sm:text-lg mb-2">Macros em Tempo de Compila&ccedil;&atilde;o</h3>
        <p class="text-gray-500 text-xs sm:text-sm leading-relaxed flex-1">Defini&ccedil;&otilde;es <code>MACRO</code> s&atilde;o armazenadas na tabela de s&iacute;mbolos e expandidas durante a travessia da AST antes da gera&ccedil;&atilde;o de c&oacute;digo. Suporta expans&atilde;o recursiva com limites de profundidade configur&aacute;veis. Impacto zero em tempo de execu&ccedil;&atilde;o.</p>
      </div>
      <div class="group bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-6 sm:p-7 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-pinky-400 hover:-translate-y-1 flex flex-col">
        <div class="mb-3"><svg class="w-8 h-8 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
        <h3 class="font-bold text-base sm:text-lg mb-2">Executor de Testes Nativo</h3>
        <p class="text-gray-500 text-xs sm:text-sm leading-relaxed flex-1"><code>TESTE</code> e <code>AFIRMA</code> s&atilde;o analisados como instru&ccedil;&otilde;es AST e executados pelo interpretador. Descobre automaticamente arquivos de teste, gera resultados compat&iacuteveis com TAP e sai com c&oacute;digos prontos para CI.</p>
      </div>
      <div class="group bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-6 sm:p-7 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-pinky-400 hover:-translate-y-1 flex flex-col">
        <div class="mb-3"><svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>
        <h3 class="font-bold text-base sm:text-lg mb-2">Servidor LSP</h3>
        <p class="text-gray-500 text-xs sm:text-sm leading-relaxed flex-1">Protocolo de Servidor de Linguagem via stdio. Arquitetura sem estado: cada requisi&ccedil;&atilde;o analisa o documento do zero. Suporta completa&ccedil;&otilde;es, documenta&ccedil;&atilde;o ao pairar, ir para defini&ccedil;&atilde;o, diagn&oacute;sticos em tempo real e formata&ccedil;&atilde;o.</p>
      </div>
      <div class="group bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-6 sm:p-7 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-pinky-400 hover:-translate-y-1 flex flex-col">
        <div class="mb-3"><svg class="w-8 h-8 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 4v12l-4-2-4 2V4M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div>
        <h3 class="font-bold text-base sm:text-lg mb-2">Gerenciador de Pacotes</h3>
        <p class="text-gray-500 text-xs sm:text-sm leading-relaxed flex-1"><code>xs install</code> resolve pacotes de reposit&oacute;rios GitHub com compatibilidade semver. <code>xs publish</code> cria uma entrada no registro. Fallback npm para interoperabilidade JS.</p>
      </div>
      <div class="group bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-6 sm:p-7 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-pinky-400 hover:-translate-y-1 flex flex-col">
        <div class="mb-3"><svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.5 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg></div>
        <h3 class="font-bold text-base sm:text-lg mb-2">Erros Estilo Rust</h3>
        <p class="text-gray-500 text-xs sm:text-sm leading-relaxed flex-1">Cada erro inclui um c&oacute;digo &uacute;nico, localiza&ccedil;&atilde;o exata com anota&ccedil;&atilde;o de seta e mensagens estruturadas de dica/ajuda. O parser implementa recupera&ccedil;&atilde;o de erros em modo p&acirc;nico para relatar m&uacute;ltiplos erros por execu&ccedil;&atilde;o.</p>
      </div>
      <div class="group bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-6 sm:p-7 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-pinky-400 hover:-translate-y-1 flex flex-col">
        <div class="mb-3"><svg class="w-8 h-8 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h-2m2-4h-2M8 2l-2 4h10l-2-4M8 14h8m-8 4h8"/></svg></div>
        <h3 class="font-bold text-base sm:text-lg mb-2">Extens&atilde;o VS Code</h3>
        <p class="text-gray-500 text-xs sm:text-sm leading-relaxed flex-1">Usa <code>vscode-xs</code> com gram&aacute;ticas TextMate para realce de sintaxe, 18 snippets de c&oacute;digo e integra&ccedil;&atilde;o com cliente LSP. Comandos para executar, compilar, testar e formatar.</p>
      </div>
      <div class="group bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-6 sm:p-7 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-pinky-400 hover:-translate-y-1 flex flex-col">
        <div class="mb-3"><svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg></div>
