<%- include('../layouts/main', { body: `
<div class="max-w-6xl mx-auto px-4 py-12">
  <h1 class="font-heading font-800 text-3xl mb-8">Playground</h1>
  <div class="grid md:grid-cols-4 gap-4 mb-6">
    <select id="example-select" class="bg-bg-2 border border-border rounded px-4 py-2 text-sm text-text">
      <option value="">Exemplos...</option>
      <% examples.forEach(e => { %>
        <option value="<%= e._id %>"><%= e.title %></option>
      <% }) %>
    </select>
    <button onclick="runCode()" class="px-6 py-2 bg-primary text-white rounded font-heading font-600 text-sm hover:bg-primary-hover transition-colors md:col-span-3">
      Executar (Ctrl+Enter)
    </button>
  </div>
  <div class="grid md:grid-cols-2 gap-4">
    <textarea id="code-editor" class="w-full h-[500px] bg-code border border-border rounded p-4 font-mono text-sm text-text resize-none focus:outline-none focus:border-primary" placeholder="Escreva seu código XS aqui..."></textarea>
    <div id="output" class="w-full h-[500px] bg-code border border-border rounded p-4 font-mono text-sm text-text-2 overflow-y-auto whitespace-pre-wrap"></div>
  </div>
</div>
<script>
const editor = document.getElementById('code-editor');
const output = document.getElementById('output');
const select = document.getElementById('example-select');

const examples = <%- JSON.stringify(examples.map(e => ({ _id: e._id, title: e.title, code: e.code }))) %>;

select.addEventListener('change', () => {
  const ex = examples.find(e => e._id === select.value);
  if (ex) editor.value = ex.code;
});

document.addEventListener('keydown', (e) => {
  if (e.ctrlKey && e.key === 'Enter') runCode();
});

async function runCode() {
  output.textContent = 'Executando...';
  try {
    const res = await fetch('/api/playground/run', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ code: editor.value }),
    });
    const data = await res.json();
    output.textContent = data.ok
      ? (data.output || 'OK (sem saída)')
      : 'Erro: ' + (data.error || 'Erro desconhecido');
  } catch (e) {
    output.textContent = 'Erro: ' + e.message;
  }
}
</script>
`}) %>
