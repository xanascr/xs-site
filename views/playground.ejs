<%- include('partials/head', { lang, alternates, page: "playground" }) %>
<%- include('partials/navbar', {}) %>

<section class="min-h-[100dvh] pt-14 pb-0 px-0 bg-gradient-to-b from-pinky-50 to-white relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-4">
    <div class="text-center mb-4 animate-fade-in">
      <h1 class="text-2xl sm:text-4xl font-black">XanaScript <span class="text-pinky-400">Playground</span></h1>
      <p class="text-sm text-gray-500 mt-1">Uma linguagem de programação completa com compilador otimizador, ORM nativo, macros em tempo de compilação e WebAssembly nativo.</p>
    </div>

    <!-- Tabs -->
    <div class="flex gap-1 mb-3 animate-fade-in">
      <button class="tab-btn active" data-tab="run">Run</button>
      <button class="tab-btn" data-tab="macro">Macros</button>
      <button class="tab-btn" data-tab="orm">ORM</button>
    </div>

    <div class="flex flex-col lg:flex-row gap-4 animate-slide-up min-h-[calc(100dvh-14rem)]" id="playgroundPanels">
      <!-- Editor column -->
      <div class="flex-1 min-h-[40vh] lg:min-h-0 rounded-2xl overflow-hidden shadow-2xl border border-gray-200 bg-white flex flex-col">
        <div class="flex items-center gap-1.5 px-3 sm:px-4 py-2.5 sm:py-3 bg-gray-100 border-b border-gray-200">
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-red-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-yellow-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-green-400"></div>
          <span class="text-gray-500 text-xs sm:text-sm ml-2 sm:ml-3 font-medium">app.xs</span>
          <div class="ml-auto flex gap-1 sm:gap-2">
            <button id="shareBtn" class="bg-gray-200 hover:bg-gray-300 text-gray-600 px-2.5 py-1.5 rounded-lg text-xs font-semibold transition-all active:scale-95">Share</button>
            <button id="runBtn" class="bg-pinky-400 hover:bg-pinky-500 text-white px-4 sm:px-5 py-1.5 rounded-lg text-xs sm:text-sm font-semibold transition-all shadow-md shadow-pinky-200 active:scale-95">Executar</button>
          </div>
        </div>
        <div id="examplesBar" class="flex items-center gap-1.5 px-3 sm:px-4 py-1.5 bg-gray-50 border-b border-gray-200 overflow-x-auto touch-pan-x snap-x snap-mandatory scrollbar-thin">
          <div class="snap-start shrink-0"></div>
        </div>
        <textarea id="codeEditor" name="codeEditor" spellcheck="false"><%= typeof code !== 'undefined' && code ? code : `CRIA nome = "XanaScript"\nCRIA idade = 25\n\nCHAMA ESSE CARA saudacao(nome, idade) {\n  VOLTA "Ola, " + nome + "! Tenho " + idade + " anos."\n}\n\nSOLTA O GRITO(saudacao(nome, idade))` %></textarea>
        <div id="editorContainer"></div>
      </div>

      <!-- Output column -->
      <div class="flex-1 min-h-[40vh] lg:min-h-0 rounded-2xl overflow-hidden shadow-2xl border border-gray-200 bg-white flex flex-col">
        <div class="flex items-center gap-1.5 px-3 sm:px-4 py-2.5 sm:py-3 bg-gray-100 border-b border-gray-200">
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-red-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-yellow-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-green-400"></div>
          <span class="text-gray-500 text-xs sm:text-sm ml-2 sm:ml-3 font-medium">Output</span>
          <button id="clearBtn" class="ml-auto text-xs text-gray-400 hover:text-gray-600 px-2 py-1">Limpar</button>
        </div>
        <div class="flex-1 overflow-hidden flex flex-col">
          <div id="tabRun" class="tab-panel flex-1 overflow-auto">
            <pre id="output" class="p-4 sm:p-6 text-sm font-mono text-gray-500 overflow-auto whitespace-pre-wrap break-words h-full">Pronto para executar código XanaScript...</pre>
          </div>
          <div id="tabMacro" class="tab-panel hidden flex-1 overflow-auto p-4 sm:p-6 space-y-4">
            <div>
              <div class="text-xs font-semibold text-gray-400 uppercase mb-1">AST Before Macros</div>
              <pre id="astBefore" class="bg-gray-900 text-gray-200 rounded-lg p-3 text-xs font-mono overflow-auto max-h-48">Run code to see AST before macro expansion...</pre>
            </div>
            <div>
              <div class="text-xs font-semibold text-gray-400 uppercase mb-1">AST After Macros</div>
              <pre id="astAfter" class="bg-gray-900 text-gray-200 rounded-lg p-3 text-xs font-mono overflow-auto max-h-48">Run code to see AST after macro expansion...</pre>
            </div>
          </div>
          <div id="TabOrm" class="tab-panel hidden flex-1 overflow-auto p-4 sm:p-6">
            <div class="text-xs font-semibold text-gray-400 uppercase mb-2">Generated SQL</div>
            <pre id="sqlOutput" class="bg-gray-900 text-green-400 rounded-lg p-3 text-xs font-mono overflow-auto max-h-full">/* Run code with TABELA to see generated SQL */</pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer', {}) %>

<style>
.tab-btn { padding: 0.375rem 0.875rem; border-radius: 0.5rem; font-size: 0.75rem; font-weight: 600; border: 1px solid #e5e7eb; background: white; color: #6b7280; cursor: pointer; transition: all 0.15s; }
.tab-btn:hover { border-color: #fbd5d5; color: #e86a6e; background: #fef6f6; }
.tab-btn.active { background: #f58b8e; color: white; border-color: #f58b8e; }
</style>

<script>
(function() {
  var output = document.getElementById('output');
  var runBtn = document.getElementById('runBtn');
  var clearBtn = document.getElementById('clearBtn');
  var shareBtn = document.getElementById('shareBtn');
  var codeEditor = document.getElementById('codeEditor');
  var editorContainer = document.getElementById('editorContainer');
  var examplesBar = document.getElementById('examplesBar');
  if (!runBtn || !codeEditor || !editorContainer) return;

  var cmEditor = CodeMirror(editorContainer, {
    value: codeEditor.value,
    mode: 'javascript',
    theme: 'default',
    lineNumbers: true,
    indentUnit: 2,
    tabSize: 2,
    styleActiveLine: true,
    viewportMargin: Infinity,
    extraKeys: { 'Ctrl-Enter': function(cm) { run(); }, 'Cmd-Enter': function(cm) { run(); } }
  });
  codeEditor.style.display = 'none';

  var examples = {
    'Hello World': 'CRIA nome = "XanaScript"\nSOLTA O GRITO("Hello from " + nome)',
    'Fibonacci': 'CHAMA FUNCAO fib(n) {\n  SE (n <= 1) { VOLTA n }\n  VOLTA fib(n - 1) + fib(n - 2)\n}\nCRIA i = 0\nREPETE AI (i <= 10) { SOLTA O GRITO("fib(" + i + ") = " + fib(i)); i = i + 1 }',
    'Macro Demo': 'MACRO measure(name, expr) { VOLTA [\n  \'CRIA __start = AGORA()\', expr[0],\n  \'SOLTA O GRITO(" " + name + ": " + (AGORA() - __start) + "ms")\'\n] }\nmeasure("loop", REPETE NA MORAL (CRIA i = 0; i < 1000; i += 1) {\n  CRIA _ = i * i\n})',
    'ORM Demo': 'TABELA Produto { nome: TEXTO, preco: NUMERO, estoque: NUMERO }\nCRIA repo = Produto\nrepo.create({ nome: "Teclado", preco: 250, estoque: 10 })\nSOLTA O GRITO(repo.list())',
    'Classes': 'CLASSE Animal { CONSTRUTOR(nome) { ISTO.nome = nome } METODO falar() { SOLTA O GRITO(ISTO.nome + " makes a sound") } }\nCLASSE Cachorro HERDA Animal { METODO falar() { SOLTA O GRITO(ISTO.nome + " says: Woof!") } }\nCRIA rex = NOVA Cachorro("Rex")\nrex.falar()',
  };
  if (examplesBar) {
    for (var name in examples) {
      var btn = document.createElement('button');
      btn.textContent = name;
      btn.className = 'text-xs px-2.5 py-1 rounded-md border border-gray-200 bg-white text-gray-500 hover:bg-pinky-50 hover:border-pinky-200 hover:text-pinky-600 transition-colors whitespace-nowrap flex-shrink-0';
      btn.addEventListener('click', (function(code) { return function() { cmEditor.setValue(code); }; })(examples[name]));
      examplesBar.appendChild(btn);
    }
  }

  // Tab switching
  var tabBtns = document.querySelectorAll('.tab-btn');
  var panels = { run: document.getElementById('tabRun'), macro: document.getElementById('tabMacro'), orm: document.getElementById('TabOrm') };
  tabBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      tabBtns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      Object.keys(panels).forEach(function(k) { panels[k].classList.add('hidden'); });
      var tab = panels[btn.getAttribute('data-tab')];
      if (tab) tab.classList.remove('hidden');
    });
  });

  var currentActiveTab = 'run';

  function getActiveTab() {
    var active = document.querySelector('.tab-btn.active');
    return active ? active.getAttribute('data-tab') : 'run';
  }

  function run() {
    if (!output) return;
    output.textContent = '';
    output.style.color = '#374151';
    if (runBtn) { runBtn.disabled = true; runBtn.textContent = 'Running...'; runBtn.classList.add('opacity-75'); }
    var code = cmEditor.getValue();
    window.location.hash = '#code=' + encodeURIComponent(code);
    if (typeof window.playgroundRun !== 'function') {
      output.textContent = 'Engine not loaded. Try refreshing.';
      if (runBtn) { runBtn.disabled = false; runBtn.textContent = 'Executar'; runBtn.classList.remove('opacity-75'); }
      return;
    }

    var tab = getActiveTab();
    if (tab === 'macro') {
      runMacroTab(code);
    } else if (tab === 'orm') {
      runOrmTab(code);
    } else {
      window.playgroundRun(code).then(function(out) {
        output.textContent = out || 'Program finished (no output)';
        if (runBtn) { runBtn.disabled = false; runBtn.textContent = 'Executar'; runBtn.classList.remove('opacity-75'); }
      }).catch(function(err) {
        output.textContent = err.message || String(err);
        if (runBtn) { runBtn.disabled = false; runBtn.textContent = 'Executar'; runBtn.classList.remove('opacity-75'); }
      });
    }
  }

  // ── Macro Tab ──
  function runMacroTab(code) {
    var astBeforeEl = document.getElementById('astBefore');
    var astAfterEl = document.getElementById('astAfter');
    astBeforeEl.textContent = 'Expanding...';
    astAfterEl.textContent = 'Expanding...';

    // The xs-engine.js exports parse/expand functions on window
    // We'll try to use them if available, otherwise show a guide
    if (typeof window.playgroundMacroExpand === 'function') {
      window.playgroundMacroExpand(code).then(function(result) {
        astBeforeEl.textContent = result.before || 'No AST produced';
        astAfterEl.textContent = result.after || 'No AST after expansion';
        if (runBtn) { runBtn.disabled = false; runBtn.textContent = 'Executar'; runBtn.classList.remove('opacity-75'); }
      }).catch(function(err) {
        astBeforeEl.textContent = 'Error: ' + (err.message || String(err));
        astAfterEl.textContent = 'Error';
        if (runBtn) { runBtn.disabled = false; runBtn.textContent = 'Executar'; runBtn.classList.remove('opacity-75'); }
      });
    } else {
      // Fallback: run normally and show interpretation
      window.playgroundRun(code).then(function(out) {
        astBeforeEl.textContent = '/* To see AST, compile the engine with debug mode.\nStandard output:\n*/ ' + (out || '(no output)');
        astAfterEl.textContent = '/* Macro AST display requires engine debug build.\nCheck /playground/xs-engine.js for updates. */';
        if (runBtn) { runBtn.disabled = false; runBtn.textContent = 'Executar'; runBtn.classList.remove('opacity-75'); }
      }).catch(function(err) {
        astBeforeEl.textContent = 'Error: ' + (err.message || String(err));
        if (runBtn) { runBtn.disabled = false; runBtn.textContent = 'Executar'; runBtn.classList.remove('opacity-75'); }
      });
    }
  }

  // ── ORM Tab ──
  function runOrmTab(code) {
    var sqlOutput = document.getElementById('sqlOutput');
    sqlOutput.textContent = 'Running with SQL tracing...';

    if (typeof window.playgroundRunWithSql === 'function') {
      window.playgroundRunWithSql(code).then(function(result) {
        sqlOutput.textContent = result.sql || '-- No SQL generated';
        if (runBtn) { runBtn.disabled = false; runBtn.textContent = 'Executar'; runBtn.classList.remove('opacity-75'); }
      }).catch(function(err) {
        sqlOutput.textContent = '-- Error: ' + (err.message || String(err));
        if (runBtn) { runBtn.disabled = false; runBtn.textContent = 'Executar'; runBtn.classList.remove('opacity-75'); }
      });
    } else {
      window.playgroundRun(code).then(function(out) {
        sqlOutput.textContent = '/* ORM SQL tracing not available in this build.\nRun TABELA queries normally. Output:\n*/\n' + (out || '(no output)');
        if (runBtn) { runBtn.disabled = false; runBtn.textContent = 'Executar'; runBtn.classList.remove('opacity-75'); }
      }).catch(function(err) {
        sqlOutput.textContent = '-- Error: ' + (err.message || String(err));
        if (runBtn) { runBtn.disabled = false; runBtn.textContent = 'Executar'; runBtn.classList.remove('opacity-75'); }
      });
    }
  }

  if (runBtn) runBtn.addEventListener('click', run);
  if (clearBtn) {
    clearBtn.addEventListener('click', function() {
      if (!output) return;
      output.textContent = 'Pronto para executar código XanaScript...';
      output.style.color = '#374151';
    });
  }
  if (shareBtn) {
    shareBtn.addEventListener('click', function() {
      var code = cmEditor.getValue();
      var url = window.location.origin + window.location.pathname + '?code=' + encodeURIComponent(code);
      navigator.clipboard.writeText(url).then(function() {
        var orig = shareBtn.textContent;
        shareBtn.textContent = 'Copied!';
        setTimeout(function() { shareBtn.textContent = orig; }, 2000);
      });
    });
  }

  (function() {
    var params = new URLSearchParams(window.location.search);
    var c = params.get('code');
    if (c) cmEditor.setValue(decodeURIComponent(c));
  })();
})();
</script>