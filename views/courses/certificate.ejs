<%- include('../layouts/main', { body: `
<div class="max-w-2xl mx-auto px-4 py-12 text-center">
  <span class="material-symbols-outlined text-6xl text-primary mb-4">workspace_premium</span>
  <h1 class="font-heading font-800 text-3xl mb-2">Certificado de Conclusão</h1>
  <p class="text-text-2 mb-8">Certificamos que</p>
  <p class="font-heading font-700 text-2xl text-primary mb-4"><%= cert.user?.username || user?.username %></p>
  <p class="text-text-2 mb-2">concluiu o curso</p>
  <p class="font-heading font-600 text-xl mb-8"><%= course.title %></p>
  <div class="bg-bg-2 border border-border rounded p-6 inline-block mb-8">
    <p class="text-xs text-text-2">Código de verificação</p>
    <p class="font-mono text-lg text-primary"><%= cert.code %></p>
  </div>
  <div>
    <button onclick="window.print()" class="px-6 py-3 bg-primary text-white rounded font-heading font-600 text-sm hover:bg-primary-hover transition-colors">Imprimir</button>
  </div>
</div>
`}) %>
