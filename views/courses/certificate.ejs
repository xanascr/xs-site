<%- include('../partials/head', { lang, t, alternates }) %>
<%- include('../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-3xl mx-auto">
    <a href="//courses/<%= course.slug %>" class="text-sm text-gray-400 hover:text-pinky-400 no-underline mb-4 inline-block">&larr; Voltar ao curso</a>

    <div class="xs-card xs-card-glass animate-fade-in p-8 text-center">
      <h1 class="text-3xl font-black mb-3">Certificado do Curso</h1>
      <p class="text-gray-500 mb-6"><%= course.title %></p>

      <% if (!enrollment || !enrollment.certificateEligible) { %>
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 mb-6">
          <p class="text-amber-700 font-semibold">Você precisa concluir todas as lições antes de solicitar um certificado.</p>
          <a href="//courses/<%= course.slug %>" class="xs-btn xs-btn-primary mt-4">Continuar Curso</a>
        </div>
      <% } else if (certificate && (certificate.status === 'issued' || certificate.status === 'pending')) { %>
        <div class="bg-green-50 border border-green-200 rounded-xl p-6 mb-6">
          <% if (certificate.status === 'pending') { %>
            <p class="text-green-700 font-semibold">Seu certificado foi solicitado e está aguardando emissão.</p>
            <p class="text-sm text-green-600 mt-2">Código: <code class="font-mono bg-white px-2 py-1 rounded border border-green-200"><%= certificate.code %></code></p>
            <p class="text-sm text-gray-500 mt-2">Você receberá um e-mail quando estiver pronto.</p>
          <% } else { %>
            <svg class="w-12 h-12 text-green-500 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-green-700 font-bold text-lg mb-1">Certificado Emitido!</p>
            <p class="text-sm text-green-600 mb-3">Código: <code class="font-mono bg-white px-2 py-1 rounded border border-green-200"><%= certificate.code %></code></p>
            <p class="text-xs text-gray-500">Você pode validar este certificado a qualquer momento na página de validação.</p>
            <a href="//certificates/validate" class="xs-btn xs-btn-ghost mt-4">Validar Certificado</a>
          <% } %>
        </div>
      <% } else { %>
        <div class="bg-pinky-50 border border-pinky-200 rounded-xl p-6 mb-6">
          <p class="text-gray-700 mb-4">Pronto para receber seu certificado por concluir este curso.</p>
          <button id="requestCertBtn" class="xs-btn xs-btn-primary">Solicitar Certificado</button>
        </div>
      <% } %>

      <div class="text-left bg-gray-50 rounded-xl p-5 text-sm text-gray-500">
        <h3 class="font-semibold text-gray-700 mb-2">Como funciona</h3>
        <ul class="list-disc list-inside space-y-1">
          <li>Conclua todas as lições para se tornar elegível</li>
          <li>Solicite seu certificado — um administrador revisará e emitirá</li>
          <li>Você receberá um e-mail com o código do seu certificado</li>
          <li>Qualquer pessoa pode validar seu certificado usando o código</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  var token = localStorage.getItem('xs_token');
  if (!token) return;

  var requestBtn = document.getElementById('requestCertBtn');
  if (requestBtn) {
    requestBtn.addEventListener('click', function() {
      fetch('/api/courses/<%= course.slug %>/certificate/request', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token }
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.ok) { window.location.reload(); }
        else { alert(d.error || 'Request failed'); }
      })
      .catch(function() { alert('Network error'); });
    });
  }
})();
</script>

<%- include('../partials/footer', { lang, t }) %>
