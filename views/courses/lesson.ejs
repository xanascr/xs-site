<%- include('../partials/head', {}) %>
<%- include('../partials/navbar', {}) %>
<%
var lessonIdx = (course.lessons || []).findIndex(function(l) { return l.slug === lesson.slug });
var prevIdx = lessonIdx - 1;
var nextIdx = lessonIdx + 1;
var hasPrev = prevIdx >= 0;
var hasNext = nextIdx < (course.lessons || []).length;

// Extract headings from bodyMd for sidebar
var headingLines = [];
if (lesson.bodyMd) {
  var lines = lesson.bodyMd.split('\n');
  lines.forEach(function(line) {
    var m = line.match(/^(#{1,4})\s+(.+)$/);
    if (m) {
      headingLines.push({ level: m[1].length, text: m[2].trim(), id: m[2].trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') });
    }
  });
}
%>
<div id="focusOverlay" class="fixed inset-0 z-[60] bg-white hidden">
  <div class="flex items-center h-12 px-4 border-b border-gray-200 bg-white">
    <button id="exitFocusBtn" class="text-xs text-gray-400 hover:text-gray-600 flex items-center gap-1">&larr; Sair do Modo Foco</button>
    <span class="ml-auto text-xs text-gray-400"><%= lesson.title %></span>
  </div>
  <iframe id="focusFrame" class="w-full h-[calc(100%-3rem)] border-0"></iframe>
</div>

<section class="pt-20 pb-20 px-0 sm:px-6 min-h-screen" id="lessonPage">
  <div class="max-w-6xl mx-auto flex gap-6">
    <!-- Sidebar: headings -->
    <aside id="lessonSidebar" class="hidden lg:block w-56 shrink-0 sticky top-20 self-start max-h-[calc(100vh-6rem)] overflow-y-auto pt-4">
      <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3 px-3">Nesta página</div>
      <% if (headingLines.length > 0) { %>
        <nav class="space-y-0.5 px-2">
          <% headingLines.forEach(function(h) { %>
            <a href="#<%= h.id %>" class="block text-xs py-1 px-2 rounded-md text-gray-500 hover:text-pinky-500 hover:bg-pinky-50 no-underline transition-all truncate" style="padding-left: <%= (h.level - 1) * 12 + 8 %>px"><%= h.text %></a>
          <% }) %>
        </nav>
      <% } %>
      <div class="mt-4 px-3 space-y-1.5">
        <button id="focusBtn" class="w-full text-xs px-3 py-1.5 rounded-lg border border-gray-200 text-gray-500 hover:bg-gray-50 transition-all flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-4-4h4m14-16v4m4-4h-4M6 3h4M18 17v4m-4-4h4M3 15h4m14-6h4"/></svg>
          Modo Foco
        </button>
        <button id="ttsBtn" class="w-full text-xs px-3 py-1.5 rounded-lg border border-gray-200 text-gray-500 hover:bg-gray-50 transition-all flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M18.364 5.636a9 9 0 010 12.728M11 5L6 9H2v6h4l5 4V5z"/></svg>
          Ouvir
        </button>
        
      </div>
      
      <!-- TTS Controls -->
      <div id="ttsControls" class="hidden mt-3 px-3 space-y-2">
        <div class="text-xs text-gray-400">Velocidade</div>
        <input id="ttsSpeed" type="range" min="0.5" max="2" step="0.1" value="1" class="w-full accent-pinky-400">
        <div class="flex gap-1 text-xs">
          <span class="text-gray-400 flex-1 text-left" id="ttsSpeedLabel">1.0x</span>
          <button id="ttsStopBtn" class="text-red-400 hover:text-red-600 px-2 hidden">Parar</button>
        </div>
      </div>
    </aside>

    <!-- Main content -->
    <div class="flex-1 min-w-0">
      <div class="max-w-4xl mx-auto px-4 sm:px-0">
        <a href="/courses/<%= course.slug %>" class="text-sm text-gray-400 hover:text-pinky-400 no-underline mb-4 inline-block">&larr; Voltar ao curso</a>

        <div class="xs-card xs-card-glass animate-fade-in">
          <div class="p-6 sm:p-8">
            <div class="flex items-center justify-between mb-6">
              <div>
                <span class="text-xs text-gray-400 uppercase tracking-wider font-semibold">Lição <%= lessonIdx + 1 %> de <%= (course.lessons || []).length %></span>
                <h1 class="text-2xl sm:text-3xl font-black mt-1"><%= lesson.title %></h1>
              </div>
              <span class="xs-tag xs-tag-primary"><%= lesson.points || 0 %> pts</span>
            </div>

            <div id="lessonContent" class="lesson-prose mb-8 select-text">
              <%- lessonHtml %>
            </div>

            <!-- Challenges -->
            <div id="challengesArea">
              <% if (lesson.challenges && lesson.challenges.length > 0) { %>
                <div class="border-t border-gray-200 pt-6 mt-8">
                  <h2 class="text-xl font-bold mb-4">Desafios</h2>
                  <div id="challenges" class="space-y-4">
                    <% lesson.challenges.forEach(function(ch, i) { %>
                      <% var isDisabled = enrollment && enrollment.progress && enrollment.progress.find(function(p) { return p.lessonSlug === lesson.slug && p.completed }) %>
                      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 challenge-card" data-idx="<%= i %>">
                        <p class="font-semibold text-sm text-gray-800 mb-2">Desafio <%= i + 1 %>: <%= ch.question %></p>
                        <div class="flex items-center gap-2">
                          <input type="text" class="challenge-input xs-input w-full" data-idx="<%= i %>" data-answer="<%= ch.answer.replace(/"/g, '&quot;') %>" placeholder="Digite sua resposta..." <%= isDisabled ? 'disabled' : '' %>>
                          <span class="challenge-result text-sm font-semibold w-20 text-center"></span>
                        </div>
                        <div class="challenge-feedback text-xs mt-1 hidden"></div>
                      </div>
                    <% }) %>
                  </div>
                  <button id="checkAnswersBtn" class="xs-btn xs-btn-ghost mt-4">Verificar Respostas</button>
                </div>
              <% } %>
            </div>

            <!-- Complete / status -->
            <div class="flex items-center justify-between mt-8 pt-6 border-t border-gray-200">
              <div id="lessonStatus">
                <% if (enrollment && enrollment.progress && enrollment.progress.find(function(p) { return p.lessonSlug === lesson.slug && p.completed })) { %>
                  <span class="inline-flex items-center gap-1.5 text-sm text-green-600 font-semibold"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Concluído</span>
                <% } else if (enrollment) { %>
                  <button id="completeBtn" class="xs-btn xs-btn-primary">Marcar como Concluído</button>
                <% } else { %>
                  <a href="/login?redirect=/courses/<%= course.slug %>/lessons/<%= lesson.slug %>" class="xs-btn xs-btn-primary">Faça login para acompanhar o progresso</a>
                <% } %>
              </div>
              <span id="earnedPoints" class="text-sm text-gray-400"></span>
            </div>

            <!-- Navigation -->
            <div class="flex items-center justify-between mt-6 pt-4 border-t border-gray-100">
              <div>
                <% if (hasPrev) { %>
                  <a href="/courses/<%= course.slug %>/lessons/<%= course.lessons[prevIdx].slug %>" class="text-sm text-gray-400 hover:text-pinky-500 no-underline inline-flex items-center gap-1">&larr; Anterior</a>
                <% } %>
              </div>
              <div>
                <% if (hasNext) { %>
                  <a href="/courses/<%= course.slug %>/lessons/<%= course.lessons[nextIdx].slug %>" id="nextLessonBtn" class="text-sm font-semibold text-pinky-500 hover:text-pinky-600 no-underline inline-flex items-center gap-1">Proximo &rarr;</a>
                <% } else { %>
                  <a href="/courses/<%= course.slug %>/certificate" class="text-sm font-semibold text-pinky-500 hover:text-pinky-600 no-underline inline-flex items-center gap-1">Certificado &rarr;</a>
                <% } %>
              </div>
            </div>
          </div>
        </div>

        <!-- Comments -->
        <div class="xs-card xs-card-glass mt-8 p-6 sm:p-8" id="commentsSection">
          <h2 class="text-xl font-bold mb-4">Comentários</h2>
          <div id="commentsList" class="space-y-3">
            <div class="text-center py-6 text-gray-400 text-sm">Carregando comentários...</div>
          </div>
          <div id="commentForm" class="mt-4 hidden">
            <textarea id="commentBody" class="xs-input w-full" rows="3" placeholder="Compartilhe seus pensamentos..." maxlength="2000"></textarea>
            <button id="submitCommentBtn" class="xs-btn xs-btn-primary text-sm mt-2">Comentar</button>
            <span id="commentError" class="text-xs text-red-500 ml-2 hidden"></span>
          </div>
          <div id="loginToComment" class="mt-4 hidden">
            <a href="/login?redirect=/courses/<%= course.slug %>/lessons/<%= lesson.slug %>" class="text-sm text-pinky-500 underline">Faça login para comentar</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer', {}) %>

<style>
.highlight-annotation { background-color: #fef3c7; border-radius: 2px; cursor: pointer; }
.lesson-prose mark.highlight-annotation { background-color: #fde68a; }
#lessonPage { transition: all 0.3s ease; }
#lessonPage.focus-mode { padding-top: 0; }
#lessonPage.focus-mode .xs-card-glass { box-shadow: none; border-color: transparent; background: white; }
.tts-reading { text-decoration: underline wavy #f58b8e 1px; text-underline-offset: 4px; }
</style>

<script>
(function() {
  var token = localStorage.getItem('xs_token');
  var lang = 'pt';
  var courseSlug = '<%= course.slug %>';
  var lessonSlug = '<%= lesson.slug %>';
  var lessonContent = document.getElementById('lessonContent');
  // ── Focus Mode ─────────────────────────────────────────────────────────
  var focusBtn = document.getElementById('focusBtn');
  var focusOverlay = document.getElementById('focusOverlay');
  var focusFrame = document.getElementById('focusFrame');
  var exitFocusBtn = document.getElementById('exitFocusBtn');
  var lessonPage = document.getElementById('lessonPage');
  if (focusBtn) focusBtn.addEventListener('click', function() {
    focusOverlay.classList.remove('hidden');
    focusFrame.srcdoc = '<html><head><link rel="stylesheet" href="/css/lesson.css"><link rel="stylesheet" href="/css/markdown.css"><style>body{padding:2rem;max-width:860px;margin:0 auto;font-size:1.125rem;line-height:1.75;color:#374151;background:#fff;}.lesson-prose h1,.lesson-prose h2,.lesson-prose h3,.lesson-prose h4{color:#1f2937;font-weight:800;}.lesson-prose p{color:#374151;}.lesson-prose code{background:#f3f4f6;padding:0.125rem 0.375rem;border-radius:0.25rem;font-size:0.875em;}.lesson-prose pre{background:#f9fafb;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1rem;overflow-x:auto;}.lesson-prose pre code{background:none;padding:0;}.lesson-prose blockquote{border-left:4px solid #e5e7eb;padding-left:1rem;color:#6b7280;margin:1rem 0;}</style></head><body>' + lessonContent.innerHTML + '</body></html>';
    lessonPage.classList.add('focus-mode');
    document.body.style.overflow = 'hidden';
    setTimeout(function() { window.scrollTo({ top: 0 }); }, 10);
  });
  if (exitFocusBtn) exitFocusBtn.addEventListener('click', function() {
    focusOverlay.classList.add('hidden');
    lessonPage.classList.remove('focus-mode');
    document.body.style.overflow = '';
    focusFrame.srcdoc = '';
  });

  // ── Collapsible sidebar heading scroll tracking ────────────────────────
  var sidebarLinks = document.querySelectorAll('#lessonSidebar nav a');
  if (sidebarLinks.length > 0) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          sidebarLinks.forEach(function(a) { a.classList.remove('text-pinky-600', 'bg-pinky-50'); });
          var link = document.querySelector('#lessonSidebar nav a[href="#' + e.target.id + '"]');
          if (link) { link.classList.add('text-pinky-600', 'bg-pinky-50'); }
        }
      });
    }, { rootMargin: '-80px 0px -60% 0px' });
    document.querySelectorAll('.lesson-prose h1, .lesson-prose h2, .lesson-prose h3, .lesson-prose h4').forEach(function(el) {
      if (!el.id) el.id = el.textContent.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
      observer.observe(el);
    });
  }

  // ── TTS ────────────────────────────────────────────────────────────────
  var ttsBtn = document.getElementById('ttsBtn');
  var ttsControls = document.getElementById('ttsControls');
  var ttsSpeed = document.getElementById('ttsSpeed');
  var ttsSpeedLabel = document.getElementById('ttsSpeedLabel');
  var ttsStopBtn = document.getElementById('ttsStopBtn');
  var synth = window.speechSynthesis;
  var ttsUtterance = null;

  function getLessonText() {
    var el = lessonContent.cloneNode(true);
    el.querySelectorAll('pre, code, .challenge-card, button, input, textarea').forEach(function(n) { n.remove(); });
    return el.textContent.replace(/\s+/g, ' ').trim();
  }

  if (ttsBtn) ttsBtn.addEventListener('click', function() {
    if (ttsControls.classList.contains('hidden')) {
      ttsControls.classList.remove('hidden');
      ttsBtn.textContent = 'Lendo...';
    } else {
      ttsControls.classList.add('hidden');
      if (ttsUtterance) { speechSynthesis.cancel(); ttsUtterance = null; }
      ttsBtn.textContent = 'Ouvir';
    }
  });
  if (ttsSpeed) ttsSpeed.addEventListener('input', function() {
    var v = parseFloat(this.value);
    ttsSpeedLabel.textContent = v.toFixed(1) + 'x';
    if (ttsUtterance) { ttsUtterance.rate = v; }
  });
  if (ttsStopBtn) ttsStopBtn.addEventListener('click', function() {
    speechSynthesis.cancel();
    ttsUtterance = null;
    ttsControls.classList.add('hidden');
    ttsBtn.textContent = 'Ouvir';
  });

  // Start speaking when TTS controls shown and auto-scroll
  var ttsObserver = new MutationObserver(function() {
    if (!ttsControls.classList.contains('hidden') && !ttsUtterance) {
      var text = getLessonText();
      if (text) {
        ttsUtterance = new SpeechSynthesisUtterance(text);
        ttsUtterance.rate = parseFloat(ttsSpeed.value);
        ttsUtterance.lang = 'pt-BR';
        ttsUtterance.onend = function() { ttsUtterance = null; ttsControls.classList.add('hidden'); ttsBtn.textContent = 'Ouvir'; };
        speechSynthesis.speak(ttsUtterance);
      }
    }
  });
  ttsObserver.observe(ttsControls, { attributes: true, attributeFilter: ['class'] });

  // Add IDs to headings for sidebar anchors
  var hTags = lessonContent.querySelectorAll('h1, h2, h3, h4');
  hTags.forEach(function(el) {
    if (!el.id) el.id = el.textContent.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  });

  // ── Complete button ─────────────────────────────────────────────────
  var completeBtn = document.getElementById('completeBtn');
  if (completeBtn) {
    completeBtn.addEventListener('click', function() {
      var answers = [];
      document.querySelectorAll('.challenge-input').forEach(function(inp) {
        answers.push(inp.value);
      });
      completeBtn.disabled = true;
      completeBtn.textContent = 'Salvando...';
      fetch('/api/courses/' + courseSlug + '/lessons/' + lessonSlug + '/complete', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
        body: JSON.stringify({ answers: answers })
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.ok) {
          var pts = document.getElementById('earnedPoints');
          if (d.earned) pts.textContent = '+' + d.earned + ' XP ganhos!';
          pts.className = 'text-sm text-green-600 font-semibold';
          setTimeout(function() { window.location.reload(); }, 1200);
        } else {
          alert(d.error || 'Falhou');
          completeBtn.disabled = false;
          completeBtn.textContent = 'Marcar como Concluído';
        }
      })
      .catch(function() {
        alert('Erro de rede.');
        completeBtn.disabled = false;
        completeBtn.textContent = 'Marcar como Concluído';
      });
    }).catch(function(){ /* ignore */ });
  }

  // ── Check answers ───────────────────────────────────────────────────
  var checkBtn = document.getElementById('checkAnswersBtn');
  if (checkBtn) {
    checkBtn.addEventListener('click', function() {
      var allCorrect = true;
      document.querySelectorAll('.challenge-card').forEach(function(card) {
        var inp = card.querySelector('.challenge-input');
        var correctAnswer = inp.getAttribute('data-answer');
        var userAnswer = inp.value.trim().toLowerCase();
        var correctLow = (correctAnswer || '').trim().toLowerCase();
        var isCorrect = correctAnswer && userAnswer === correctLow;
        var resultSpan = card.querySelector('.challenge-result');
        var fb = card.querySelector('.challenge-feedback');
        inp.className = inp.className.replace(/border-(red|green)-\d+/g, '').trim() + ' xs-input w-full';
        inp.classList.remove('border-gray-200');
        if (!userAnswer) {
          if (resultSpan) { resultSpan.textContent = ''; resultSpan.className = 'challenge-result text-sm font-semibold w-20 text-center'; }
          if (fb) { fb.classList.add('hidden'); }
          allCorrect = false; return;
        }
        if (isCorrect) {
          inp.classList.add('border-green-300', 'bg-green-50');
          if (resultSpan) { resultSpan.textContent = '\u2713 Correto'; resultSpan.className = 'challenge-result text-sm font-semibold w-20 text-center text-green-600'; }
          if (fb) { fb.textContent = ''; fb.classList.add('hidden'); }
        } else {
          inp.classList.add('border-red-300');
          if (resultSpan) { resultSpan.textContent = 'Errado'; resultSpan.className = 'challenge-result text-sm font-semibold w-20 text-center text-red-500'; }
          if (fb) { fb.textContent = 'Resposta começa com: ' + (correctAnswer ? correctAnswer.substring(0, 3) + '...' : ''); fb.classList.remove('hidden'); fb.className = 'challenge-feedback text-xs mt-1 text-red-500'; }
          allCorrect = false;
        }
      });
      if (allCorrect && completeBtn) {
        completeBtn.textContent = 'Tudo certo! Concluir \u2192';
        completeBtn.className = 'xs-btn xs-btn-primary animate-pulse';
      }
    });
  }

  // ── Comments ─────────────────────────────────────────────────────
  function loadComments() {
    fetch('/api/courses/' + courseSlug + '/lessons/' + lessonSlug + '/comments')
      .then(function(r) { return r.json(); }).then(function(d) {
        var list = document.getElementById('commentsList');
        if (!d.ok || !d.comments || d.comments.length === 0) {
          list.innerHTML = '<div class="text-center py-6 text-gray-400 text-sm">Nenhum comentário ainda. Seja o primeiro!</div>';
          return;
        }
        list.innerHTML = '';
        d.comments.forEach(function(c) {
          list.innerHTML += '<div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="flex items-center gap-2 mb-1">'
            + '<span class="font-semibold text-xs text-gray-700">' + escapeHtml(c.username) + '</span>'
            + '<span class="text-xs text-gray-400">' + new Date(c.createdAt).toLocaleDateString() + '</span>'
            + (c.userId === (token ? parseJwt(token).id : null) ? '<button class="text-xs text-red-400 hover:text-red-600 ml-auto delete-comment" data-id="' + c._id + '">Excluir</button>' : '') + '</div>'
            + '<p class="text-sm text-gray-700">' + escapeHtml(c.body) + '</p></div>';
        });
        document.querySelectorAll('.delete-comment').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var id = this.getAttribute('data-id');
            if (!confirm('Excluir este comentário?')) return;
            fetch('/api/courses/' + courseSlug + '/lessons/' + lessonSlug + '/comments/' + id, {
              method: 'DELETE', headers: { 'Authorization': 'Bearer ' + token }
            }).then(function(r) { return r.json(); }).then(function(d) { if (d.ok) loadComments(); else alert(d.error || 'Falhou'); }).catch(function() { alert('Erro de rede'); });
          });
        });
      });
  }
  function parseJwt(token) { try { return JSON.parse(atob(token.split('.')[1])); } catch(e) { return {}; } }
  function escapeHtml(str) { var d = document.createElement('div'); d.textContent = str; return d.innerHTML; }
  var commentForm = document.getElementById('commentForm');
  if (token) { commentForm.classList.remove('hidden'); } else { document.getElementById('loginToComment').classList.remove('hidden'); }
  var submitBtn = document.getElementById('submitCommentBtn');
  if (submitBtn) {
    submitBtn.addEventListener('click', function() {
      var body = document.getElementById('commentBody');
      if (!body.value.trim()) { document.getElementById('commentError').textContent = 'Comentário não pode ficar vazio'; document.getElementById('commentError').classList.remove('hidden'); return; }
      submitBtn.disabled = true; submitBtn.textContent = 'Publicando...';
      fetch('/api/courses/' + courseSlug + '/lessons/' + lessonSlug + '/comments', {
        method: 'POST', headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' }, body: JSON.stringify({ body: body.value.trim() })
      }).then(function(r) { return r.json(); }).then(function(d) {
        if (d.ok) { body.value = ''; loadComments(); document.getElementById('commentError').classList.add('hidden'); }
        else { document.getElementById('commentError').textContent = d.error || 'Falhou'; document.getElementById('commentError').classList.remove('hidden'); }
        submitBtn.disabled = false; submitBtn.textContent = 'Comentar';
      }).catch(function() { document.getElementById('commentError').textContent = 'Erro de rede.'; document.getElementById('commentError').classList.remove('hidden'); submitBtn.disabled = false; submitBtn.textContent = 'Comentar'; });
    });
  }
  loadComments();
  // ── Keyboard Navigation ──────────────────────────────────────────
  (function() {
    var sections = document.querySelectorAll('h2, h3, h4');
    var focusables = [];
    sections.forEach(function(s) { focusables.push(s); });
    if (focusables.length === 0) return;
    function scrollToSection(el) { if (el) { el.scrollIntoView({ behavior: 'smooth', block: 'start' }); el.focus({ preventScroll: true }); } }
    var curIdx = 0;
    document.addEventListener('keydown', function(e) {
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
      if (e.key === 'Tab') {
        var shift = e.shiftKey;
        var sidebar = document.getElementById('lessonSidebar');
        if (sidebar && !sidebar.contains(e.target)) return;
        if (shift) { e.preventDefault(); curIdx = curIdx > 0 ? curIdx - 1 : focusables.length - 1; }
        else { e.preventDefault(); curIdx = curIdx < focusables.length - 1 ? curIdx + 1 : 0; }
        scrollToSection(focusables[curIdx]);
      }
      if (e.key === 'ArrowDown') { e.preventDefault(); curIdx = Math.min(curIdx + 1, focusables.length - 1); scrollToSection(focusables[curIdx]); }
      if (e.key === 'ArrowUp') { e.preventDefault(); curIdx = Math.max(curIdx - 1, 0); scrollToSection(focusables[curIdx]); }
      if (e.key === 'Enter' && focusables[curIdx]) {
        var id = focusables[curIdx].id;
        if (id) window.location.hash = '#' + id;
      }
    });
  })();

  // ── Time tracking ─────────────────────────────────────────────────
  (function() {
    var startTime = Date.now();
    var interval = setInterval(function() {
      var elapsed = Math.round((Date.now() - startTime) / 1000);
      if (elapsed > 0 && elapsed % 30 === 0) {
        fetch('/api/stats/lesson/time', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ courseSlug: courseSlug, lessonSlug: lessonSlug, seconds: 30 })
        }).catch(function() {});
      }
    }, 1000);
    window.addEventListener('beforeunload', function() {
      var elapsed = Math.round((Date.now() - startTime) / 1000);
      if (elapsed >= 10) {
        navigator.sendBeacon('/api/stats/lesson/time', JSON.stringify({ courseSlug: courseSlug, lessonSlug: lessonSlug, seconds: elapsed }));
      }
    });
  })();
})();
</script>