<%- include('../layouts/main', { body: `
<div class="max-w-6xl mx-auto px-4 py-12">
  <h1 class="font-heading font-800 text-3xl mb-8">Cursos</h1>
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% courses.forEach(c => { %>
      <a href="/courses/<%= c.slug %>" class="block bg-bg-2 border border-border rounded p-6 hover:border-primary transition-colors group">
        <h2 class="font-heading font-700 text-lg group-hover:text-primary transition-colors"><%= c.title %></h2>
        <p class="text-text-2 text-sm mt-2 line-clamp-2"><%= c.description %></p>
        <div class="flex items-center gap-3 mt-4 text-xs text-text-2">
          <span class="capitalize"><%= c.level %></span>
          <span><%= c.modules.length %> módulos</span>
        </div>
      </a>
    <% }) %>
  </div>
</div>
`}) %>
