<%- include('partials/head', {}) %>
<%- include('partials/navbar', {}) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen flex items-center justify-center">
  <div class="w-full max-w-sm">
    <h1 class="text-3xl font-black text-center mb-2">Esqueceu sua senha?</h1>
    <p class="text-center text-gray-400 text-sm mb-8">Enviaremos um link de redefinição</p>

    <% if (typeof sent !== 'undefined' && sent === '1') { %>
    <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-xl px-4 py-3 mb-4 text-center">Se esse email estiver registrado, um link de redefinição foi enviado.</div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-50 border border-red-200 text-red-600 text-sm rounded-xl px-4 py-3 mb-4 text-center"><%= error %></div>
    <% } %>

    <form id="forgotForm" class="space-y-4">
      <input name="email" type="email" placeholder="Endereço de email" required class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-pinky-400">
      <div id="forgotError" class="text-red-500 text-sm hidden"></div>
      <button type="submit" class="w-full bg-pinky-400 hover:bg-pinky-500 text-white font-semibold py-3 rounded-xl transition-all">Enviar Link de Redefinição</button>
    </form>

    <p class="text-center text-sm text-gray-400 mt-4"><a href="<%= '' %>/login" class="text-pinky-400 hover:underline">Voltar para entrar</a></p>
  </div>
</section>

<script>
document.getElementById('forgotForm').onsubmit = async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const errEl = document.getElementById('forgotError');
  errEl.classList.add('hidden');
  try {
    const res = await fetch('/api/auth/forgot-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: fd.get('email') }),
    });
    const data = await res.json();
    if (!data.ok) { errEl.textContent = data.error; errEl.classList.remove('hidden'); return; }
    window.location.href = '<%= '' %>/forgot-password?sent=1';
  } catch (e) { errEl.textContent = 'Erro de rede'; errEl.classList.remove('hidden'); }
};
</script>

<%- include('partials/footer', {}) %>
