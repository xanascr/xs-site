<%- include('../partials/head', { lang, t, alternates }) %>
<%- include('../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-2xl mx-auto animate-fade-in">
    <h1 class="text-3xl font-black mb-6">Configurações da Conta</h1>

    <div class="xs-card xs-card-glass p-6 mb-6">
      <h2 class="text-xl font-bold mb-4">Autenticação de Dois Fatores</h2>

      <div id="tfaStatus" class="mb-4">
        <div class="text-center py-4 text-gray-400 text-sm">Carregando...</div>
      </div>

      <div id="tfaSetup" class="hidden space-y-4">
        <p class="text-sm text-gray-600">Escaneie o QR code abaixo com seu aplicativo autenticador (Google Authenticator, Authy, etc.) e insira o código de 6 dígitos para confirmar.</p>
        <div class="flex justify-center">
          <div id="tfaQrContainer" class="bg-white p-4 rounded-xl border border-gray-200">
            <div class="text-center py-8 text-gray-400 text-sm">Gerando QR code...</div>
          </div>
        </div>
        <div class="text-center text-xs text-gray-400">Ou insira manualmente esta chave: <code id="tfaSecret" class="font-mono text-pinky-500"></code></div>
        <div class="max-w-xs mx-auto">
          <input id="tfaCode" type="text" placeholder="000000" inputmode="numeric" class="xs-input text-center text-xl tracking-widest">
          <button id="tfaConfirmBtn" class="xs-btn xs-btn-primary w-full justify-center mt-2">Ativar 2FA</button>
          <span id="tfaError" class="text-xs text-red-500 hidden mt-1 block text-center"></span>
        </div>
      </div>

      <div id="tfaActive" class="hidden space-y-4">
        <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-sm text-green-700">Autenticação de dois fatores está ativa.</div>
        <button id="tfaDisableBtn" class="xs-btn xs-btn-ghost text-red-500 border-red-200 hover:bg-red-50">Desativar 2FA</button>
        <div id="tfaDisableForm" class="hidden space-y-2 max-w-xs">
          <input id="tfaDisablePassword" type="password" placeholder="Sua senha" class="xs-input">
          <input id="tfaDisableCode" type="text" placeholder="Código 2FA (opcional)" class="xs-input">
          <button id="tfaDisableConfirmBtn" class="xs-btn xs-btn-ghost text-red-500 border-red-200 hover:bg-red-50">Confirmar Desativação</button>
          <span id="tfaDisableError" class="text-xs text-red-500 hidden"></span>
        </div>
      </div>
    </div>

    <div class="xs-card xs-card-glass p-6">
      <h2 class="text-xl font-bold mb-2">Códigos de Backup</h2>
      <p class="text-sm text-gray-500 mb-4">Guarde estes códigos em local seguro. Cada um pode ser usado uma vez se você perder acesso ao autenticador.</p>
      <div id="backupCodesList" class="hidden">
        <pre id="backupCodesPre" class="bg-gray-50 border border-gray-200 rounded-lg p-3 text-sm font-mono text-center tracking-wider"></pre>
        <p class="text-xs text-red-500 mt-2">Salve agora. Eles não serão mostrados novamente.</p>
      </div>
      <button id="tfaBackupBtn" class="xs-btn xs-btn-ghost text-sm">Regenerar Códigos de Backup</button>
      <span id="tfaBackupError" class="text-xs text-red-500 hidden ml-2"></span>
    </div>
  </div>
</section>

<%- include('../partials/footer', { lang, t }) %>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
(function() {
  var token = localStorage.getItem('xs_token');
  if (!token) { window.location.href = '/<%= lang %>/login?redirect=/<%= lang %>/settings'; return; }

  var tfaStatus = document.getElementById('tfaStatus');
  var tfaSetup = document.getElementById('tfaSetup');
  var tfaActive = document.getElementById('tfaActive');
  var tfaQr = document.getElementById('tfaQrContainer');
  var tfaSecret = document.getElementById('tfaSecret');
  var tfaCode = document.getElementById('tfaCode');
  var tfaConfirmBtn = document.getElementById('tfaConfirmBtn');
  var tfaError = document.getElementById('tfaError');
  var tfaDisableBtn = document.getElementById('tfaDisableBtn');
  var tfaDisableForm = document.getElementById('tfaDisableForm');
  var tfaDisablePassword = document.getElementById('tfaDisablePassword');
  var tfaDisableCode = document.getElementById('tfaDisableCode');
  var tfaDisableConfirmBtn = document.getElementById('tfaDisableConfirmBtn');
  var tfaDisableError = document.getElementById('tfaDisableError');
  var backupCodesList = document.getElementById('backupCodesList');
  var backupCodesPre = document.getElementById('backupCodesPre');
  var tfaBackupBtn = document.getElementById('tfaBackupBtn');
  var tfaBackupError = document.getElementById('tfaBackupError');

  var headers = { 'Authorization': 'Bearer ' + token };

  fetch('/api/auth/2fa/status', { headers: headers })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.ok) return;
      tfaStatus.innerHTML = '';
      if (data.twoFactorEnabled) {
        tfaActive.classList.remove('hidden');
      } else {
        tfaSetup.classList.remove('hidden');
        setup2FA();
      }
    });

  function setup2FA() {
    fetch('/api/auth/2fa/setup', { method: 'POST', headers: headers })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.ok) { tfaQr.innerHTML = '<div class="text-red-500 text-sm">Falha ao gerar QR code.</div>'; return; }
        tfaSecret.textContent = data.secret;
        tfaQr.innerHTML = '<div id="qrcode"></div>';
        new QRCode(document.getElementById('qrcode'), { text: data.otpauth, width: 200, height: 200 });
      });
  }

  tfaConfirmBtn.addEventListener('click', function() {
    var code = tfaCode.value.trim();
    if (!code) { tfaError.textContent = 'Insira o código do autenticador.'; tfaError.classList.remove('hidden'); return; }
    tfaConfirmBtn.disabled = true; tfaConfirmBtn.textContent = 'Verificando...';
    fetch('/api/auth/2fa/confirm', { method: 'POST', headers: Object.assign({}, headers, { 'Content-Type': 'application/json' }), body: JSON.stringify({ code: code }) })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.ok) { tfaError.textContent = d.error; tfaError.classList.remove('hidden'); tfaConfirmBtn.disabled = false; tfaConfirmBtn.textContent = 'Ativar 2FA'; return; }
        tfaSetup.classList.add('hidden');
        tfaActive.classList.remove('hidden');
        backupCodesList.classList.remove('hidden');
        backupCodesPre.textContent = d.backupCodes ? d.backupCodes.join('\n') : '';
      });
  });

  tfaDisableBtn.addEventListener('click', function() { tfaDisableForm.classList.toggle('hidden'); });

  tfaDisableConfirmBtn.addEventListener('click', function() {
    var body = { password: tfaDisablePassword.value };
    if (tfaDisableCode.value) body.code = tfaDisableCode.value;
    fetch('/api/auth/2fa/disable', { method: 'POST', headers: Object.assign({}, headers, { 'Content-Type': 'application/json' }), body: JSON.stringify(body) })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.ok) { tfaDisableError.textContent = d.error; tfaDisableError.classList.remove('hidden'); return; }
        window.location.reload();
      });
  });

  tfaBackupBtn.addEventListener('click', function() {
    var password = prompt('Digite sua senha para regenerar códigos de backup:');
    if (!password) return;
    fetch('/api/auth/2fa/backup-codes', { method: 'POST', headers: Object.assign({}, headers, { 'Content-Type': 'application/json' }), body: JSON.stringify({ password: password }) })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.ok) { tfaBackupError.textContent = d.error; tfaBackupError.classList.remove('hidden'); return; }
        backupCodesList.classList.remove('hidden');
        backupCodesPre.textContent = d.backupCodes ? d.backupCodes.join('\n') : '';
        tfaBackupError.textContent = ''; tfaBackupError.classList.add('hidden');
      });
  });
})();
</script>