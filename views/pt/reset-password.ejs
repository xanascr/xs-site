<%- include('../partials/head', { lang, t, alternates }) %>
<%- include('../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen flex items-center justify-center">
  <div class="w-full max-w-sm">
    <h1 class="text-3xl font-black text-center mb-2">Nova senha</h1>
    <p class="text-center text-gray-500 text-sm mb-8">Escolha uma nova senha para sua conta</p>
    <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-600 text-sm rounded-xl px-4 py-3 mb-4 text-center"><%= error %></div>
    <% } %>
    <form id="resetForm" class="space-y-4">
      <input type="hidden" name="token" value="<%= token %>">
      <input name="password" type="password" placeholder="Nova senha" required minlength="6" class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-pinky-400">
      <input name="confirm" type="password" placeholder="Confirmar senha" required minlength="6" class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-pinky-400">
      <div id="resetError" class="text-red-500 text-sm hidden"></div>
      <button type="submit" class="w-full bg-pinky-400 hover:bg-pinky-500 text-white font-semibold py-3 rounded-xl transition-all">Redefinir senha</button>
    </form>
    <p class="text-center text-sm text-gray-400 mt-4"><a href="/<%= lang === 'en' ? '' : lang %>/login" class="text-pinky-400 hover:underline">Voltar ao login</a></p>
  </div>
</section>

<script>
document.getElementById('resetForm').onsubmit = async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const errEl = document.getElementById('resetError');
  errEl.classList.add('hidden');
  if (fd.get('password') !== fd.get('confirm')) {
    errEl.textContent = 'As senhas não conferem';
    errEl.classList.remove('hidden');
    return;
  }
  try {
    const res = await fetch('/api/auth/reset-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token: fd.get('token'), password: fd.get('password') }),
    });
    const data = await res.json();
    if (!data.ok) { errEl.textContent = data.error; errEl.classList.remove('hidden'); return; }
    window.location.href = '/<%= lang === 'en' ? '' : lang %>/login';
  } catch (e) { errEl.textContent = 'Erro de rede'; errEl.classList.remove('hidden'); }
};
</script>

<%- include('../partials/footer', { lang, t }) %>
