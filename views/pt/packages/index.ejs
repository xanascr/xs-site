<%- include('../../partials/head', { lang, t, alternates }) %>
<%- include('../../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-5xl mx-auto">
    <h1 class="text-3xl md:text-5xl font-black text-center mb-4"><%= t('packages.title') %></h1>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light"><%= t('packages.subtitle') %></p>

    <form method="GET" class="max-w-md mx-auto mb-8">
      <input type="text" name="q" value="<%= query %>" placeholder="<%= t('packages.search') %>" class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-pinky-400 focus:ring-1 focus:ring-pinky-200">
    </form>

    <% if (packages.length === 0) { %>
    <p class="text-center text-gray-400 text-sm"><%= t('packages.noResults') %></p>
    <% } else { %>
    <div class="grid gap-4">
      <% packages.forEach(function(pkg) { %>
      <a href="/<%= lang === 'en' ? '' : lang %>/packages/<%= pkg.name %>" class="block bg-white rounded-2xl border border-gray-200 p-5 no-underline hover:border-pinky-200 hover:shadow-sm transition-all">
        <div class="flex items-start justify-between">
          <div>
            <h3 class="font-bold text-gray-800"><%= pkg.name %></h3>
            <p class="text-sm text-gray-500 mt-1"><%= pkg.description %></p>
          </div>
          <div class="text-right text-xs text-gray-400">
            <div>v<%= pkg.version %></div>
            <div class="mt-1"><%= pkg.downloads?.toLocaleString() || 0 %> downloads</div>
          </div>
        </div>
        <div class="flex items-center gap-2 mt-3">
          <% if (pkg.license) { %><span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded"><%= pkg.license %></span><% } %>
          <% if (pkg.author) { %><span class="text-xs text-gray-400">por <%= pkg.author %></span><% } %>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>
  </div>
</section>

<%- include('../../partials/footer', { lang, t }) %>
