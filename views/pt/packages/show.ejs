<%- include('../../partials/head', { lang, t, alternates }) %>
<%- include('../../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-3xl mx-auto">
    <a href="/<%= lang === 'en' ? '' : lang %>/packages" class="text-sm text-gray-400 hover:text-pinky-400 no-underline">&larr; <%= t('packages.title') %></a>

    <div class="mt-6 bg-white rounded-2xl border border-gray-200 p-8">
      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-3xl font-black text-gray-800"><%= pkg.name %></h1>
          <p class="text-gray-500 mt-2"><%= pkg.description %></p>
        </div>
        <div class="text-right text-sm text-gray-400">
          <div><%= t('packages.version') %>: v<%= pkg.version %></div>
          <div class="mt-1"><%= pkg.downloads?.toLocaleString() || 0 %> <%= t('packages.downloads') %></div>
        </div>
      </div>

      <div class="flex items-center gap-3 mt-4">
        <% if (pkg.license) { %><span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded"><%= t('packages.license') %>: <%= pkg.license %></span><% } %>
        <% if (pkg.author) { %><span class="text-xs text-gray-400">por <%= pkg.author %></span><% } %>
        <span class="text-xs text-gray-400"><%= t('packages.updated') %>: <%= new Date(pkg.updatedAt).toLocaleDateString() %></span>
      </div>

      <% if (pkg.repository) { %>
      <div class="mt-4">
        <a href="<%= pkg.repository %>" target="_blank" class="text-sm text-pinky-400 hover:underline"><%= pkg.repository %></a>
      </div>
      <% } %>

      <div class="mt-6 flex gap-3">
        <button onclick="navigator.clipboard.writeText('xs install <%= pkg.name %>')" class="bg-pinky-400 hover:bg-pinky-500 text-white px-5 py-2 rounded-lg font-semibold text-sm transition-all"><%= t('packages.install') %> <%= pkg.name %></button>
      </div>

      <% if (pkg.readmeSanitized) { %>
      <div class="mt-8 prose prose-sm max-w-none text-gray-600">
        <%- pkg.readmeSanitized %>
      </div>
      <% } %>
    </div>
  </div>
</section>

<%- include('../../partials/footer', { lang, t }) %>
