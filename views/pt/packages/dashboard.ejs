<%- include('../../partials/head', { lang, t, alternates }) %>
<%- include('../../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-black">Meus Pacotes</h1>
        <p class="text-gray-500 text-sm mt-1" id="userInfo"></p>
      </div>
      <button id="logoutBtn" class="text-sm text-gray-400 hover:text-red-500 transition-colors">Sair</button>
    </div>

    <div id="packageList" class="space-y-4"></div>

    <div id="noPackages" class="text-center py-12 hidden">
      <p class="text-gray-400">Você ainda não publicou nenhum pacote.</p>
      <a href="/<%= lang %>/packages" class="mt-4 inline-block bg-pinky-400 hover:bg-pinky-500 text-white px-5 py-2 rounded-lg font-semibold text-sm transition-all">Ver pacotes</a>
    </div>
  </div>
</section>

<div id="editModal" class="fixed inset-0 z-50 bg-black/40 hidden items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl border border-gray-200 w-full max-w-3xl max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between p-6 border-b border-gray-100">
      <h2 id="editModalTitle" class="text-xl font-black text-gray-800"></h2>
      <button id="editCloseBtn" class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
    </div>
    <div class="p-6 space-y-4">
      <input type="hidden" id="editPkgName">
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Descrição</label>
        <textarea id="editDesc" rows="2" class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-pinky-400 resize-none"></textarea>
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Palavras-chave (separadas por vírgula)</label>
        <input id="editKeywords" class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-pinky-400">
      </div>
      <div class="flex gap-4">
        <div class="flex-1">
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Licença</label>
          <input id="editLicense" class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-pinky-400">
        </div>
        <div class="flex-1">
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">URL do Repositório</label>
          <input id="editRepo" class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-pinky-400">
        </div>
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">README (Markdown)</label>
        <textarea id="editReadme" rows="8" class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm font-mono focus:outline-none focus:border-pinky-400"></textarea>
      </div>
      <div id="editReadmePreview" class="hidden">
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Visualizar</label>
        <div id="editReadmePreviewContent" class="markdown-body border border-gray-200 rounded-xl p-4 text-sm"></div>
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Dependências (separadas por vírgula)</label>
        <input id="editDeps" class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-pinky-400">
      </div>
      <div id="editReadmeMdPreview" class="hidden border border-gray-200 rounded-xl p-4">
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Preview do README</label>
        <div id="editPreviewContent" class="markdown-body text-sm"></div>
      </div>
    </div>
    <div class="flex justify-end gap-3 px-6 pb-6">
      <button id="editCancelBtn" class="px-4 py-2 rounded-lg border border-gray-200 text-gray-600 text-sm font-semibold hover:bg-gray-50 transition-colors">Cancelar</button>
      <button id="editSaveBtn" class="px-5 py-2 rounded-lg bg-pinky-400 hover:bg-pinky-500 text-white text-sm font-semibold transition-all">Salvar</button>
    </div>
  </div>
</div>

<script>
(function() {
  var token = localStorage.getItem('xs_token');
  var user = JSON.parse(localStorage.getItem('xs_user') || 'null');
  if (!token || !user) { window.location.href = '<%= lang === 'en' ? '' : '/' + lang %>/login'; return; }
  document.getElementById('userInfo').textContent = 'Logado como ' + user.username + ' (' + user.role + ')';
  document.getElementById('editModal').addEventListener('click', function(e) { if (e.target === this) closeEdit(); });
  document.getElementById('editCloseBtn').addEventListener('click', closeEdit);
  document.getElementById('editCancelBtn').addEventListener('click', closeEdit);
  document.getElementById('logoutBtn').onclick = async function() {
    try { await fetch('/api/auth/logout', { method:'POST', headers:{'Authorization':'Bearer '+token} }); } catch(_) {}
    localStorage.removeItem('xs_token');
    localStorage.removeItem('xs_user');
    window.location.href = '<%= lang === 'en' ? '' : '/' + lang %>/';
  };

  function loadPackages() {
    fetch('/api/packages/mine', { headers: { 'Authorization': 'Bearer ' + token } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var list = document.getElementById('packageList');
        var none = document.getElementById('noPackages');
        list.innerHTML = '';
        if (!data.ok || !data.packages || data.packages.length === 0) {
          none.classList.remove('hidden');
          return;
        }
        none.classList.add('hidden');
        data.packages.forEach(function(pkg) {
          var statusColor = { pending: 'text-amber-500', approved: 'text-green-600', rejected: 'text-red-500' };
          var card = document.createElement('div');
          card.className = 'bg-white rounded-2xl border border-gray-200 p-5';
          card.innerHTML = ''
            + '<div class="flex items-start justify-between">'
            + '<div class="min-w-0 flex-1">'
            + '<h3 class="font-bold text-gray-800">' + escapeHtml(pkg.name) + '</h3>'
            + '<p class="text-sm text-gray-500 mt-1 truncate">' + escapeHtml(pkg.description || '') + '</p>'
            + '</div>'
            + '<div class="text-right shrink-0 ml-4">'
            + '<div class="text-sm font-semibold ' + (statusColor[pkg.status] || 'text-gray-400') + '">' + pkg.status + '</div>'
            + '<div class="text-xs text-gray-400 mt-1">v' + pkg.version + '</div>'
            + '</div>'
            + '</div>'
            + (pkg.reviewNotes ? '<div class="mt-2 text-sm text-red-500 bg-red-50 rounded-lg px-3 py-2">Notas da revisão: ' + escapeHtml(pkg.reviewNotes) + '</div>' : '')
            + '<div class="mt-3 flex items-center justify-between">'
            + '<div class="text-xs text-gray-400">Enviado ' + new Date(pkg.createdAt).toLocaleDateString() + ' | ' + (pkg.downloads || 0) + ' downloads</div>'
            + '<button class="edit-btn text-xs bg-gray-100 hover:bg-pinky-100 text-gray-600 hover:text-pinky-600 px-3 py-1.5 rounded-lg font-semibold transition-colors" data-name="' + pkg.name + '">Editar</button>'
            + '</div>';
          list.appendChild(card);
        });

        document.querySelectorAll('.edit-btn').forEach(function(btn) {
          btn.onclick = function() {
            openEdit(this.dataset.name);
          };
        });
      });
  }

  window.openEdit = function(name) {
    fetch('/api/packages/' + name, { headers: { 'Authorization': 'Bearer ' + token } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.ok || !data.package) { alert('Falha ao carregar dados do pacote'); return; }
        var pkg = data.package;
        document.getElementById('editModalTitle').textContent = 'Editar ' + pkg.name;
        document.getElementById('editPkgName').value = pkg.name;
        document.getElementById('editDesc').value = pkg.description || '';
        document.getElementById('editKeywords').value = (pkg.keywords || []).join(', ');
        document.getElementById('editLicense').value = pkg.license || '';
        document.getElementById('editRepo').value = pkg.repository || '';
        document.getElementById('editReadme').value = pkg.readme || '';
        document.getElementById('editDeps').value = (pkg.dependencies || []).join(', ');
        document.getElementById('editModal').classList.remove('hidden');
        document.getElementById('editModal').classList.add('flex');
        document.getElementById('editReadmePreview').classList.add('hidden');
      });
  };

  window.closeEdit = function() {
    document.getElementById('editModal').classList.add('hidden');
    document.getElementById('editModal').classList.remove('flex');
  };

  document.getElementById('editSaveBtn').onclick = function() {
    var name = document.getElementById('editPkgName').value;
    var keywords = document.getElementById('editKeywords').value.split(',').map(function(s) { return s.trim(); }).filter(function(s) { return s; });
    var deps = document.getElementById('editDeps').value.split(',').map(function(s) { return s.trim(); }).filter(function(s) { return s; });
    var body = {
      description: document.getElementById('editDesc').value,
      keywords: keywords,
      license: document.getElementById('editLicense').value,
      repository: document.getElementById('editRepo').value,
      readme: document.getElementById('editReadme').value,
      dependencies: deps,
    };
    var btn = this;
    btn.disabled = true;
    btn.textContent = 'Salvando...';
    fetch('/api/packages/' + name, {
      method: 'PUT',
      headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.ok) { alert(data.error || 'Falha ao atualizar'); btn.disabled = false; btn.textContent = 'Salvar'; return; }
        closeEdit();
        loadPackages();
      })
      .catch(function() { alert('Erro de rede'); btn.disabled = false; btn.textContent = 'Salvar'; });
  };

  document.getElementById('editReadme').oninput = function() {
    var val = this.value.trim();
    var preview = document.getElementById('editReadmePreview');
    if (!val) { preview.classList.add('hidden'); return; }
    preview.classList.remove('hidden');
    document.getElementById('editPreviewContent').innerHTML = '<div class="text-xs text-gray-400">Carregando preview...</div>';
    clearTimeout(window._mdTimer);
    window._mdTimer = setTimeout(function() {
      fetch('https://api.github.com/markdown', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: val, mode: 'gfm' }),
      })
        .then(function(r) { return r.text(); })
        .then(function(html) {
          document.getElementById('editPreviewContent').innerHTML = html;
          if (typeof hljs !== 'undefined') {
            document.querySelectorAll('#editPreviewContent pre code').forEach(function(b) { hljs.highlightElement(b); });
          }
        })
        .catch(function() {
          document.getElementById('editPreviewContent').innerHTML = '<div class="text-xs text-gray-400">Preview indisponível offline.</div>';
        });
    }, 500);
  };

  function escapeHtml(str) {
    if (!str) return '';
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  loadPackages();
})();
</script>

<%- include('../../partials/footer', { lang, t }) %>
