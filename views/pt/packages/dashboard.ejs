<%- include('../../partials/head', { lang, t, alternates }) %>
<%- include('../../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-black">Meus Pacotes</h1>
        <p class="text-gray-500 text-sm mt-1" id="userInfo"></p>
      </div>
      <button id="logoutBtn" class="text-sm text-gray-400 hover:text-red-500 transition-colors">Sair</button>
    </div>

    <div id="packageList" class="space-y-4"></div>

    <div id="noPackages" class="text-center py-12 hidden">
      <p class="text-gray-400">Você ainda não publicou nenhum pacote.</p>
      <a href="/<%= lang === 'en' ? '' : lang %>/packages/publish" class="mt-4 inline-block bg-pinky-400 hover:bg-pinky-500 text-white px-5 py-2 rounded-lg font-semibold text-sm transition-all">Publicar seu primeiro pacote</a>
    </div>
  </div>
</section>

<script>
(function() {
  var token = localStorage.getItem('xs_token');
  var user = JSON.parse(localStorage.getItem('xs_user') || 'null');
  if (!token || !user) { window.location.href = '/<%= lang === 'en' ? '' : lang %>/login'; return; }
  document.getElementById('userInfo').textContent = 'Logado como ' + user.username + ' (' + user.role + ')';
  document.getElementById('logoutBtn').onclick = function() {
    localStorage.removeItem('xs_token');
    localStorage.removeItem('xs_user');
    window.location.href = '/<%= lang === 'en' ? '' : lang %>/';
  };
  fetch('/api/packages/mine', { headers: { 'Authorization': 'Bearer ' + token } })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var list = document.getElementById('packageList');
      var none = document.getElementById('noPackages');
      if (!data.ok || !data.packages || data.packages.length === 0) {
        none.classList.remove('hidden');
        return;
      }
      data.packages.forEach(function(pkg) {
        var statusColor = { pending: 'text-amber-500', approved: 'text-green-600', rejected: 'text-red-500' };
        var div = document.createElement('div');
        div.className = 'bg-white rounded-2xl border border-gray-200 p-5';
        div.innerHTML = '<div class="flex items-start justify-between"><div><h3 class="font-bold text-gray-800">' + pkg.name + '</h3><p class="text-sm text-gray-500 mt-1">' + (pkg.description || '') + '</p></div><div class="text-right"><div class="text-sm font-semibold ' + (statusColor[pkg.status] || 'text-gray-400') + '">' + pkg.status + '</div><div class="text-xs text-gray-400 mt-1">v' + pkg.version + '</div></div></div>' + (pkg.reviewNotes ? '<div class="mt-2 text-sm text-red-500 bg-red-50 rounded-lg px-3 py-2">Notas da revisão: ' + pkg.reviewNotes + '</div>' : '') + '<div class="mt-3 text-xs text-gray-400">Enviado ' + new Date(pkg.createdAt).toLocaleDateString() + ' | ' + (pkg.downloads || 0) + ' downloads</div></div>';
        list.appendChild(div);
      });
    });
})();
</script>

<%- include('../../partials/footer', { lang, t }) %>
