<%- include('../../partials/head', { lang, t, alternates }) %>
<%- include('../../partials/navbar', { lang, t }) %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css">

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-4xl mx-auto">
    <a href="/<%= lang %>/packages" class="text-sm text-gray-400 hover:text-pinky-400 no-underline">&larr; <%= t('packages.title') %></a>

    <div class="mt-6 bg-white rounded-2xl border border-gray-200 overflow-hidden">
      <div class="p-8 pb-6">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="min-w-0">
            <h1 class="text-3xl font-black text-gray-800 break-all"><%= pkg.name %></h1>
            <p class="text-gray-500 mt-2 text-lg"><%= pkg.description %></p>
          </div>
          <div class="text-right text-sm text-gray-400 shrink-0">
            <div class="text-2xl font-black text-gray-800">v<%= pkg.version %></div>
            <div class="mt-1"><%= pkg.downloads?.toLocaleString() || 0 %> <%= t('packages.downloads') %></div>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-2 mt-4">
          <% if (pkg.license) { %><span class="text-xs bg-gray-100 text-gray-500 px-2.5 py-1 rounded font-medium"><%= t('packages.license') %>: <%= pkg.license %></span><% } %>
          <% if (pkg.author) { %><span class="text-xs text-gray-400">by <span class="font-medium text-gray-600"><%= pkg.author %></span></span><% } %>
          <span class="text-xs text-gray-400"><%= t('packages.updated') %>: <%= new Date(pkg.updatedAt).toLocaleDateString() %></span>
        </div>

        <% if (pkg.keywords && pkg.keywords.length > 0) { %>
        <div class="flex flex-wrap gap-1.5 mt-3">
          <% pkg.keywords.forEach(function(kw) { %>
          <span class="text-xs bg-pinky-50 text-pinky-500 px-2 py-0.5 rounded"><%= kw %></span>
          <% }) %>
        </div>
        <% } %>

        <% if (pkg.repository) { %>
        <div class="mt-3">
          <a href="<%= pkg.repository %>" target="_blank" class="text-sm text-pinky-400 hover:underline inline-flex items-center gap-1">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            <%= pkg.repository %>
          </a>
        </div>
        <% } %>

        <div class="mt-6 flex gap-3 flex-wrap">
          <button onclick="navigator.clipboard.writeText('xs install <%= pkg.name %>')" class="bg-pinky-400 hover:bg-pinky-500 text-white px-5 py-2.5 rounded-lg font-semibold text-sm transition-all inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            xs install <%= pkg.name %>
          </button>
        </div>
      </div>

      <% if (pkg.readmeSanitized) { %>
      <div class="border-t border-gray-100 px-8 py-6">
        <h2 class="text-lg font-bold text-gray-800 mb-4">README</h2>
        <div class="prose prose-sm max-w-none text-gray-600">
          <%- pkg.readmeSanitized %>
        </div>
      </div>
      <% } %>

      <div class="border-t border-gray-100 px-8 py-6">
        <h2 class="text-lg font-bold text-gray-800 mb-4"><%= t('packages.sourceFiles') %></h2>
        <div id="sourceFiles">
          <p class="text-gray-400 text-sm"><%= t('packages.loadingFiles') %></p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
(async function() {
  try {
    const res = await fetch('/api/packages/<%= pkg.name %>/source');
    const data = await res.json();
    if (data.ok && data.files && data.files.length > 0) {
      const container = document.getElementById('sourceFiles');
      container.innerHTML = '';
      data.files.forEach(function(file, i) {
        const ext = file.path.split('.').pop();
        const langClass = (ext === 'xs' || ext === 'js' || ext === 'json' || ext === 'md') ? 'language-' + ext : '';
        const div = document.createElement('div');
        div.className = 'mb-4 border border-gray-200 rounded-xl overflow-hidden';
        div.innerHTML = '<div class="flex items-center justify-between px-4 py-2 bg-gray-50 border-b border-gray-200">'
          + '<span class="text-xs font-mono text-gray-500 truncate">' + escapeHtml(file.path) + '</span>'
          + '<span class="text-xs text-gray-400">' + formatSize(file.content.length) + '</span>'
          + '</div>'
          + '<pre class="p-4 text-xs leading-relaxed font-mono text-gray-700 bg-white overflow-x-auto max-h-96 scrollbar-thin"><code class="' + langClass + '">' + escapeHtml(file.content) + '</code></pre>';
        container.appendChild(div);
      });
    }
  } catch (e) {
    document.getElementById('sourceFiles').innerHTML = '<p class="text-gray-400 text-sm">Source files unavailable.</p>';
  }

  function escapeHtml(str) {
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function formatSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / 1048576).toFixed(1) + ' MB';
  }
})();
</script>

<%- include('../../partials/footer', { lang, t }) %>
