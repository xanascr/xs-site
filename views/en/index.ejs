<%- include('../partials/head', { lang, t, alternates }) %>

<%- include('../partials/navbar', { lang, t }) %>

<!-- Hero + Playground -->
<section class="min-h-[100dvh] pt-20 sm:pt-24 pb-10 sm:pb-16 px-4 sm:px-6 bg-gradient-to-b from-pinky-50 to-white relative overflow-hidden">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-6 sm:mb-8 animate-fade-in">
      <h1 class="text-3xl sm:text-5xl md:text-7xl font-black leading-tight mb-3 sm:mb-4">
        XanaScript <span class="text-pinky-400">Playground</span>
      </h1>
      <p class="text-base sm:text-lg md:text-xl text-gray-500 max-w-2xl mx-auto px-2 font-light"><%= t('hero.subtitle') %></p>
    </div>

    <div class="flex flex-col lg:flex-row gap-4 sm:gap-6 animate-slide-up" style="height: min(calc(100dvh - 18rem), 640px); min-height: 300px;">
      <div class="flex-1 min-h-[200px] lg:min-h-0 rounded-2xl overflow-hidden shadow-2xl border border-gray-200 bg-white flex flex-col">
        <div class="flex items-center gap-1.5 px-3 sm:px-4 py-2.5 sm:py-3 bg-gray-100 border-b border-gray-200">
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-red-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-yellow-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-green-400"></div>
          <span class="text-gray-500 text-xs sm:text-sm ml-2 sm:ml-3 font-medium">app.xs</span>
          <div class="ml-auto flex gap-1 sm:gap-2">
            <button id="runBtn" class="bg-pinky-400 hover:bg-pinky-500 text-white px-4 sm:px-5 py-1.5 rounded-lg text-xs sm:text-sm font-semibold transition-all shadow-md shadow-pinky-200 active:scale-95"><%= t('playground.run') %></button>
          </div>
        </div>
        <div id="examplesBar" class="flex items-center gap-1.5 px-3 sm:px-4 py-1.5 bg-gray-50 border-b border-gray-200 overflow-x-auto"></div>
        <textarea id="codeEditor" name="codeEditor" spellcheck="false">CRIA nome = "XanaScript"
CRIA idade = 25

CHAMA ESSE CARA saudacao(nome, idade) {
  VOLTA "Ola, " + nome + "! Tenho " + idade + " anos."
}

SOLTA O GRITO(saudacao(nome, idade))

CRIA soma = 0
REPETE NA MORAL (CRIA i = 1; i <= 10; i += 1) {
  soma = soma + i
}

SOLTA O GRITO("Soma de 1 a 10: " + soma)</textarea>
        <div id="editorContainer"></div>
      </div>

      <div class="flex-1 min-h-[200px] lg:min-h-0 rounded-2xl overflow-hidden shadow-2xl border border-gray-200 bg-white flex flex-col">
        <div class="flex items-center gap-1.5 px-3 sm:px-4 py-2.5 sm:py-3 bg-gray-100 border-b border-gray-200">
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-red-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-yellow-400"></div>
          <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-green-400"></div>
          <span class="text-gray-500 text-xs sm:text-sm ml-2 sm:ml-3 font-medium">Output</span>
          <button id="clearBtn" class="ml-auto text-xs text-gray-400 hover:text-gray-600 transition-colors"><%= t('playground.clear') %></button>
        </div>
        <pre id="output" class="flex-1 min-h-[160px] m-0 bg-white text-gray-700 p-4 sm:p-5 font-mono text-xs sm:text-sm overflow-auto leading-relaxed whitespace-pre-wrap border-t border-gray-100"><%= t('playground.ready') %></pre>
      </div>
    </div>

    <div class="text-center mt-4 sm:mt-6 text-xs sm:text-sm text-gray-400">
      <span><%= t('playground.cli') %> </span><a href="#install" class="text-pinky-400 hover:underline font-medium"><%= t('playground.cliLink') %></a>
    </div>
  </div>
</section>

<!-- Installation -->
<section id="install" class="py-14 sm:py-20 px-4 sm:px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-center mb-3 sm:mb-4"><%= t('install.title') %></h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-8 sm:mb-12 text-base sm:text-lg font-light"><%= t('install.subtitle') %></p>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-pinky-50 rounded-2xl p-8 border border-pinky-100">
        <h3 class="text-xl font-bold mb-3"><%= t('install.npm.title') %></h3>
        <p class="text-gray-500 text-sm mb-4"><%= t('install.npm.desc') %></p>
        <div class="code-block bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">Bash</div>
          <pre class="p-4">npm install -g xanascript</pre>
        </div>
      </div>
      <div class="bg-pinky-50 rounded-2xl p-8 border border-pinky-100">
        <h3 class="text-xl font-bold mb-3"><%= t('install.binary.title') %></h3>
        <p class="text-gray-500 text-sm mb-4"><%= t('install.binary.desc') %></p>
        <div onclick="copyCmd(this)" class="inline-flex items-center gap-2 bg-white border border-gray-200 rounded-xl px-4 py-2.5 font-mono text-sm text-gray-500 cursor-pointer transition-all hover:border-pinky-400 select-none">
          <span class="text-pinky-400">$</span>
          <span class="text-gray-800">curl -fsSL https://xanascript.xyz/install.sh | bash</span>
        </div>
        <div onclick="copyCmd(this)" class="mt-2 inline-flex items-center gap-2 bg-white border border-gray-200 rounded-xl px-4 py-2.5 font-mono text-sm text-gray-500 cursor-pointer transition-all hover:border-pinky-400 select-none">
          <span class="text-pinky-400">$</span>
          <span class="text-gray-800">xs --version</span>
        </div>
        <% if (typeof npmDownloads !== 'undefined' && npmDownloads !== null) { %>
        <div class="mt-3 text-xs text-gray-400">
          <span class="inline-flex items-center gap-1"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a.5.5 0 0 1 .5.5v11.793l3.146-3.147a.5.5 0 0 1 .708.708l-4 4a.5.5 0 0 1-.708 0l-4-4a.5.5 0 0 1 .708-.708L7.5 13.293V1.5A.5.5 0 0 1 8 1z"/></svg> <%= npmDownloads.toLocaleString() %> downloads this month</span>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<!-- Syntax -->
<section id="syntax" class="py-20 px-6 bg-pinky-50/50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-4">Complete Syntax</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light">Every keyword is clear Portuguese. The code explains itself.</p>
    <div class="grid md:grid-cols-2 gap-6">
      <div>
        <h4 class="font-semibold mb-3 text-gray-700">Variables & Functions</h4>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4"><span class="kw">CRIA</span> nome = <span class="str">"XanaScript"</span>
<span class="kw">CRIA</span> idade = <span class="num">5</span>

<span class="kw">CHAMA ESSE CARA</span> <span class="fn">saudacao</span>(nome, idade) {
  <span class="kw">VOLTA</span> <span class="str">"Ola, "</span> + nome + <span class="str">"! Tenho "</span> + idade + <span class="str">" anos."</span>
}</pre>
        </div>

        <h4 class="font-semibold mb-3 mt-6 text-gray-700">Conditionals & Loops</h4>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4"><span class="kw">SE LIGA SO</span> (idade >= <span class="num">18</span>) {
  <span class="kw">SOLTA O GRITO</span>(<span class="str">"Maior de idade"</span>)
} <span class="kw">SENAO</span> {
  <span class="kw">SOLTA O GRITO</span>(<span class="str">"Menor de idade"</span>)
}

<span class="kw">REPETE NA MORAL</span> (<span class="kw">CRIA</span> i = <span class="num">0</span>; i < <span class="num">5</span>; i++) {
  <span class="kw">SOLTA O GRITO</span>(i)
}

<span class="kw">REPETE AI</span> (condicao) {
  <span class="cm">// while loop</span>
}</pre>
        </div>
      </div>
      <div>
        <h4 class="font-semibold mb-3 text-gray-700">Classes & OOP</h4>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4"><span class="kw">CLASSE</span> <span class="fn">Animal</span> {
  <span class="kw">CONSTRUTOR</span>(nome) {
    <span class="kw">CRIA ISTO</span>.nome = nome
  }
  <span class="kw">METODO</span> falar() {
    <span class="kw">SOLTA O GRITO</span>(<span class="kw">ISTO</span>.nome + <span class="str">" faz barulho"</span>)
  }
}

<span class="kw">CLASSE</span> <span class="fn">Cachorro</span> <span class="kw">HERDA</span> Animal {
  <span class="kw">METODO</span> falar() {
    <span class="kw">SOLTA O GRITO</span>(<span class="kw">ISTO</span>.nome + <span class="str">" diz: Au Au!"</span>)
  }
}

<span class="kw">CRIA</span> rex = <span class="kw">NOVA</span> Cachorro(<span class="str">"Rex"</span>)
rex.falar()</pre>
        </div>

        <h4 class="font-semibold mb-3 mt-6 text-gray-700">Pattern Matching & More</h4>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4"><span class="kw">CRIA</span> resultado = <span class="kw">COMBINA</span> (valor) {
  <span class="kw">CASO</span> <span class="num">0</span> =&gt; <span class="str">"zero"</span>
  <span class="kw">CASO</span> <span class="num">1</span> =&gt; <span class="str">"um"</span>
  <span class="kw">CASO</span> _ =&gt; <span class="str">"outro"</span>
}

<span class="cm">// Template strings</span>
<span class="kw">SOLTA O GRITO</span>(`Ola, <span class="str">${nome}</span>!`)

<span class="cm">// Arrow functions</span>
<span class="kw">CRIA</span> quadrado = (x) =&gt; x * x

<span class="cm">// Async/Await</span>
<span class="kw">CRIA</span> data = <span class="kw">ESPERA AI</span> <span class="kw">AGORA VAI</span>(url)

<span class="cm">// Regex</span>
<span class="str">"hello"</span> ~= <span class="str">"^h.*o$"</span></pre>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Features -->
<section id="features" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-4">Why XanaScript?</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light">A language designed from the ground up with a full compiler toolchain, not a transpiler or wrapper.</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Portuguese Syntax</h3>
        <p class="text-gray-500 text-sm">Multi-word keywords (<code>SE LIGA SO</code>, <code>CHAMA ESSE CARA</code>, <code>REPETE NA MORAL</code>) are lexed as atomic tokens via lookahead DFA. No translation layer — the grammar itself is Portuguese.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Optimizing JS Codegen</h3>
        <p class="text-gray-500 text-sm">Multi-pass optimizer: constant folding, loop unrolling (up to 8 iterations), integer type inference for automatic <code>Int32Array</code>/<code>Float64Array</code> usage, and function inlining.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Native WebAssembly</h3>
        <p class="text-gray-500 text-sm">Direct <code>.wasm</code> binary emission — no Emscripten, no wabt.js, no LLVM. Implements Section Type/Function/Code/Export/Data manually with a bundled linker that resolves function indices and label offsets.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Built-in ORM</h3>
        <p class="text-gray-500 text-sm"><code>TABELA</code> is a first-class syntax construct parsed into AST nodes. The codegen emits complete CRUD functions (<code>inserir</code>, <code>buscar</code>, <code>atualizar</code>, <code>remover</code>) with filter support (<code>$gt</code>, <code>$lt</code>, <code>$eq</code>) and JSON persistence.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Compile-Time Macros</h3>
        <p class="text-gray-500 text-sm"><code>MACRO</code> definitions are stored in the symbol table and expanded during AST traversal before codegen. Supports recursive expansion with configurable depth limits. Zero runtime footprint.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Native Test Runner</h3>
        <p class="text-gray-500 text-sm"><code>TESTE</code> and <code>AFIRMA</code> are parsed as AST statements and executed by the interpreter. Auto-discovers test files, outputs TAP-compatible results, and exits with CI-ready codes.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">LSP Server</h3>
        <p class="text-gray-500 text-sm">Language Server Protocol over stdio. Stateless architecture: each request re-parses the document from scratch. Supports completions, hover docs, go-to-definition, real-time diagnostics, and formatting.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Package Manager</h3>
        <p class="text-gray-500 text-sm"><code>xs install</code> resolves packages from GitHub repositories with semver compatibility. <code>xs publish</code> creates a registry entry. npm fallback for JS interop.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Rust-Style Errors</h3>
        <p class="text-gray-500 text-sm">Each error includes a unique code, exact source location with arrow annotation, and structured hint/help messages. The parser implements panic-mode error recovery to report multiple errors per run.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">VS Code Extension</h3>
        <p class="text-gray-500 text-sm">Uses <code>vscode-xs</code> with TextMate grammars for syntax highlighting, 18 code snippets, and LSP client integration. Commands for run, build, test, and format.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Complete CLI</h3>
        <p class="text-gray-500 text-sm">20+ subcommands: <code>run</code>, <code>build</code> (JS/Wasm), <code>test</code>, <code>repl</code>, <code>format</code>, <code>docs</code>, <code>lsp</code>, <code>init</code>, <code>install</code>, <code>publish</code>, <code>watch</code>, <code>benchmark</code>. Single binary via <code>bun --compile</code>, zero runtime deps.</p>
      </div>
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md transition-all hover:border-pinky-400 hover:-translate-y-1 hover:shadow-lg">
        <h3 class="font-bold text-lg mb-2">Task Runner</h3>
        <p class="text-gray-500 text-sm"><code>TAREFA</code> declarations in <code>tarefas.xs</code> define named tasks parsed into AST. Executed via <code>xs &lt;taskname&gt;</code> with dependency resolution.</p>
      </div>
    </div>
  </div>
</section>

<!-- Wasm -->
<section id="wasm" class="py-20 px-6 bg-pinky-50/50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-4">Native WebAssembly</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light">Direct <code>.wasm</code> emission — no Emscripten, no wabt.js, no LLVM toolchain.</p>
    <div class="grid md:grid-cols-2 gap-8">
      <div>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4"><span class="kw">CHAMA ESSE CARA</span> <span class="fn">sum</span>(a, b) {
  <span class="kw">VOLTA</span> a + b
}
<span class="kw">CHAMA ESSE CARA</span> <span class="fn">main</span>() {
  <span class="kw">VOLTA</span> sum(<span class="num">10</span>, <span class="num">20</span>)
}</pre>
        </div>
        <div onclick="copyCmd(this)" class="mt-3 inline-flex items-center gap-2 bg-gray-50 border border-gray-200 rounded-xl px-4 py-2.5 font-mono text-sm text-gray-500 cursor-pointer transition-all hover:border-pinky-400 select-none">
          <span class="text-pinky-400">$</span>
          <span class="text-gray-800">xs build --wasm math.xs</span>
        </div>
      </div>
      <div>
        <p class="text-gray-600 mb-4"><strong class="text-gray-800">wasm_binary.js</strong> implements the Wasm binary format specification from scratch:</p>
        <ul class="list-disc list-inside text-gray-600 space-y-1.5 mb-4">
          <li>Magic number (<code>00 61 73 6d</code>) + version (<code>01 00 00 00</code>)</li>
          <li>Section encoding: Type Section (function signatures), Function Section (type index mapping), Code Section (function bodies with local declarations), Export Section (named exports), Data Section (initial memory contents)</li>
          <li>All integers encoded via LEB128 (unsigned and signed variants)</li>
          <li>Two-value type system: <code>i32</code> and <code>f64</code> — all XS arithmetic operations map to the appropriate opcode</li>
        </ul>
        <p class="text-gray-600 mb-4">The internal <strong class="text-gray-800">linker</strong> resolves function indices between sections during a second pass. After codegen, it patches label offsets for branch instructions (<code>br</code>, <code>br_if</code>, <code>block</code>, <code>loop</code>). The linker also handles export name string table encoding.</p>
        <p class="text-gray-600 mb-4">Memory allocation uses a bundled bump allocator — <code>CRIA VETOR</code> with compile-time known sizes emits <code>memory.grow</code> + pointer arithmetic. Strings are stored as (length, data) pairs at the allocated offset.</p>
        <div class="grid grid-cols-2 gap-2">
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">i32 / f64</code><span class="text-gray-400 text-xs">Value types</span></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">block / loop</code><span class="text-gray-400 text-xs">Control flow</span></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">call / return</code><span class="text-gray-400 text-xs">Functions</span></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">memory.grow</code><span class="text-gray-400 text-xs">Dynamic alloc</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ORM -->
<section id="orm" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-4">Built-in ORM</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light">Tables as a first-class AST node — parsed, type-checked, and codegen'd in the compiler pipeline.</p>
    <div class="grid md:grid-cols-2 gap-8">
      <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
        <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
        <pre class="p-4"><span class="kw">TABELA</span> <span class="fn">Product</span> {
  name: <span class="typ">TEXTO</span>,
  price: <span class="typ">NUMERO</span>,
  stock: <span class="typ">NUMERO</span>
}

<span class="kw">CRIA</span> repo = Product
repo.create({ name: <span class="str">"Keyboard"</span>, price: <span class="num">250</span>, stock: <span class="num">10</span> })
repo.create({ name: <span class="str">"Mouse"</span>, price: <span class="num">120</span>, stock: <span class="num">25</span> })

<span class="kw">SOLTA O GRITO</span>(repo.list())
<span class="kw">CRIA</span> expensive = repo.findWhere({ price: <span class="num">250</span> })
repo.update(<span class="num">1</span>, { name: <span class="str">"RGB Keyboard"</span> })
repo.delete(<span class="num">2</span>)</pre>
      </div>
      <div>
        <p class="text-gray-600 mb-4"><code>TABELA</code> is parsed as a <code>TableDef</code> AST node containing a name and typed field list. The parser validates that field types are one of the five supported: <code>TEXTO</code>, <code>NUMERO</code>, <code>BOOLEANO</code>, <code>DATA</code>, <code>QUALQUER</code>. Invalid types produce a compile-time error with source annotation.</p>
        <p class="text-gray-600 mb-4">On the codegen side, <code>TableDef</code> emits a constructor function that returns an object with the CRUD methods. The runtime stores data as JSON files on disk (Node/Bun) or in-memory (browser). Each record gets an auto-incrementing <code>_id</code> field plus <code>_criado</code> and <code>_atualizado</code> timestamps.</p>
        <p class="text-gray-600 mb-4">The <code>findWhere</code> method supports filter operators passed as keys prefixed with <code>$</code>: <code>$eq</code>, <code>$gt</code>, <code>$lt</code>, <code>$gte</code>, <code>$lte</code>, <code>$ne</code>, and <code>$in</code> (array match). Compound filters use implicit AND semantics.</p>
        <div class="grid grid-cols-2 gap-2">
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">TEXTO</code><span class="text-gray-400 text-xs">string</span></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">NUMERO</code><span class="text-gray-400 text-xs">number</span></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">BOOLEANO</code><span class="text-gray-400 text-xs">boolean</span></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">DATA</code><span class="text-gray-400 text-xs">ISO string</span></div>
          <div class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2.5 text-sm"><code class="text-pinky-500 font-mono text-xs">QUALQUER</code><span class="text-gray-400 text-xs">any</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Macros -->
<section id="macros" class="py-20 px-6 bg-pinky-50/50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-4">Compile-Time Macros</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light">AST-level substitution — expanded during the optimization phase, erased before codegen.</p>
    <div class="grid md:grid-cols-2 gap-8">
      <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
        <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
        <pre class="p-4"><span class="kw">MACRO</span> <span class="fn">square</span>(x) { x * x }
<span class="kw">MACRO</span> <span class="fn">cube</span>(x) { x * square(x) }
<span class="kw">MACRO</span> <span class="fn">max</span>(a, b) {
  <span class="kw">SE LIGA SO</span> (a > b) { a } <span class="kw">SENAO</span> { b }
}
<span class="kw">CRIA</span> r1 = square(<span class="num">5</span>)
<span class="kw">CRIA</span> r2 = cube(<span class="num">3</span>)
<span class="kw">CRIA</span> r3 = max(<span class="num">10</span>, <span class="num">20</span>)
<span class="kw">CRIA</span> r4 = max(square(<span class="num">4</span>), cube(<span class="num">2</span>))</pre>
      </div>
      <div>
        <p class="text-gray-600 mb-4">Macros are parsed into <code>MacroDef</code> AST nodes with a parameter list and body. During the optimization phase, the macro expander walks the AST and replaces each <code>CallExpr</code> matching a macro name with the macro's body AST, substituting parameter identifiers with the argument expressions via a shallow copy.</p>
        <p class="text-gray-600 mb-4">Expansion is <strong>recursive</strong>: if a macro body contains calls to other macros, those are expanded in a post-substitution pass. The expander tracks a depth counter (default limit: 64) to prevent infinite recursion from circular macro references. After full expansion, all <code>MacroDef</code> nodes are removed from the AST.</p>
        <p class="text-gray-600 mb-4">Because expansion operates on the AST rather than text (unlike C preprocessor <code>#define</code>), there is no risk of operator-precedence bugs or unintended token pasting. The resulting AST is then fed through the optimizer and codegen as if the macro bodies were written inline.</p>
      </div>
    </div>
  </div>
</section>

<!-- Tests -->
<section id="tests" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-4">Test Runner</h2>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light">First-class <code>TESTE</code> and <code>AFIRMA</code> AST nodes — parsed, interpreted, and reported by the compiler itself.</p>
    <div class="grid md:grid-cols-2 gap-8">
      <div>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">XS</div>
          <pre class="p-4"><span class="kw">TESTE</span> <span class="str">"sum of two numbers"</span> {
  <span class="kw">CRIA</span> r = <span class="num">2</span> + <span class="num">3</span>
  <span class="kw">AFIRMA</span>(r == <span class="num">5</span>)
  <span class="kw">ASSUNTO</span>(r, <span class="num">5</span>)
}
<span class="kw">TESTE</span> <span class="str">"multiplication"</span> {
  <span class="kw">CRIA</span> r = <span class="num">3</span> * <span class="num">4</span>
  <span class="kw">ASSUNTO</span>(r, <span class="num">12</span>)
}</pre>
        </div>
        <div onclick="copyCmd(this)" class="mt-3 inline-flex items-center gap-2 bg-gray-50 border border-gray-200 rounded-xl px-4 py-2.5 font-mono text-sm text-gray-500 cursor-pointer transition-all hover:border-pinky-400 select-none">
          <span class="text-pinky-400">$</span>
          <span class="text-gray-800">xs test .</span>
        </div>
      </div>
      <div>
        <p class="text-gray-600 mb-4"><code>TESTE</code> blocks are parsed into <code>TestStmt</code> AST nodes containing an expression (the description) and a statement block. <code>AFIRMA</code> and <code>ASSUNTO</code> are parsed as <code>AssertStmt</code> nodes — the former takes a single boolean expression, the latter takes an actual/expected pair with structural comparison.</p>
        <p class="text-gray-600 mb-4">The test runner discovers files by glob pattern (<code>**/*.test.xs</code>) and executes them through the AST interpreter. Each <code>TestStmt</code> is wrapped in a try-catch: assertion failures throw structured <code>AssertionError</code> objects with file/line/diff info. The runner aggregates results and outputs TAP-compatible format with colored pass/fail indicators, execution time per test, and a summary line.</p>
        <p class="text-gray-600 mb-4">Exit code 1 on any failure — CI/CD ready. The <code>xs test --watch</code> flag re-runs on file changes using the built-in file watcher.</p>
        <div class="code-block bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-2 border-b border-gray-100 text-xs text-gray-400 uppercase tracking-wider font-semibold">Output</div>
          <pre class="p-4 text-green-600">  PASS  sum of two numbers (2ms)
  PASS  multiplication (1ms)

  Tests: 2 passed, 2 total</pre>
        </div>
      </div>
    </div>
  </div>
</section>

