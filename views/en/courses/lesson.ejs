<%- include('../../partials/head', { lang, t, alternates }) %>
<%- include('../../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-4xl mx-auto">
    <a href="/<%= lang %>/courses/<%= course.slug %>" class="text-sm text-gray-400 hover:text-pinky-400 no-underline mb-4 inline-block">&larr; Back to course</a>

    <div class="xs-card xs-card-glass animate-fade-in">
      <div class="p-6 sm:p-8">
        <div class="flex items-center justify-between mb-6">
          <div>
            <span class="text-xs text-gray-400 uppercase tracking-wider font-semibold">Lesson <%= (course.lessons || []).findIndex(function(l) { return l.slug === lesson.slug }) + 1 %> of <%= (course.lessons || []).length %></span>
            <h1 class="text-2xl sm:text-3xl font-black mt-1"><%= lesson.title %></h1>
          </div>
          <span class="xs-tag xs-tag-primary"><%= lesson.points || 0 %> pts</span>
        </div>

        <div class="lesson-prose mb-8">
          <%- lessonHtml %>
        </div>

        <div id="challengesArea">
          <% if (lesson.challenges && lesson.challenges.length > 0) { %>
            <div class="border-t border-gray-200 pt-6 mt-8">
              <h2 class="text-xl font-bold mb-4">Challenges</h2>
              <div id="challenges" class="space-y-4">
                <% lesson.challenges.forEach(function(ch, i) { %>
                  <% var isDisabled = enrollment && enrollment.progress && enrollment.progress.find(function(p) { return p.lessonSlug === lesson.slug && p.completed }) %>
                  <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
                    <p class="font-semibold text-sm text-gray-800 mb-2">Challenge <%= i + 1 %>: <%= ch.question %></p>
                    <div class="flex items-center gap-2">
                      <input type="text" class="challenge-input xs-input w-full" data-idx="<%= i %>" data-answer="<%= ch.answer.replace(/"/g, '&quot;') %>" placeholder="Type your answer..." <%= isCompleted ? 'disabled' : '' %>>
                      <span class="challenge-result text-sm font-semibold w-20 text-center"></span>
                    </div>
                    <div class="challenge-feedback text-xs mt-1 hidden"></div>
                  </div>
                <% }) %>
              </div>
              <button id="checkAnswersBtn" class="xs-btn xs-btn-ghost mt-4">Check Answers</button>
            </div>
          <% } %>
        </div>

        <div class="flex items-center justify-between mt-8 pt-6 border-t border-gray-200">
          <div id="lessonStatus">
            <% if (enrollment && enrollment.progress && enrollment.progress.find(function(p) { return p.lessonSlug === lesson.slug && p.completed })) { %>
              <span class="inline-flex items-center gap-1.5 text-sm text-green-600 font-semibold"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Completed</span>
            <% } else if (enrollment) { %>
              <button id="completeBtn" class="xs-btn xs-btn-primary">Mark as Completed</button>
            <% } else { %>
              <a href="/<%= lang %>/login?redirect=/<%= lang %>/courses/<%= course.slug %>/lessons/<%= lesson.slug %>" class="xs-btn xs-btn-primary">Log in to track progress</a>
            <% } %>
          </div>
          <span id="earnedPoints" class="text-sm text-gray-400"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  var token = localStorage.getItem('xs_token');
  if (!token) return;

  // ── Complete button ─────────────────────────────────────────────────
  var completeBtn = document.getElementById('completeBtn');
  if (completeBtn) {
    completeBtn.addEventListener('click', function() {
      var answers = [];
      document.querySelectorAll('.challenge-input').forEach(function(inp) {
        answers.push(inp.value);
      });
      completeBtn.disabled = true;
      completeBtn.textContent = 'Saving...';
      fetch('/api/courses/<%= course.slug %>/lessons/<%= lesson.slug %>/complete', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
        body: JSON.stringify({ answers: answers })
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.ok) { window.location.reload(); }
        else { alert(d.error || 'Failed'); completeBtn.disabled = false; completeBtn.textContent = 'Mark as Completed'; }
      })
      .catch(function() { alert('Network error.'); completeBtn.disabled = false; completeBtn.textContent = 'Mark as Completed'; });
    });
  }

  // ── Check answers ───────────────────────────────────────────────────
  var checkBtn = document.getElementById('checkAnswersBtn');
  if (!checkBtn) return;

  checkBtn.addEventListener('click', function() {
    document.querySelectorAll('.challenge-input').forEach(function(inp) {
      var correctAnswer = inp.getAttribute('data-answer');
      var userAnswer = inp.value.trim().toLowerCase();
      var correctLow = (correctAnswer || '').trim().toLowerCase();
      var isCorrect = correctAnswer && userAnswer === correctLow;
      var resultSpan = inp.parentElement.querySelector('.challenge-result');
      var fb = inp.parentElement.parentElement.querySelector('.challenge-feedback');

      if (isCorrect) {
        inp.classList.remove('border-red-300');
        inp.classList.add('border-green-300', 'bg-green-50');
        if (resultSpan) { resultSpan.textContent = '✓ Correct'; resultSpan.className = 'challenge-result text-sm font-semibold w-20 text-center text-green-600'; }
        if (fb) { fb.textContent = ''; fb.classList.add('hidden'); }
      } else {
        inp.classList.remove('border-green-300', 'bg-green-50');
        inp.classList.add('border-red-300');
        if (resultSpan) { resultSpan.textContent = '✗ Wrong'; resultSpan.className = 'challenge-result text-sm font-semibold w-20 text-center text-red-500'; }
        if (fb) {
          fb.textContent = 'Answer starts with: ' + (correctAnswer ? correctAnswer.substring(0, 3) + '...' : '');
          fb.classList.remove('hidden', 'text-green-600');
          fb.classList.add('text-red-500');
        }
      }
    });
  });
})();
</script>

<%- include('../../partials/footer', { lang, t }) %>