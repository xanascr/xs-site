<%- include('../partials/head', { lang, t, alternates }) %>
<%- include('../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-6xl mx-auto">
    <h1 class="text-4xl md:text-5xl font-black text-center mb-3"><%= t('examples.title') %></h1>
    <p class="text-center text-gray-400 max-w-xl mx-auto mb-12 text-lg font-light"><%= t('examples.subtitle') %></p>

    <div class="grid gap-6 grid-cols-1 md:grid-cols-2">
      <% examples.forEach(function(ex) { %>
      <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 flex flex-col">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
          <h3 class="font-bold text-lg text-gray-800 truncate"><%= ex.title %></h3>
          <span class="text-xs font-mono text-gray-400 bg-gray-100 px-2 py-1 rounded shrink-0 ml-2"><%= ex.lang %></span>
        </div>
        <div class="p-6 flex flex-col gap-4 flex-1">
          <p class="text-gray-500 text-sm leading-relaxed"><%= ex.desc %></p>
          <div class="code-block bg-gray-900 rounded-xl border border-gray-700 overflow-hidden mt-auto">
            <pre class="p-4 text-xs sm:text-sm overflow-x-auto scrollbar-thin text-gray-100 leading-relaxed highlight-xs"><%= ex.code %></pre>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<script>
(function() {
  function highlightXsCode() {
    var blocks = document.querySelectorAll('.highlight-xs');
    blocks.forEach(function(block) {
      var html = block.innerHTML;
      html = html.replace(/(CRIA\b|CHAMA ESSE CARA\b|SE LIGA SO\b|SENAO\b|REPETE NA MORAL\b|REPETE AI\b|ENQUANTO\b|PARE\b|VOLTA\b|SOLTA O GRITO\b|FUNCAO\b|CLASSE\b|HERDA\b|CONSTRUTOR\b|METODO\b|NOVA\b|ISTO\b|COMBINA\b|CASO\b|TABELA\b|ESPERA AI\b|AGORA VAI\b|TAREFA\b|TESTE\b|AFIRMA\b|MACRO\b|PARTIU\b|ACABOU\b|VERDADEIRO\b|FALSO\b|NULO\b)/g, '<span class="xs-kw">$1</span>');
      html = html.replace(/("(?:[^"\\]|\\.)*")/g, '<span class="xs-str">$1</span>');
      html = html.replace(/('(?:[^'\\]|\\.)*')/g, '<span class="xs-str">$1</span>');
      html = html.replace(/(`(?:[^`\\]|\\.)*`)/g, '<span class="xs-str">$1</span>');
      html = html.replace(/\b(\d+(?:\.\d+)?)\b/g, '<span class="xs-num">$1</span>');
      html = html.replace(/\/\/.*/g, '<span class="xs-cm">$&</span>');
      block.innerHTML = html;
    });
  }
  highlightXsCode();
})();
</script>

<style>
.xs-kw { color: #f58b8e; font-weight: 600; }
.xs-str { color: #34d399; }
.xs-num { color: #60a5fa; }
.xs-cm { color: #6b7280; font-style: italic; }
</style>

<%- include('../partials/footer', { lang, t }) %>
