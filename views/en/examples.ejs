<%- include('../partials/head', { lang, t, alternates }) %>
<%- include('../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-6xl mx-auto animate-fade-in">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-pinky-50 border border-pinky-100 text-pinky-500 text-xs font-semibold mb-4">Examples</div>
      <h1 class="text-4xl md:text-5xl font-black mb-2"><%= t('examples.title') %></h1>
      <p class="text-gray-400 max-w-xl mx-auto"><%= t('examples.subtitle') %></p>
    </div>

    <div class="grid gap-6 grid-cols-1 md:grid-cols-2">
      <% examples.forEach(function(ex) { %>
      <div class="xs-card overflow-hidden flex flex-col">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
          <h3 class="font-bold text-gray-800 truncate"><%= ex.title %></h3>
          <span class="text-xs font-mono text-white bg-pinky-400 px-2.5 py-1 rounded shrink-0 ml-2"><%= ex.lang %></span>
        </div>
        <div class="p-6 flex flex-col gap-4 flex-1">
          <p class="text-gray-500 text-sm leading-relaxed"><%= ex.desc %></p>
          <div class="relative mt-auto">
            <div class="flex items-center gap-1.5 px-4 py-2 bg-gray-100 rounded-t-xl border border-gray-200 border-b-0">
              <span class="w-3 h-3 rounded-full bg-red-400/80"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-400/80"></span>
              <span class="w-3 h-3 rounded-full bg-green-400/80"></span>
            </div>
            <pre class="p-4 text-xs sm:text-sm overflow-x-auto scrollbar-thin text-gray-700 leading-relaxed font-mono bg-white border border-gray-200 rounded-b-xl"><%= ex.code %></pre>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('../partials/footer', { lang, t }) %>
