<%- include('../partials/head', { lang, t, alternates }) %>
<%- include('../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen flex items-center justify-center">
  <div class="w-full max-w-sm animate-fade-in">
    <div class="text-center mb-8">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-pinky-50 border border-pinky-100 text-pinky-500 text-xs font-semibold mb-4">Comienza ya</div>
      <h1 class="text-3xl font-black">Crear Cuenta</h1>
    </div>

    <div class="xs-card p-6">
      <form id="signupForm" class="space-y-4">
        <input name="username" type="text" placeholder="Usuario (3-32 caracteres)" pattern="^[a-z0-9_-]{3,32}$" required class="xs-input">
        <input name="email" type="email" placeholder="Correo electrónico" required class="xs-input">
        <input name="password" type="password" placeholder="Contraseña (mín. 8 caracteres)" minlength="8" required class="xs-input">

        <div class="bg-pinky-50 border border-pinky-200 rounded-xl p-4 space-y-3">
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" name="privacyConsent" required class="mt-0.5 accent-pinky-400 w-4 h-4 shrink-0">
            <span class="text-xs text-gray-600 leading-relaxed">
              Acepto la <a href="/<%= lang %>/privacy" class="text-pinky-500 hover:underline font-semibold">Política de Privacidad</a> y consiento el tratamiento de mis datos personales según la <strong class="text-gray-700">LGPD</strong>.
            </span>
          </label>
          <p class="text-xs text-gray-400 ml-7 leading-relaxed">
            Tus datos se usan solo para autenticación y gestión de paquetes. Puedes solicitar exportación o eliminación de datos en cualquier momento.
          </p>
        </div>

        <div id="signupError" class="text-red-500 text-sm hidden"></div>
        <button type="submit" class="xs-btn xs-btn-primary w-full justify-center">Crear Cuenta</button>
      </form>
    </div>
    <p class="text-center text-sm text-gray-400 mt-6">¿Ya estás registrado? <a href="/<%= lang %>/login" class="text-pinky-400 hover:underline font-semibold">Iniciar sesión</a></p>
  </div>
</section>

<script>
document.getElementById('signupForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const errEl = document.getElementById('signupError');
  errEl.classList.add('hidden');
  try {
    const res = await fetch('/api/auth/signup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username: fd.get('username'), email: fd.get('email'), password: fd.get('password'), privacyConsent: fd.get('privacyConsent') === 'on' }),
    });
    const data = await res.json();
    if (!data.ok) { errEl.textContent = data.error; errEl.classList.remove('hidden'); return; }
    localStorage.setItem('xs_token', data.token);
    localStorage.setItem('xs_user', JSON.stringify(data.user));
    window.location.href = '/<%= lang %>/packages/dashboard';
  } catch (e) { errEl.textContent = 'Error de red'; errEl.classList.remove('hidden'); }
});
</script>

<%- include('../partials/footer', { lang, t }) %>
