      <div class="md:col-span-3 space-y-10 text-gray-600 leading-relaxed text-[15px]">
        <!-- Primeros Pasos -->
        <section id="install">
          <h2 class="text-2xl font-black text-gray-800 mb-3">Instalación</h2>
          <p class="mb-3">Instala globalmente a través de npm:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-4">npm install -g xanascript</pre>
          <p class="mb-3">Verifica la instalación:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-4">xs --help</pre>
          <p>Deberías ver una lista de todos los comandos disponibles.</p>
        </section>

        <section id="hello-world">
          <h2 class="text-2xl font-black text-gray-800 mb-3">Hola Mundo</h2>
          <p class="mb-3">Crea un archivo llamado <code>hello.xs</code>:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-3"><span class="text-gray-400">// hello.xs</span>
<span class="text-gray-400">// Hola Mundo en XanaScript</span>
<span class="kw">PARTIU</span>()
<span class="kw">SOLTA O GRITO</span>(<span class="str">"Hello, World!"</span>)
<span class="kw">ACABOU</span>()</pre>
          <p class="mb-3">Ejecútalo:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-4">xs run hello.xs</pre>
          <div class="bg-green-50 border border-green-200 rounded-xl px-4 py-3 text-sm text-green-700">
            <strong>Salida:</strong> <code>Hello, World!</code>
          </div>
        </section>

        <section id="cli-usage">
          <h2 class="text-2xl font-black text-gray-800 mb-3">Uso de la CLI</h2>
          <p class="mb-3">XanaScript proporciona una CLI completa con comandos para ejecutar, compilar, probar y empaquetar:</p>
          <div class="overflow-x-auto mb-4">
            <table class="w-full text-sm border border-gray-200 rounded-xl">
              <thead><tr><th class="text-left p-3 bg-gray-50 font-semibold">Comando</th><th class="text-left p-3 bg-gray-50 font-semibold">Descripción</th></tr></thead>
              <tbody>
                <tr><td class="p-3 border-t"><code>xs run file.xs</code></td><td class="p-3 border-t">Ejecutar un script (intérprete AST)</td></tr>
                <tr><td class="p-3 border-t"><code>xs vm file.xs</code></td><td class="p-3 border-t">Ejecutar a través de la máquina virtual de bytecode</td></tr>
                <tr><td class="p-3 border-t"><code>xs build file.xs</code></td><td class="p-3 border-t">Compilar a JavaScript</td></tr>
                <tr><td class="p-3 border-t"><code>xs build --opt file.xs</code></td><td class="p-3 border-t">Compilar con optimización completa</td></tr>
                <tr><td class="p-3 border-t"><code>xs build --wasm file.xs</code></td><td class="p-3 border-t">Compilar a binario WebAssembly</td></tr>
                <tr><td class="p-3 border-t"><code>xs build --standalone file.xs</code></td><td class="p-3 border-t">Generar archivo .js autónomo</td></tr>
                <tr><td class="p-3 border-t"><code>xs test [dir]</code></td><td class="p-3 border-t">Ejecutar archivos de prueba (*test*.xs)</td></tr>
                <tr><td class="p-3 border-t"><code>xs fmt file.xs</code></td><td class="p-3 border-t">Formatear código fuente</td></tr>
                <tr><td class="p-3 border-t"><code>xs check file.xs</code></td><td class="p-3 border-t">Solo verificar sintaxis</td></tr>
                <tr><td class="p-3 border-t"><code>xs repl</code></td><td class="p-3 border-t">Iniciar REPL interactivo</td></tr>
                <tr><td class="p-3 border-t"><code>xs dev [file]</code></td><td class="p-3 border-t">Modo observador con recarga en caliente</td></tr>
                <tr><td class="p-3 border-t"><code>xs lsp</code></td><td class="p-3 border-t">Iniciar servidor LSP (stdin/stdout)</td></tr>
                <tr><td class="p-3 border-t"><code>xs init [dir]</code></td><td class="p-3 border-t">Andamiar un nuevo proyecto</td></tr>
                <tr><td class="p-3 border-t"><code>xs install [pkg]</code></td><td class="p-3 border-t">Instalar un paquete</td></tr>
                <tr><td class="p-3 border-t"><code>xs publish</code></td><td class="p-3 border-t">Publicar en el registro</td></tr>
                <tr><td class="p-3 border-t"><code>xs search &lt;term&gt;</code></td><td class="p-3 border-t">Buscar paquetes</td></tr>
                <tr><td class="p-3 border-t"><code>xs login</code></td><td class="p-3 border-t">Autenticarse en el registro</td></tr>
                <tr><td class="p-3 border-t"><code>xs whoami</code></td><td class="p-3 border-t">Mostrar usuario actual</td></tr>
                <tr><td class="p-3 border-t"><code>xs logout</code></td><td class="p-3 border-t">Cerrar sesión del registro</td></tr>
                <tr><td class="p-3 border-t"><code>xs docs [src] [out]</code></td><td class="p-3 border-t">Generar documentación HTML</td></tr>
                <tr><td class="p-3 border-t"><code>xs bench</code></td><td class="p-3 border-t">Ejecutar pruebas de rendimiento</td></tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- Guía del Lenguaje -->
        <section id="variables">
          <h2 class="text-2xl font-black text-gray-800 mb-3">Variables</h2>
          <p class="mb-3">Usa <code>CRIA</code> para declarar variables. Los tipos se infieren del valor:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-4"><span class="kw">CRIA</span> nome = <span class="str">"XanaScript"</span>
<span class="kw">CRIA</span> ano = <span class="num">2026</span>
<span class="kw">CRIA</span> ativo = <span class="at">VERDADEIRO</span>
<span class="kw">CRIA</span> nada = <span class="at">NULO</span>

<span class="kw">CRIA</span> nums = [<span class="num">1</span>, <span class="num">2</span>, <span class="num">3</span>]
<span class="kw">CRIA</span> config = { nome: <span class="str">"server"</span>, porta: <span class="num">3000</span> }</pre>
          <p>Reasigna usando <code>=</code>:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto">nome = <span class="str">"XS"</span></pre>
        </section>

        <section id="types">
          <h2 class="text-2xl font-black text-gray-800 mb-3">Tipos</h2>
          <p class="mb-3">XanaScript tiene tipado dinámico con los siguientes primitivos:</p>
          <div class="overflow-x-auto mb-4">
            <table class="w-full text-sm border border-gray-200 rounded-xl">
              <thead><tr><th class="text-left p-3 bg-gray-50 font-semibold">Tipo</th><th class="text-left p-3 bg-gray-50 font-semibold">Ejemplo</th><th class="text-left p-3 bg-gray-50 font-semibold">Notas</th></tr></thead>
              <tbody>
                <tr><td class="p-3 border-t"><code>NUMERO</code></td><td class="p-3 border-t"><code>42</code>, <code>3.14</code></td><td class="p-3 border-t">Doble IEEE 754 (número JS)</td></tr>
                <tr><td class="p-3 border-t"><code>TEXTO</code></td><td class="p-3 border-t"><code>"hello"</code>, <code>`template ${x}`</code></td><td class="p-3 border-t">Plantillas de texto con backticks</td></tr>
                <tr><td class="p-3 border-t"><code>BOOLEANO</code></td><td class="p-3 border-t"><code>VERDADEIRO</code>, <code>FALSO</code></td><td class="p-3 border-t">Literales booleanos en portugués</td></tr>
                <tr><td class="p-3 border-t"><code>NULO</code></td><td class="p-3 border-t"><code>NULO</code></td><td class="p-3 border-t">Valor nulo</td></tr>
                <tr><td class="p-3 border-t"><code>Array</code></td><td class="p-3 border-t"><code>[1, 2, 3]</code></td><td class="p-3 border-t">Arreglos dinámicos, tipos mixtos permitidos</td></tr>
                <tr><td class="p-3 border-t"><code>Object</code></td><td class="p-3 border-t"><code>{ a: 1 }</code></td><td class="p-3 border-t">Pares clave-valor</td></tr>
                <tr><td class="p-3 border-t"><code>FUNCAO</code></td><td class="p-3 border-t"><code>(x) => x * 2</code></td><td class="p-3 border-t">Funciones de primera clase</td></tr>
              </tbody>
            </table>
          </div>
          <p>Verifica tipos en tiempo de ejecución:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto"><span class="kw">SOLTA O GRITO</span>(<span class="fn">TIPO</span>(<span class="num">42</span>))   <span class="cm">// "number"</span>
<span class="kw">SOLTA O GRITO</span>(<span class="fn">TIPO</span>(<span class="str">"xs"</span>)) <span class="cm">// "string"</span></pre>
        </section>

        <section id="control-flow">
          <h2 class="text-2xl font-black text-gray-800 mb-3">Flujo de Control</h2>
          <p class="mb-3">Los condicionales usan palabras clave en portugués:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-4"><span class="kw">SE LIGA SO</span> (x > <span class="num">10</span>) {
  <span class="kw">SOLTA O GRITO</span>(<span class="str">"Greater than 10"</span>)
} <span class="kw">SENAO SE</span> (x > <span class="num">5</span>) {
  <span class="kw">SOLTA O GRITO</span>(<span class="str">"Greater than 5"</span>)
} <span class="kw">SENAO</span> {
  <span class="kw">SOLTA O GRITO</span>(<span class="str">"5 or less"</span>)
}</pre>
          <p class="mb-3">Bucles:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-4"><span class="cm">// Bucle for</span>
<span class="kw">REPETE NA MORAL</span> (<span class="kw">CRIA</span> i = <span class="num">0</span>; i < <span class="num">5</span>; i += <span class="num">1</span>) {
  <span class="kw">SOLTA O GRITO</span>(i)
}

<span class="cm">// Bucle while</span>
<span class="kw">CRIA</span> x = <span class="num">0</span>
<span class="kw">REPETE AI</span> (x < <span class="num">5</span>) {
  <span class="kw">SOLTA O GRITO</span>(x)
  x += <span class="num">1</span>
}

<span class="cm">// Ternario</span>
<span class="kw">CRIA</span> resultado = (x > <span class="num">0</span>) ? <span class="str">"positive"</span> : <span class="str">"negative"</span></pre>
        </section>

        <section id="functions">
          <h2 class="text-2xl font-black text-gray-800 mb-3">Funciones</h2>
          <p class="mb-3">Funciones nombradas y anónimas:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-4"><span class="cm">// Función nombrada</span>
<span class="kw">CHAMA ESSE CARA</span> soma(a, b) {
  <span class="kw">VOLTA</span> a + b
}

<span class="cm">// Función flecha</span>
<span class="kw">CRIA</span> dobro = (x) => x * <span class="num">2</span>

<span class="cm">// Flecha multilínea</span>
<span class="kw">CRIA</span> saudacao = (nome) => {
  <span class="kw">VOLTA</span> <span class="str">"Hello, "</span> + nome + <span class="str">"!"</span>
}

<span class="kw">SOLTA O GRITO</span>(<span class="fn">soma</span>(<span class="num">3</span>, <span class="num">4</span>))
<span class="kw">SOLTA O GRITO</span>(<span class="fn">dobro</span>(<span class="num">5</span>))
<span class="kw">SOLTA O GRITO</span>(<span class="fn">saudacao</span>(<span class="str">"XS"</span>))</pre>
          <p>Se admiten parámetros por defecto y parámetros rest.</p>
        </section>

        <section id="classes">
          <h2 class="text-2xl font-black text-gray-800 mb-3">Clases y POO</h2>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-4"><span class="kw">CLASSE</span> Animal {
  <span class="kw">CONSTRUTOR</span>(nome) {
    <span class="kw">CRIA</span> <span class="kw">ISTO</span>.nome = nome
  }
  <span class="kw">METODO</span> falar() {
    <span class="kw">SOLTA O GRITO</span>(<span class="kw">ISTO</span>.nome + <span class="str">" makes a sound"</span>)
  }
}

<span class="kw">CLASSE</span> Cachorro <span class="kw">HERDA</span> Animal {
  <span class="kw">METODO</span> falar() {
    <span class="kw">SOLTA O GRITO</span>(<span class="kw">ISTO</span>.nome + <span class="str">" says: Woof!"</span>)
  }
}

<span class="kw">CRIA</span> rex = <span class="kw">NOVA</span> Cachorro(<span class="str">"Rex"</span>)
<span class="fn">rex.falar</span>()</pre>
        </section>

        <section id="pattern-matching">
          <h2 class="text-2xl font-black text-gray-800 mb-3">Coincidencia de Patrones</h2>
          <p class="mb-3">Usa <code>COMBINA</code> para una coincidencia de patrones expresiva con desestructuración:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-4"><span class="cm">// Coincidir por valor</span>
<span class="kw">CRIA</span> descrever = (val) => <span class="kw">COMBINA</span> (val) {
  <span class="kw">CASO</span> <span class="num">0</span> => <span class="str">"zero"</span>
  <span class="kw">CASO</span> <span class="num">1</span> => <span class="str">"one"</span>
  <span class="kw">CASO</span> _ => <span class="str">"many"</span>
}

<span class="cm">// Coincidir con arreglos usando desestructuración</span>
<span class="kw">CRIA</span> checkList = (items) => <span class="kw">COMBINA</span> (items) {
  <span class="kw">CASO</span> [] => <span class="str">"empty"</span>
  <span class="kw">CASO</span> [x] => <span class="str">"one item: "</span> + x
  <span class="kw">CASO</span> [x, y] => <span class="str">"two items"</span>
  <span class="kw">CASO</span> _ => <span class="str">"many items"</span>
}</pre>
          <p>El comodín <code>_</code> coincide con cualquier cosa. Los patrones de arreglo admiten desestructuración.</p>
        </section>

        <section id="async">
          <h2 class="text-2xl font-black text-gray-800 mb-3">Async / Await</h2>
          <p class="mb-3">Async/await nativo con <code>ASSINCRONO</code> y <code>ESPERA AI</code>:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-4"><span class="kw">CRIA</span> fetch = <span class="kw">ASSINCRONO</span> (url) => {
  <span class="kw">CRIA</span> res = <span class="kw">ESPERA AI</span> <span class="fn">AGORA VAI</span>(url)
  <span class="kw">CRIA</span> data = <span class="fn">PARSEIA</span>(res)
  <span class="kw">VOLTA</span> data
}

<span class="kw">CRIA</span> run = <span class="kw">ASSINCRONO</span> () => {
  <span class="kw">CRIA</span> users = <span class="kw">ESPERA AI</span> <span class="fn">fetch</span>(<span class="str">"https://api.example.com/users/1"</span>)
  <span class="kw">SOLTA O GRITO</span>(<span class="str">"Name: "</span> + users.nome)
}

<span class="kw">ESPERA AI</span> <span class="fn">run</span>()</pre>
          <p>También admite <code>ESPERA AI(ms)</code> para retardos basados en tiempo.</p>
        </section>

        <section id="error-handling">
          <h2 class="text-2xl font-black text-gray-800 mb-3">Manejo de Errores</h2>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto"><span class="kw">TENTA</span> {
  <span class="kw">CRIA</span> data = <span class="fn">PARSEIA</span>(<span class="str">"{ invalid json }"</span>)
} <span class="kw">PEGA</span> (err) {
  <span class="kw">SOLTA O GRITO</span>(<span class="str">"Error: "</span> + err)
}</pre>
        </section>

        <hr class="border-gray-200">

        <!-- Avanzado -->
        <section id="orm" class="scroll-mt-24">
          <h2 class="text-2xl font-black text-gray-800 mb-3">ORM (TABELA)</h2>
          <p class="mb-3">XanaScript incluye un ORM integrado usando la palabra clave <code>TABELA</code>. Define un esquema y obtén operaciones CRUD automáticas:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-4"><span class="kw">TABELA</span> Product {
  nome: <span class="typ">TEXTO</span>,
  preco: <span class="typ">NUMERO</span>,
  estoque: <span class="typ">NUMERO</span>
}

<span class="kw">CRIA</span> repo = Product

<span class="cm">// Crear</span>
<span class="fn">repo.create</span>({ nome: <span class="str">"Keyboard"</span>, preco: <span class="num">250</span>, estoque: <span class="num">10</span> })

<span class="cm">// Leer todos</span>
<span class="kw">SOLTA O GRITO</span>(<span class="fn">repo.list</span>())

<span class="cm">// Buscar por ID</span>
<span class="kw">SOLTA O GRITO</span>(<span class="fn">repo.find</span>(<span class="num">1</span>))

<span class="cm">// Filtrar con operadores</span>
<span class="kw">CRIA</span> caros = <span class="fn">repo.findWhere</span>({ preco: { $gte: <span class="num">200</span> } })

<span class="cm">// Actualizar</span>
<span class="fn">repo.update</span>(<span class="num">1</span>, { preco: <span class="num">200</span> })

<span class="cm">// Eliminar</span>
<span class="fn">repo.delete</span>(<span class="num">2</span>)</pre>
          <p>Operadores de filtro: <code>$gte</code>, <code>$gt</code>, <code>$lt</code>, <code>$lte</code>, <code>$eq</code>, <code>$ne</code>, <code>$in</code>, <code>$nin</code>.</p>
        </section>

        <section id="macros">
          <h2 class="text-2xl font-black text-gray-800 mb-3">Macros</h2>
          <p class="mb-3">Generación de código en tiempo de compilación con <code>MACRO</code>:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-4"><span class="kw">MACRO</span> <span class="fn">assert</span>(expr) {
  <span class="kw">CRIA</span> cond = expr[<span class="num">1</span>]
  <span class="kw">CRIA</span> code = <span class="fn">TEXTO</span>(cond)
  <span class="kw">VOLTA</span> [
    <span class="str">"SE LIGA SO (!"</span> + code + <span class="str">") { SOLTA O GRITO('Assertion failed: "</span> + code + <span class="str">"') }"</span>
  ]
}

<span class="fn">assert</span>(x > <span class="num">0</span>)  <span class="cm">// Se expande en tiempo de compilación</span></pre>
          <p>Las macros reciben el nodo AST de su argumento y devuelven código transformado.</p>
        </section>

        <section id="wasm">
          <h2 class="text-2xl font-black text-gray-800 mb-3">WebAssembly</h2>
          <p class="mb-3">Compila XanaScript directamente a binario WebAssembly:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-4">xs build --wasm app.xs</pre>
          <p>Esto genera un archivo <code>.wasm</code> que puede ejecutarse en cualquier runtime de WebAssembly (navegadores, WasmEdge, Wasmtime). El compilador utiliza un emisor binario que genera módulos Wasm válidos a partir del AST optimizado de XS.</p>
        </section>

        <section id="http-server">
          <h2 class="text-2xl font-black text-gray-800 mb-3">Servidor HTTP</h2>
          <p class="mb-3">Servidor HTTP integrado con enrutamiento:</p>
          <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-4"><span class="kw">CHAMA ESSE CARA</span> handler(req, res) {
  <span class="kw">SE LIGA SO</span> (req.url == <span class="str">"/"</span>) {
    <span class="fn">res.json</span>({ mensagem: <span class="str">"Hello from XanaScript!"</span> })
  } <span class="kw">SENAO SE</span> (req.url == <span class="str">"/api/data"</span>) {
    <span class="fn">res.json</span>({ items: [<span class="num">1</span>, <span class="num">2</span>, <span class="num">3</span>], total: <span class="num">3</span> })
  } <span class="kw">SENAO</span> {
    <span class="fn">res.status</span>(<span class="num">404</span>).json({ erro: <span class="str">"Not found"</span> })
  }
}

<span class="kw">CRIA SERVIDOR</span>(<span class="num">3000</span>, handler)
<span class="kw">SOLTA O GRITO</span>(<span class="str">"Server running on :3000"</span>)</pre>
        </section>

        <hr class="border-gray-200">

        <!-- Referencia -->
        <section id="builtins">
          <h2 class="text-2xl font-black text-gray-800 mb-3">Funciones Incorporadas</h2>
          <div class="overflow-x-auto mb-4">
            <table class="w-full text-sm border border-gray-200 rounded-xl">
              <thead><tr><th class="text-left p-3 bg-gray-50 font-semibold">Función</th><th class="text-left p-3 bg-gray-50 font-semibold">Descripción</th></tr></thead>
              <tbody>
                <tr><td class="p-3 border-t"><code>SOLTA O GRITO(x)</code></td><td class="p-3 border-t">Imprimir en consola</td></tr>
                <tr><td class="p-3 border-t"><code>AGORA VAI(url)</code></td><td class="p-3 border-t">Solicitud HTTP GET (asíncrona)</td></tr>
                <tr><td class="p-3 border-t"><code>ESPERA AI(ms)</code></td><td class="p-3 border-t">Dormir / retardo (asíncrono)</td></tr>
