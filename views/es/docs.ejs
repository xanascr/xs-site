                <tr><td class="p-3 border-t"><code>PARSEIA(json)</code></td><td class="p-3 border-t">Analizar cadena JSON</td></tr>
                <tr><td class="p-3 border-t"><code>TAMANHO(x)</code></td><td class="p-3 border-t">Longitud de arreglo o cadena</td></tr>
                <tr><td class="p-3 border-t"><code>TIPO(x)</code></td><td class="p-3 border-t">Nombre del tipo de un valor</td></tr>
                <tr><td class="p-3 border-t"><code>OUVE_AQUI(k)</code></td><td class="p-3 border-t">Leer variable de entorno</td></tr>
                <tr><td class="p-3 border-t"><code>OUVE_TUDO()</code></td><td class="p-3 border-t">Arreglo de argumentos de CLI</td></tr>
                <tr><td class="p-3 border-t"><code>CRIA SERVIDOR(p, h)</code></td><td class="p-3 border-t">Iniciar servidor HTTP en el puerto p</td></tr>
