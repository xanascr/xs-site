<%- include('../partials/head', { lang, t, alternates }) %>
<%- include('../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-5xl mx-auto">
    <h1 class="text-3xl md:text-5xl font-black text-center mb-4"><%= t('examples.title') %></h1>
    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-lg font-light"><%= t('examples.subtitle') %></p>

    <div class="grid gap-8">
      <% examples.forEach(function(ex) { %>
      <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
          <h3 class="font-bold text-lg text-gray-800"><%= ex.title %></h3>
          <span class="text-xs font-mono text-gray-400 bg-gray-100 px-2 py-1 rounded"><%= ex.lang %></span>
        </div>
        <div class="p-6">
          <p class="text-gray-500 text-sm mb-4"><%= ex.desc %></p>
          <div class="code-block bg-gray-50 rounded-xl border border-gray-200 overflow-hidden">
            <pre class="p-4 text-sm"><%= ex.code %></pre>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('../partials/footer', { lang, t }) %>
