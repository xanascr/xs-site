<%- include('../partials/head', { lang, t, alternates }) %>
<%- include('../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-6xl mx-auto">
    <h1 class="text-4xl md:text-5xl font-black text-center mb-3"><%= t('examples.title') %></h1>
    <p class="text-center text-gray-400 max-w-xl mx-auto mb-12 text-lg font-light"><%= t('examples.subtitle') %></p>

    <div class="grid gap-8 grid-cols-1 md:grid-cols-2">
      <% examples.forEach(function(ex) { %>
      <div class="bg-[#1a1a2e] rounded-2xl border border-gray-800 overflow-hidden shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200 flex flex-col">
        <div class="px-6 py-4 border-b border-gray-800 flex items-center justify-between">
          <h3 class="font-bold text-lg text-gray-100 truncate"><%= ex.title %></h3>
          <span class="text-xs font-mono text-indigo-400 bg-indigo-900/40 px-2 py-1 rounded shrink-0 ml-2"><%= ex.lang %></span>
        </div>
        <div class="p-6 flex flex-col gap-4 flex-1">
          <p class="text-gray-400 text-sm leading-relaxed"><%= ex.desc %></p>
          <div class="code-block bg-[#0d1117] rounded-xl border border-gray-700 overflow-hidden mt-auto shadow-inner">
            <div class="flex items-center gap-1.5 px-4 py-2 bg-[#161b22] border-b border-gray-700">
              <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
            </div>
            <pre class="p-4 text-xs sm:text-sm overflow-x-auto scrollbar-thin text-gray-100 leading-relaxed font-mono"><%= ex.code %></pre>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('../partials/footer', { lang, t }) %>
