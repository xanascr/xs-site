<%- include('../../partials/head', { lang, t, alternates }) %>
<%- include('../../partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-4xl mx-auto">
    <a href="/<%= lang %>/courses/<%= course.slug %>" class="text-sm text-gray-400 hover:text-pinky-400 no-underline mb-4 inline-block">&larr; Back to course</a>

    <div class="xs-card xs-card-glass animate-fade-in">
      <div class="p-6 sm:p-8">
        <div class="flex items-center justify-between mb-6">
          <div>
            <span class="text-xs text-gray-400 uppercase tracking-wider font-semibold">Lesson <%= (course.lecciones || []).findIndex(function(l) { return l.slug === lesson.slug }) + 1 %> of <%= (course.lecciones || []).length %></span>
            <h1 class="text-2xl sm:text-3xl font-black mt-1"><%= lesson.title %></h1>
          </div>
          <span class="xs-tag xs-tag-primary"><%= lesson.points || 0 %> pts</span>
        </div>

        <div class="prose prose-sm sm:prose max-w-none text-gray-700 mb-8">
          <%= lesson.contentHtml || lesson.content || '' %>
        </div>

        <% if (lesson.Desafios && lesson.Desafios.length > 0) { %>
          <div class="border-t border-gray-200 pt-6 mt-8">
            <h2 class="text-xl font-bold mb-4">Desafios</h2>
            <div id="Desafios" class="space-y-4">
              <% lesson.Desafios.forEach(function(ch, i) { %>
                <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
                  <p class="font-semibold text-sm text-gray-800 mb-2">Challenge <%= i + 1 %>: <%= ch.question %></p>
                  <input type="text" class="challenge-input xs-input w-full" data-idx="<%= i %>" placeholder="Type your answer..." <%= enrollment && enrollment.progress && enrollment.progress.find(function(p) { return p.leccioneslug === lesson.slug }) && enrollment.progress.find(function(p) { return p.leccioneslug === lesson.slug }).Completado ? 'disabled' : '' %>>
                  <div class="challenge-feedback text-xs mt-1 hidden"></div>
                </div>
              <% }) %>
            </div>
            <button id="checkAnswersBtn" class="xs-btn xs-btn-primary mt-4">Verificar Respuestas</button>
          </div>
        <% } %>

        <div class="flex items-center justify-between mt-8 pt-6 border-t border-gray-200">
          <div id="leccionestatus">
            <% if (enrollment && enrollment.progress && enrollment.progress.find(function(p) { return p.leccioneslug === lesson.slug }) && enrollment.progress.find(function(p) { return p.leccioneslug === lesson.slug }).Completado) { %>
              <span class="inline-flex items-center gap-1.5 text-sm text-green-600 font-semibold"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Completado</span>
            <% } else if (enrollment) { %>
              <button id="completeBtn" class="xs-btn xs-btn-primary">Marcar como Completado</button>
            <% } else { %>
              <span class="text-sm text-gray-400">Inscribete para seguir el progreso</span>
            <% } %>
          </div>
          <span id="earnedPoints" class="text-sm text-gray-400"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  var token = localStorage.getItem('xs_token');
  if (!token) return;

  var completeBtn = document.getElementById('completeBtn');
  if (completeBtn) {
    completeBtn.addEventListener('click', function() {
      var answers = [];
      document.querySelectorAll('.challenge-input').forEach(function(inp) {
        answers.push(inp.value);
      });

      fetch('/api/courses/<%= course.slug %>/lecciones/<%= lesson.slug %>/complete', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
        body: JSON.stringify({ answers: answers })
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.ok) {
          window.location.reload();
        } else {
          alert(d.error || 'Failed to complete lesson');
        }
      })
      .catch(function() { alert('Network error'); });
    });
  }

  var checkBtn = document.getElementById('checkAnswersBtn');
  if (checkBtn) {
    checkBtn.addEventListener('click', function() {
      // Client-side answer check
      var answers = JSON.parse('<%= JSON.stringify((lesson.Desafios || []).map(function(c) { return c.answer })).replace(/'/g, "\\'") %>');
      document.querySelectorAll('.challenge-input').forEach(function(inp) {
        var idx = parseInt(inp.dataset.idx);
        var fb = inp.parentElement.querySelector('.challenge-feedback');
        var isCorrect = answers[idx] && inp.value.trim().toLowerCase() === answers[idx].trim().toLowerCase();
        if (isCorrect) {
          inp.classList.remove('border-red-300');
          inp.classList.add('border-green-300', 'bg-green-50');
          fb.textContent = '✓ Correct!';
          fb.classList.remove('text-red-500');
          fb.classList.add('text-green-600');
        } else {
          inp.classList.remove('border-green-300', 'bg-green-50');
          inp.classList.add('border-red-300');
          fb.textContent = '✗ Try again. Hint: ' + (answers[idx] || '');
          fb.classList.remove('text-green-600');
          fb.classList.add('text-red-500');
        }
        fb.classList.remove('hidden');
      });
    });
  }
})();
</script>

<%- include('../../partials/footer', { lang, t }) %>
