<%- include('partials/head', { lang, t, alternates }) %>
<%- include('partials/navbar', { lang, t }) %>

<section class="pt-20 sm:pt-28 pb-20 px-4 sm:px-6 min-h-screen">
  <div class="max-w-4xl mx-auto animate-fade-in">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-3xl font-black">Painel</h1>
      <a href="//settings" class="text-xs text-gray-400 hover:text-pinky-400 no-underline flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Configurações
      </a>
    </div>

    <% if (!user) { %>
      <div class="xs-card xs-card-glass p-8 text-center">
        <p class="text-gray-500 mb-4">Entre para ver seu progresso.</p>
        <a href="/login?redirect=/dashboard" class="xs-btn xs-btn-primary">Entrar</a>
      </div>
    <% } else { %>
      <!-- Stats cards -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 mb-8" id="statsGrid">
        <div class="xs-card xs-card-glass p-4 sm:p-5 text-center animate-up" style="animation-delay:0s">
          <div class="text-2xl font-black text-pinky-500" id="xpDisplay"><%= user.xp || 0 %></div>
          <div class="text-xs text-gray-500 mt-1">XP</div>
        </div>
        <div class="xs-card xs-card-glass p-4 sm:p-5 text-center animate-up" style="animation-delay:0.05s">
          <div class="text-2xl font-black text-pinky-500" id="levelDisplay"><%= user.level || 1 %></div>
          <div class="text-xs text-gray-500 mt-1">Nível</div>
        </div>
        <div class="xs-card xs-card-glass p-4 sm:p-5 text-center animate-up" style="animation-delay:0.1s">
          <div class="text-2xl font-black <%= (user.streak || 0) >= 3 ? 'text-amber-500' : 'text-gray-500' %>" id="streakDisplay"><%= user.streak || 0 %></div>
          <div class="text-xs text-gray-500 mt-1">Dias Seguidos</div>
        </div>
        <div class="xs-card xs-card-glass p-4 sm:p-5 text-center animate-up" style="animation-delay:0.15s">
          <div class="text-2xl font-black text-green-500" id="coursesDisplay">0</div>
          <div class="text-xs text-gray-500 mt-1">Inscrito</div>
        </div>
      </div>

      <!-- XP progress to next level -->
      <% var xp = user.xp || 0 %>
      <% var currentLevel = user.level || 1 %>
      <% var xpInLevel = xp % 200 %>
      <div class="xs-card xs-card-glass p-4 sm:p-6 mb-8">
        <div class="flex items-center justify-between text-sm text-gray-500 mb-2">
          <span>Nível <%= currentLevel %> &mdash; Nível <%= currentLevel + 1 %></span>
          <span><%= xpInLevel %> / 200 XP</span>
        </div>
        <div class="w-full h-3 bg-gray-100 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-pinky-400 to-amber-400 rounded-full transition-all" style="width:<%= (xpInLevel / 200 * 100) %>%"></div>
        </div>
      </div>

      <!-- Learning Roadmap -->
      <h2 class="text-xl font-bold mb-3">Roteiro de Aprendizado</h2>
      <div id="roadmapContainer" class="space-y-2 mb-8">
        <div class="text-center py-8 text-gray-400 text-sm">Carregando recomendações...</div>
      </div>

      <!-- Badges -->
      <h2 class="text-xl font-bold mb-3">Medalhas</h2>
      <div id="badgesGrid" class="flex flex-wrap gap-2 sm:gap-3 mb-8">
        <div class="text-center py-4 text-gray-400 text-sm w-full">Carregando...</div>
      </div>

      <!-- My Courses -->
      <h2 class="text-xl font-bold mb-4">Meus Cursos</h2>
      <div id="enrollmentsList" class="space-y-2 sm:space-y-3">
        <div class="text-center py-8 text-gray-400">Carregando...</div>
      </div>

      <!-- My Packages -->
      <h2 class="text-xl font-bold mb-4 mt-10">Meus Pacotes</h2>
      <div id="myPackagesList" class="space-y-2">
        <div class="text-center py-8 text-gray-400">Carregando...</div>
      </div>
    <% } %>
  </div>
</section>

<script>
(function() {
  var token = localStorage.getItem('xs_token');
  if (!token) return;
  var lang = 'pt';

  // ── Roadmap ──
  (async function() {
    try {
      var res = await fetch('/api/dashboard/roadmap', { headers: { 'Authorization': 'Bearer ' + token } });
      var data = await res.json();
      var container = document.getElementById('roadmapContainer');
      if (!data.ok || !data.recommendations || data.recommendations.length === 0) {
        container.innerHTML = '<div class="text-center py-6 text-gray-400 text-sm">Inscreva-se em um curso para receber recomendações!</div>';
        return;
      }
      container.innerHTML = '';
      data.recommendations.forEach(function(r) {
        if (r.completed) {
          container.innerHTML += '<div class="flex items-center gap-3 bg-green-50 border border-green-200 rounded-xl px-4 py-3">'
            + '<span class="text-green-600 text-lg shrink-0">&#x2714;</span>'
            + '<div class="flex-1 min-w-0"><div class="font-semibold text-sm text-green-800 truncate">' + escapeHtml(r.courseTitle) + '</div><div class="text-xs text-green-600">Todas as aulas concluídas!</div></div></div>';
        } else if (r.notEnrolled) {
          container.innerHTML += '<a href="/courses/' + r.courseSlug + '" class="flex items-center gap-3 bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 no-underline">'
            + '<span class="text-amber-500 text-lg shrink-0">&#x1F525;</span>'
            + '<div class="flex-1 min-w-0"><div class="font-semibold text-sm text-amber-800 truncate">' + escapeHtml(r.courseTitle) + '</div><div class="text-xs text-amber-600">Iniciar este curso</div></div></a>';
        } else {
          container.innerHTML += '<a href="/courses/' + r.courseSlug + '/lessons/' + r.lessonSlug + '" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl px-4 py-3 no-underline transition-all hover:border-pinky-400 hover:shadow-sm">'
            + '<span class="w-7 h-7 rounded-full bg-pinky-400 text-white flex items-center justify-center text-xs font-bold shrink-0">' + r.order + '</span>'
            + '<div class="flex-1 min-w-0">'
            + '<div class="font-semibold text-sm text-gray-800 truncate">' + r.lessonTitle + '</div>'
            + '<div class="text-xs text-gray-400">' + escapeHtml(r.courseTitle) + ' &middot; ' + r.points + ' pts</div>'
            + '</div></a>';
        }
      });
    } catch(e) {
      document.getElementById('roadmapContainer').innerHTML = '<div class="text-center py-6 text-gray-400 text-sm">Falha ao carregar.</div>';
    }
  })();

  // ── Enrollments ──
  (async function() {
    try {
      var res = await fetch('/api/courses/dashboard/enrollments', { headers: { 'Authorization': 'Bearer ' + token } });
      var data = await res.json();
      if (!data.ok) return;
      var enrollments = data.enrollments || [];
      document.getElementById('coursesDisplay').textContent = enrollments.length;
      var list = document.getElementById('enrollmentsList');
      if (enrollments.length === 0) {
        list.innerHTML = '<div class="text-center py-8 text-gray-400">Nenhum curso ainda. <a href="/courses" class="text-pinky-500 underline">Ver cursos</a></div>';
        return;
      }
      list.innerHTML = '';
      enrollments.forEach(function(enc) {
        var course = enc.courseId;
        if (!course || !course.lessons) return;
        var doneCount = (enc.progress || []).filter(function(p) { return p.completed; }).length;
        var totalCount = course.lessons.length;
        var pct = totalCount > 0 ? Math.round(doneCount / totalCount * 100) : 0;
        var nextLesson = (course.lessons || []).find(function(l) {
          var p = (enc.progress || []).find(function(x) { return x.lessonSlug === l.slug; });
          return !p || !p.completed;
        }) || course.lessons[0];
        var label = doneCount === 0 ? 'Iniciar' : (doneCount < totalCount ? 'Continuar' : 'Revisar');
        list.innerHTML += '<a href="/courses/' + course.slug + '/lessons/' + (nextLesson ? nextLesson.slug : '') + '" class="flex items-center gap-3 sm:gap-4 bg-white border border-gray-200 rounded-xl px-4 sm:px-5 py-3 sm:py-4 no-underline transition-all hover:border-pinky-400 hover:shadow-sm">'
          + '<div class="flex-1 min-w-0">'
          + '<div class="font-semibold text-sm text-gray-800 truncate">' + escapeHtml(course.title) + '</div>'
          + '<div class="text-xs text-gray-400 mt-0.5">' + doneCount + '/' + totalCount + ' aulas &middot; ' + (enc.points || 0) + ' pts</div>'
          + '</div>'
          + '<div class="w-20 sm:w-24">'
          + '<div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden">'
          + '<div class="h-full bg-green-500 rounded-full" style="width:' + pct + '%"></div>'
          + '</div></div>'
          + '<span class="text-xs font-semibold text-pinky-400 shrink-0">' + label + '</span></a>';
      });
    } catch(e) {
      document.getElementById('enrollmentsList').innerHTML = '<div class="text-center py-8 text-gray-400">Falha ao carregar.</div>';
    }
  })();

  // ── Badges ──
  (async function() {
    try {
      var res = await fetch('/api/courses/dashboard/badges', { headers: { 'Authorization': 'Bearer ' + token } });
      var data = await res.json();
      if (!data.ok) return;
      var grid = document.getElementById('badgesGrid');
      if (!data.badges || data.badges.length === 0) {
        grid.innerHTML = '<div class="text-center py-4 text-gray-400 text-sm w-full">Complete aulas para ganhar medalhas!</div>';
        return;
      }
      grid.innerHTML = '';
      data.badges.forEach(function(b) {
        grid.innerHTML += '<div class="flex items-center gap-2 bg-white border border-gray-200 rounded-lg px-3 py-2 text-sm" title="' + escapeHtml(b.description) + '">'
          + '<span>' + (b.icon || '\u{1F396}\uFE0F') + '</span>'
          + '<span class="font-medium text-gray-700">' + escapeHtml(b.name) + '</span></div>';
      });
    } catch(e) {}
  })();

  // ── My Packages ──
  (async function() {
    try {
      var res = await fetch('/api/packages/mine', { headers: { 'Authorization': 'Bearer ' + token } });
      var data = await res.json();
      var list = document.getElementById('myPackagesList');
      if (!data.ok || !data.packages) {
        console.warn('Dashboard: packages API response', data);
        list.innerHTML = '<div class="text-center py-8 text-gray-400">Nenhum pacote publicado. <a href="/packages/dashboard" class="text-pinky-500 underline">Publicar um</a></div>';
        return;
      }
      if (data.packages.length === 0) {
        list.innerHTML = '<div class="text-center py-8 text-gray-400">Nenhum pacote publicado. <a href="/packages/dashboard" class="text-pinky-500 underline">Publicar um</a></div>';
        return;
      }
      list.innerHTML = '';
      data.packages.forEach(function(pkg) {
        list.innerHTML += '<a href="/packages/' + pkg.name + '" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl px-4 py-3 no-underline transition-all hover:border-pinky-400 hover:shadow-sm">'
          + '<div class="flex-1 min-w-0">'
          + '<div class="font-semibold text-sm text-gray-800 truncate">' + escapeHtml(pkg.name) + '</div>'
          + '<div class="text-xs text-gray-400">' + (pkg.description ? escapeHtml(pkg.description).slice(0, 80) : '') + ' &middot; ' + (pkg.downloads || 0) + ' downloads</div>'
          + '</div>'
          + '<svg class="w-4 h-4 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>';
      });
    } catch(e) {
      console.error('Dashboard: my packages failed', e);
      document.getElementById('myPackagesList').innerHTML = '<div class="text-center py-8 text-gray-400">Falha ao carregar pacotes.</div>';
    }
  })();

  function escapeHtml(str) {
    var d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }
})();
</script>

<%- include('partials/footer', { lang, t }) %>
