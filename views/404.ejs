<%- include('partials/head', { lang, t, alternates }) %>
<%- include('partials/navbar', { lang, t }) %>

<section class="pt-28 pb-20 px-4 sm:px-6 min-h-[80vh] flex items-center justify-center">
  <div class="max-w-lg mx-auto text-center animate-fade-in">
    <div class="text-8xl sm:text-9xl font-black text-pinky-200 mb-4">404</div>
    <h1 class="text-3xl sm:text-4xl font-black mb-4 tracking-tight">
      SE LIGA SO,
    </h1>
    <p class="text-xl text-gray-500 mb-2">esta página <span class="text-pinky-400 font-semibold">não existe</span>!</p>
    <div class="text-sm text-gray-400 mb-8 max-w-sm mx-auto leading-relaxed">
      Parece que você tentou acessar um recurso que não foi definido — ou talvez tenha digitado errado no terminal.
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 mb-8 text-left font-mono text-sm">
      <div class="text-gray-400 mb-1">$ xs route --debug</div>
      <div class="text-red-500">ERRO: Rota não encontrada em <span class="text-pinky-400">nenhum</span> módulo.</div>
      <div class="text-gray-400 mt-2">Dica: use <span class="text-pinky-400 font-semibold">t(404)</span> ou volte ao início.</div>
    </div>
    <div class="flex items-center justify-center gap-3">
      <a href="/" class="xs-btn xs-btn-primary">Voltar ao início</a>
      <a href="/courses" class="xs-btn xs-btn-ghost">Ver cursos</a>
    </div>
  </div>
</section>

<%- include('partials/footer', { lang, t }) %>