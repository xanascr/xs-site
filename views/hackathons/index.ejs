<%- include('../layouts/main', { body: `
<div class="max-w-6xl mx-auto px-4 py-12">
  <h1 class="font-heading font-800 text-3xl mb-8">Hackathons</h1>
  <div class="grid md:grid-cols-2 gap-6">
    <% hackathons.forEach(h => { %>
      <a href="/hackathons/<%= h._id %>" class="block bg-bg-2 border border-border rounded p-6 hover:border-primary transition-colors group">
        <div class="flex items-start justify-between mb-3">
          <h2 class="font-heading font-700 text-lg group-hover:text-primary transition-colors"><%= h.title %></h2>
          <span class="text-xs px-2 py-1 rounded <%= h.active ? 'bg-success/10 text-success' : 'bg-bg-3 text-text-2' %>"><%= h.active ? 'Ativo' : 'Encerrado' %></span>
        </div>
        <p class="text-text-2 text-sm line-clamp-2"><%= h.description %></p>
        <div class="flex gap-4 mt-4 text-xs text-text-2">
          <span>Início: <%= new Date(h.startDate).toLocaleDateString() %></span>
          <span>Fim: <%= new Date(h.endDate).toLocaleDateString() %></span>
        </div>
      </a>
    <% }) %>
  </div>
</div>
`}) %>
